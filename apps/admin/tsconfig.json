{
	"compilerOptions": {
		"strict": true,
		"esModuleInterop": true,
		"jsx": "react-jsx",
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"verbatimModuleSyntax": true,
		"skipLibCheck": true,
		"types": ["vite/client"],
		"rootDirs": [".", "../.."],
		"baseUrl": ".",
		"paths": {
			"@vit/api": ["../../packages/api/dist/index.d.ts"],
			"@vit/api/*": ["../../packages/api/dist/*"],
			"@vit/shared": ["../../packages/shared/src/index.ts"],
			"@vit/shared/*": ["../../packages/shared/src/*"],
			"@/*": ["./src/*"],
			"@server/*": ["../server/src/*"],
			"server/alchemy": ["../server/alchemy.run.ts"]
		}
	},
	"include": ["**/*.ts", "../../env.ts"]
}
