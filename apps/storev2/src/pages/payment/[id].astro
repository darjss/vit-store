---

import PaymentOptions from "@/components/payment/payment-options";
import { env } from "cloudflare:workers";
import Layout from "@/layouts/Layout.astro";
import { paymentSuccessUrl } from "@/lib/payment-url";
import { loadPaymentOrRedirect } from "@/lib/server-loaders";
import { createServerClient } from "@/lib/trpc";
import { CardIcon as IconCreditCard } from "@solar-icons/solid/linear";

const { id } = Astro.params;
if (!id) {
     return Astro.redirect("/404");
}
const cookieHeader = Astro.request.headers.get("cookie") || "";
const serverApi = createServerClient(cookieHeader, env.server, Astro.redirect);
const checkoutToken = Astro.url.searchParams.get("ct") || undefined;
const result = await loadPaymentOrRedirect(serverApi, id, checkoutToken, Astro.redirect);
if ("redirect" in result) return result.redirect;
const payment = result.payment;

if (payment.status === "success") {
    return Astro.redirect(paymentSuccessUrl(payment.paymentNumber, checkoutToken));
}
---

<Layout>
    <div class="container mx-auto px-3 py-4 sm:px-4 sm:py-6 max-w-3xl min-h-screen">
        <div class="mb-4 sm:mb-6">
            <div class="enter-rise rounded-2xl border border-border bg-card p-4 shadow-soft mb-3 sm:mb-4">
                <div class="flex items-center gap-3">
                    <div class="flex size-11 shrink-0 items-center justify-center rounded-full bg-wash-lemon">
                        <IconCreditCard class="h-5 w-5" aria-hidden="true" />
                    </div>
                    <div class="flex-1 min-w-0">
                        <h1 class="font-display text-lg text-foreground sm:text-xl">
                            Төлбөр төлөх
                        </h1>
                        <p class="text-xs sm:text-sm text-muted-foreground mt-0.5">
                            #{payment.order.orderNumber}
                        </p>
                    </div>
                </div>
            </div>

            <div class="enter-rise stagger-1 rounded-2xl border border-border bg-card shadow-soft mb-4 sm:mb-6">
                <div class="p-3 sm:p-4 space-y-3">
                    <div class="flex items-center justify-between rounded-xl bg-wash-lemon px-3.5 py-2.5">
                        <span class="text-xs sm:text-sm font-semibold text-foreground/70">Нийт дүн</span>
                        <span class="font-display text-lg sm:text-xl text-foreground">{payment.total.toLocaleString()}₮</span>
                    </div>
                    <div class="space-y-2">
                        {payment.order.products.map((product) => (
                            <div class="flex items-center gap-2.5 sm:gap-3 rounded-xl p-2 sm:p-2.5 bg-muted/30">
                                {product.imageUrl && (
                                    <img
                                        src={product.imageUrl}
                                        alt={product.name}
                                        class="size-10 sm:size-12 object-cover rounded-lg shrink-0"
                                    />
                                )}
                                <span class="text-xs sm:text-sm font-medium text-foreground flex-1 line-clamp-2">{product.name}</span>
                                <span class="text-xs font-semibold text-muted-foreground px-2 py-0.5 rounded-full bg-muted shrink-0 tabular-nums">{product.quantity}x</span>
                            </div>
                        ))}
                    </div>
                </div>
            </div>
        </div>

        <div class="enter-rise stagger-2">
            <PaymentOptions
                paymentNumber={id}
                orderNumber={payment.order.orderNumber}
                total={payment.total}
                customerPhone={payment.order.customerPhone}
                accountNumber={payment.transferAccount.accountNumber}
                accountName={payment.transferAccount.accountName}
                provider={payment.provider}
                checkoutToken={checkoutToken}
                client:only="solid-js"
            >
                <div slot="fallback" class="w-full rounded-2xl border border-border bg-card p-4 shadow-soft">
                    <div class="h-10 w-full animate-pulse rounded-xl bg-muted/40"></div>
                </div>
            </PaymentOptions>
        </div>
    </div>
</Layout>
