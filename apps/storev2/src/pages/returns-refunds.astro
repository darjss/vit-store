---
import Layout from "@/layouts/Layout.astro";
import IconCheck from "~icons/ri/check-line";

const title = "Буцаалт ба Буцаан олголт";
const description = "Amerik Vitamin-ийн бараа буцаалт, буцаан олголтын бодлого. Бид бараа буцаалт хүлээн авдаггүй.";

const reasons = [
  "Бүтээгдэхүүнүүд маань АНУ-аас шууд импортлогдсон жинхэнэ бүтээгдэхүүнүүд юм.",
  "Хүнсний нэмэлт тэжээл нь нээсний дараа буцааж борлуулах боломжгүй байдаг.",
  "Импортын барааны онцлогоос шалтгаалан буцаалт хүлээн авах боломжгүй.",
];
---

<Layout title={title} description={description} noindex nofollow>
  <div class="container mx-auto max-w-[65ch] px-5 py-8 lg:px-8 lg:py-14">
    <!-- Header -->
    <header class="enter-rise mb-10">
      <h1 class="mb-2 font-display text-foreground text-h2">Буцаалт ба Буцаан олголт</h1>
      <p class="text-muted-foreground text-sm md:text-base">
        Бид бараа буцаалт хүлээн авдаггүй
      </p>
    </header>

    <div class="enter-rise stagger-1 space-y-10">
      <section>
        <h2 class="mb-3 font-display text-foreground text-lg">Буцаалт хүлээн авдаггүй</h2>
        <p class="mb-5 text-muted-foreground text-sm leading-relaxed md:text-base">
          Бид АНУ-аас шууд оруулж ирсэн жинхэнэ бүтээгдэхүүнүүдийг борлуулдаг тул бараа буцаалт хүлээн авдаггүй.
        </p>

        <h3 class="mb-3 font-display text-foreground text-sm">Яагаад буцаалт хүлээн авдаггүй вэ?</h3>
        <ul class="space-y-3">
          {reasons.map((reason) => (
            <li class="flex items-start gap-3 text-muted-foreground text-sm leading-relaxed md:text-base">
              <span class="mt-0.5 flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full bg-wash-mint text-foreground">
                <IconCheck class="h-3.5 w-3.5" />
              </span>
              <span>{reason}</span>
            </li>
          ))}
        </ul>
      </section>

      <section class="rounded-2xl bg-wash-lemon/70 p-5 md:p-6">
        <h3 class="mb-2 font-display text-foreground text-sm">Бүтээгдэхүүнээ сайтар сонгоно уу</h3>
        <p class="text-foreground text-sm leading-relaxed">
          Захиалга өгөхөөс өмнө бүтээгдэхүүний тайлбар, найрлага, хэмжээг сайтар уншиж,
          өөртөө тохирох эсэхийг нягтлан шалгана уу. Асуулт байвал бидэнтэй <a href="/contact" class="font-semibold underline underline-offset-4 transition-colors duration-150 hover:text-cocoa">холбогдоно уу</a>.
        </p>
      </section>

      <section>
        <h2 class="mb-3 font-display text-foreground text-lg">Буцаан олголт</h2>
        <p class="text-muted-foreground text-sm leading-relaxed md:text-base">
          Бид <strong class="text-foreground">буцаан олголт хийдэггүй</strong>. Төлбөр төлсний дараа захиалгыг цуцлах боломжгүй.
          Хэрэв бүтээгдэхүүний чанарт асуудал гарвал бидэнтэй утсаар холбогдож шийдвэрлүүлэх боломжтой.
        </p>
      </section>

      <section>
        <h2 class="mb-4 font-display text-foreground text-lg">Бид юу хийж чаддаг вэ?</h2>
        <div class="space-y-6">
          <div>
            <h3 class="mb-2 font-display text-foreground text-sm">Чанарын асуудал</h3>
            <p class="text-muted-foreground text-sm leading-relaxed md:text-base">
              Хэрэв бүтээгдэхүүний чанарт асуудал гарвал бидэнтэй холбогдож, асуудлыг шийдвэрлэнэ үү.
            </p>
          </div>
          <div>
            <h3 class="mb-2 font-display text-foreground text-sm">Зөвлөгөө</h3>
            <p class="text-muted-foreground text-sm leading-relaxed md:text-base">
              Бүтээгдэхүүн сонгохоос өмнө биднээс зөвлөгөө авах боломжтой. Утсаар холбогдоно уу.
            </p>
          </div>
        </div>
      </section>
    </div>
  </div>
</Layout>
