---
import Layout from "@/layouts/Layout.astro";
import IconAlert from "~icons/ri/alert-line";
import IconClose from "~icons/ri/close-circle-line";
import IconCheck from "~icons/ri/check-line";

const title = "Буцаалт ба Буцаан олголт";
const description = "Amerik Vitamin-ийн бараа буцаалт, буцаан олголтын бодлого. Бид бараа буцаалт хүлээн авдаггүй.";
---

<Layout title={title} description={description} noindex nofollow>
  <div class="container mx-auto px-5 py-8 lg:px-8 lg:py-14 max-w-4xl">
    <!-- Header -->
    <div class="mb-8 lg:mb-10">
      <div class="border border-border bg-destructive p-4 lg:p-6 shadow-soft-lg mb-4 text-destructive-foreground">
        <h1 class="text-2xl md:text-3xl lg:text-4xl font-extrabold uppercase tracking-tight">
          Буцаалт ба Буцаан олголт
        </h1>
        <p class="text-sm font-medium mt-2 opacity-80">
          Бид бараа буцаалт хүлээн авдаггүй
        </p>
      </div>
    </div>

    <!-- Main Policy Statement -->
    <div class="border border-border bg-card p-5 lg:p-8 shadow-soft-sm mb-8">
      <div class="flex items-start gap-4 mb-6">
        <div class="w-12 h-12 border border-border bg-destructive flex items-center justify-center shrink-0">
          <IconClose class="w-6 h-6 text-destructive-foreground" />
        </div>
        <div>
          <h2 class="text-xl font-extrabold uppercase tracking-tight">Буцаалт хүлээн авдаггүй</h2>
          <p class="text-sm font-medium text-muted-foreground mt-1">
            Бид АНУ-аас шууд оруулж ирсэн жинхэнэ бүтээгдэхүүнүүдийг борлуулдаг тул бараа буцаалт хүлээн авдаггүй.
          </p>
        </div>
      </div>

      <div class="space-y-4">
        <div class="border border-border bg-muted/30 p-4">
          <h3 class="font-extrabold text-sm uppercase tracking-wider mb-2">Яагаад буцаалт хүлээн авдаггүй вэ?</h3>
          <ul class="text-sm font-medium text-muted-foreground leading-relaxed space-y-2">
            <li class="flex items-start gap-2">
              <IconCheck class="w-4 h-4 mt-0.5 text-primary shrink-0" />
              <span>Бүтээгдэхүүнүүд маань АНУ-аас шууд импортлогдсон жинхэнэ бүтээгдэхүүнүүд юм.</span>
            </li>
            <li class="flex items-start gap-2">
              <IconCheck class="w-4 h-4 mt-0.5 text-primary shrink-0" />
              <span>Хүнсний нэмэлт тэжээл нь нээсний дараа буцааж борлуулах боломжгүй байдаг.</span>
            </li>
            <li class="flex items-start gap-2">
              <IconCheck class="w-4 h-4 mt-0.5 text-primary shrink-0" />
              <span>Импортын барааны онцлогоос шалтгаалан буцаалт хүлээн авах боломжгүй.</span>
            </li>
          </ul>
        </div>

        <div class="border border-border bg-yellow-50 p-4">
          <div class="flex items-start gap-3">
            <IconAlert class="w-5 h-5 mt-0.5 text-yellow-700 shrink-0" />
            <div>
              <h3 class="font-extrabold text-sm uppercase tracking-wider mb-2">Бүтээгдэхүүнээ сайтар сонгоно уу</h3>
              <p class="text-sm font-medium leading-relaxed">
                Захиалга өгөхөөс өмнө бүтээгдэхүүний тайлбар, найрлага, хэмжээг сайтар уншиж, 
                өөртөө тохирох эсэхийг нягтлан шалгана уу. Асуулт байвал бидэнтэй <a href="/contact" class="font-extrabold underline decoration-2 underline-offset-4">холбогдоно уу</a>.
              </p>
            </div>
          </div>
        </div>

        <div class="border border-border bg-primary/10 p-4">
          <h3 class="font-extrabold text-sm uppercase tracking-wider mb-2">Буцаан олголт</h3>
          <p class="text-sm font-medium text-muted-foreground leading-relaxed">
            Бид <strong>буцаан олголт хийдэггүй</strong>. Төлбөр төлсний дараа захиалгыг цуцлах боломжгүй. 
            Хэрэв бүтээгдэхүүний чанарт асуудал гарвал бидэнтэй утсаар холбогдож шийдвэрлүүлэх боломжтой.
          </p>
        </div>
      </div>
    </div>

    <!-- What we DO offer -->
    <div class="border border-border bg-card p-5 lg:p-6 shadow-soft-sm">
      <h2 class="text-lg font-extrabold uppercase tracking-tight mb-4">Бид юу хийж чаддаг вэ?</h2>
      <div class="grid gap-3 md:grid-cols-2">
        <div class="border border-border bg-muted/30 p-4">
          <div class="font-extrabold text-sm uppercase tracking-wider mb-1">Чанарын асуудал</div>
          <p class="text-xs font-medium text-muted-foreground">
            Хэрэв бүтээгдэхүүний чанарт асуудал гарвал бидэнтэй холбогдож, асуудлыг шийдвэрлэнэ үү.
          </p>
        </div>
        <div class="border border-border bg-muted/30 p-4">
          <div class="font-extrabold text-sm uppercase tracking-wider mb-1">Зөвлөгөө</div>
          <p class="text-xs font-medium text-muted-foreground">
            Бүтээгдэхүүн сонгохоос өмнө биднээс зөвлөгөө авах боломжтой. Утсаар холбогдоно уу.
          </p>
        </div>
      </div>
    </div>
  </div>
</Layout>
