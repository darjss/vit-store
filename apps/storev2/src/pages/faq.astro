---
import Layout from "@/layouts/Layout.astro";
import { AltArrowDownIcon as IconArrowDown } from "@solar-icons/solid/linear";

const title = "Түгээмэл асуулт хариулт";
const description = "Amerik Vitamin-ийн тухай түгээмэл асуулт, хариулт. Бүтээгдэхүүн, хүргэлт, төлбөрийн талаар.";

const faqs = [
  {
    q: "Бүтээгдэхүүнүүд хаанаас ирдэг вэ?",
    a: "Бүтээгдэхүүнүүд маань бүгд АНУ-аас шууд импортлогдсон жинхэнэ, баталгаат бүтээгдэхүүнүүд юм. Бид олон улсын алдартай брэндүүдийн бүтээгдэхүүнүүдийг шууд нийлүүлдэг.",
  },
  {
    q: "Хүргэлт хэр удаж байна вэ?",
    a: "Захиалгыг өдөр бүр 12:00 цагаас хойш хүргэнэ. Өглөөний захиалгыг өдөрт нь, оройн захиалгыг маргааш хүргэнэ. Улаанбаатар хотын бүх дүүрэгт хүргэлт хийнэ.",
  },
  {
    q: "Хөдөө орон нутаг руу хүргэлт хийдэг үү?",
    a: 'Тийм ээ, бид хөдөө орон нутаг руу хүргэлт хийнэ. "Замын Унаа"-ар илгээдэг бөгөөд тээврийн зардал хүлээн авагчийн хариуцах болно.',
  },
  {
    q: "Бараа буцааж болох уу?",
    a: "Уучлаарай, бид бараа буцаалт хүлээн авдаггүй. Импортын хүнсний нэмэлт тэжээлийн онцлогоос шалтгаалан буцаалт хүлээн авах боломжгүй. Захиалга өгөхөөс өмнө бүтээгдэхүүнээ сайтар сонгоно уу.",
  },
  {
    q: "Мөнгө буцаан олгох боломжтой юу?",
    a: "Бид буцаан олголт хийдэггүй. Төлбөр төлсний дараа захиалгыг цуцлах боломжгүй. Хэрэв чанарын асуудал гарвал бидэнтэй холбогдоно уу.",
  },
  {
    q: "Төлбөрийн ямар хэлбэр хүлээн авдаг вэ?",
    a: "Бид дансаар шилжүүлэх болон QPay-ээр төлбөр хүлээн авдаг. QPay ашиглан бүх банкны апп-аар хурдан төлбөр хийх боломжтой.",
  },
  {
    q: "Бүтээгдэхүүн жинхэнэ гэдгийг хэрхэн мэдэх вэ?",
    a: "Бүтээгдэхүүнүүд маань АНУ-аас шууд ирсэн бөгөөд GMP, FDA бүртгэлтэй үйлдвэрүүдээс нийлүүлдэг. Бид хуурамч бүтээгдэхүүн борлуулдаггүй.",
  },
  {
    q: "Захиалгаа хэрхэн хянах вэ?",
    a: 'Та <a href="/order-tracking" class="font-semibold text-foreground underline underline-offset-4">Захиалга хянах</a> хуудас руу ороод захиалгын дугаар, утасны дугаараа оруулан захиалгынхаа төлөвийг хянах боломжтой.',
  },
  {
    q: "Хүргэлтийн хураамж хэд вэ?",
    a: "Улаанбаатар хотод хүргэлтийн хураамж стандарт 6,000₮. Хөдөө орон нутаг руу хүргэхдээ 'Замын Унаа'-ар илгээдэг бөгөөд тээврийн зардал хүлээн авагчийн хариуцах болно.",
  },
  {
    q: "Утасны дугаараар нэвтрэх боломжтой юу?",
    a: "Тийм ээ, бид OTP баталгаажуулалт ашиглан утасны дугаараар нэвтрэх боломжыг олгодог. Нэвтэрсний дараа захиалгынхаа түүхийг харах боломжтой.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.a.replace(/<[^>]*>/g, ""),
    },
  })),
};
---

<Layout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <div class="container mx-auto max-w-2xl px-5 py-8 lg:px-8 lg:py-14">
    <!-- Header -->
    <div class="enter-rise mb-8 lg:mb-10">
      <h1 class="mb-2 font-display text-foreground text-h2">Түгээмэл асуулт хариулт</h1>
      <p class="text-muted-foreground text-sm md:text-base">
        Таны мэдэхийг хүссэн бүх зүйл
      </p>
    </div>

    <!-- FAQ List -->
    <div class="enter-rise stagger-1 divide-y divide-border overflow-hidden rounded-2xl border border-border bg-card shadow-soft">
      {faqs.map((faq) => (
        <details class="group">
          <summary class="flex min-h-[44px] cursor-pointer select-none list-none items-center justify-between gap-4 p-4 transition-[background-color] duration-150 ease-out hover:bg-muted/60 md:p-5 [&::-webkit-details-marker]:hidden">
            <h3 class="font-semibold text-foreground text-sm leading-snug md:text-base">{faq.q}</h3>
            <IconArrowDown class="h-5 w-5 flex-shrink-0 text-muted-foreground transition-transform duration-200 ease-out group-open:rotate-180" />
          </summary>
          <div class="max-w-[65ch] px-4 pb-5 md:px-5">
            <p class="text-muted-foreground text-sm leading-relaxed" set:html={faq.a} />
          </div>
        </details>
      ))}
    </div>

    <!-- Still have questions -->
    <div class="enter-rise stagger-2 mt-6 rounded-2xl bg-wash-peach/60 p-5 md:p-6">
      <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
        <div>
          <h2 class="font-display text-foreground text-lg">Асуулт байна уу?</h2>
          <p class="mt-1 text-muted-foreground text-sm">
            Бидэнтэй шууд холбогдож асуултаа асууна уу
          </p>
        </div>
        <a
          href="/contact"
          class="inline-flex min-h-11 items-center justify-center rounded-full bg-primary px-6 py-2.5 font-semibold text-primary-foreground text-sm shadow-lift transition-[transform,box-shadow] duration-150 ease-out hover:-translate-y-0.5 hover:shadow-lift-lg active:scale-[0.97]"
        >
          Холбогдох
        </a>
      </div>
    </div>
  </div>
</Layout>
