---
import OrderTrackingForm from "@/components/order-tracking-form";
import Layout from "@/layouts/Layout.astro";

const title = "Захиалга хянах";
const description = "Amerik Vitamin - захиалгынхаа төлөвийг хянах. Утасны дугаар, захиалгын дугаараа оруулан мэдээлэл авах.";
---

<Layout title={title} description={description}>
  <div class="container mx-auto max-w-2xl px-5 py-8 lg:px-8 lg:py-14">
    <div class="enter-rise mb-8 text-center">
      <h1 class="mb-2 font-display text-foreground text-h2">Захиалга хянах</h1>
      <p class="text-muted-foreground text-sm md:text-base">
        Захиалгын дугаар, утасны дугаараа оруулан мэдээлэл авах
      </p>
    </div>

    <OrderTrackingForm client:load />
  </div>
</Layout>
