---
import Layout from "@/layouts/Layout.astro";

const title = "Нууцлалын бодлого";
const description = "Amerik Vitamin-ийн нууцлалын бодлого. Хэрэглэгчийн мэдээлэл хэрхэн хадгалагддаг, хамгаалагддаг талаар.";

const sections = [
  {
    heading: "1. Мэдээлэл цуглуулах",
    body: "Бид зөвхөн захиалга хийхэд шаардлагатай мэдээллийг цуглуулдаг. Үүнд: утасны дугаар, хүргэлтийн хаяг, захиалгын түүх багтана. Бид таны и-мэйл хаяг, нэр, овог зэрэг нэмэлт мэдээллийг шаарддаггүй.",
  },
  {
    heading: "2. Мэдээллийн ашиглалт",
    body: "Цуглуулсан мэдээллийг зөвхөн захиалгыг боловсруулах, хүргэлт хийх, төлбөр хүлээн авах зорилгоор ашиглана. Бид таны мэдээллийг гуравдагч этгээдэд худалдах, шилжүүлэхгүй.",
  },
  {
    heading: "3. Cookie бодлого",
    body: "Бид cookie ашигладаггүй. Таны хөтөчөнд ямар ч мэдээлэл хадгалахгүй. Зөвхөн нэвтэрсэн хэрэглэгчдийн хувьд session token ашиглан нэвтрэлтийг хадгалдаг.",
  },
  {
    heading: "4. Мэдээлэл хадгалах",
    body: "Таны мэдээлэл аюулгүй сервер дээр хадгалагдана. Бид мэдээллийн аюулгүй байдлыг хангахын тулд хамгийн сүүлийн үеийн технологиудыг ашигладаг.",
  },
];
---

<Layout title={title} description={description} noindex nofollow>
  <div class="container mx-auto max-w-[65ch] px-5 py-8 lg:px-8 lg:py-14">
    <!-- Header -->
    <header class="enter-rise mb-10">
      <h1 class="mb-2 font-display text-foreground text-h2">Нууцлалын бодлого</h1>
      <p class="text-muted-foreground text-sm md:text-base">
        Таны мэдээллийн аюулгүй байдал бидний нэгдүгээр зорилт
      </p>
    </header>

    <div class="enter-rise stagger-1 space-y-10">
      {sections.map((section) => (
        <section>
          <h2 class="mb-3 font-display text-foreground text-lg">{section.heading}</h2>
          <p class="text-muted-foreground text-sm leading-relaxed md:text-base">
            {section.body}
          </p>
        </section>
      ))}

      <section>
        <h2 class="mb-3 font-display text-foreground text-lg">5. Холбоо барих</h2>
        <p class="mb-4 text-muted-foreground text-sm leading-relaxed md:text-base">
          Нууцлалын бодлоготой холбоотой асуулт байвал бидэнтэй холбогдоно уу.
        </p>
        <div class="flex flex-wrap gap-3">
          <a
            href="tel:+97699993950"
            class="inline-flex min-h-11 items-center gap-2 rounded-full border border-border bg-card px-5 py-2.5 font-semibold text-foreground text-sm shadow-soft-sm transition-[transform,box-shadow,background-color] duration-150 ease-out hover:bg-muted hover:shadow-soft active:scale-[0.97]"
          >
            Утас: 9999-3950
          </a>
          <a
            href="mailto:info@amerikvitamin.mn"
            class="inline-flex min-h-11 items-center gap-2 rounded-full border border-border bg-card px-5 py-2.5 font-semibold text-foreground text-sm shadow-soft-sm transition-[transform,box-shadow,background-color] duration-150 ease-out hover:bg-muted hover:shadow-soft active:scale-[0.97]"
          >
            И-мэйл: info@amerikvitamin.mn
          </a>
        </div>
      </section>
    </div>
  </div>
</Layout>
