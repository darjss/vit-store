---
import SearchPage from "@/components/search/search-page";
import Layout from "@/layouts/Layout.astro";

export const prerender = false;

const title = "Хайлт";
const description = "Америк Витамин дэлгүүрээс бүтээгдэхүүн хайх.";
---

<Layout title={title} description={description} noindex>
	<div class="min-h-[calc(100vh-200px)]">
		<SearchPage client:load>
			<div slot="fallback" class="mx-auto max-w-screen-2xl px-4 py-8 sm:px-6">
				<div class="border border-border bg-primary/10 px-4 py-4 rounded-lg shadow-soft sm:px-6">
					<div class="h-8 w-48 mb-4 animate-pulse bg-foreground/10"></div>
					<div class="h-14 w-full animate-pulse bg-foreground/10 rounded-lg"></div>
				</div>
				<div class="mt-6 flex flex-col gap-3">
					<div class="flex animate-pulse items-stretch gap-4 border border-border bg-background p-2 rounded-lg shadow-soft">
						<div class="h-28 w-28 shrink-0 border border-border bg-muted rounded-lg sm:h-32 sm:w-32"></div>
						<div class="flex flex-1 flex-col justify-between py-1">
							<div class="space-y-3">
								<div class="h-5 w-3/4 rounded bg-muted"></div>
								<div class="h-4 w-1/2 rounded bg-muted"></div>
							</div>
							<div class="flex items-end justify-between">
								<div class="h-6 w-1/3 rounded bg-muted"></div>
								<div class="h-10 w-10 rounded bg-muted"></div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</SearchPage>
	</div>
</Layout>
