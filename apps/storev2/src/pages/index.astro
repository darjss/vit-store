---
import HomeProductCard from "@/components/product/home-product-card.astro";
import Layout from "@/layouts/Layout.astro";
import { productColors } from "@/lib/constant";
import { toProductImageUrl } from "@/lib/image";
import { api } from "@/lib/trpc";
import type { ProductForHome } from "@/lib/types";
import { formatCurrency } from "@/lib/utils";

export const prerender = true;

const products = await api.product.getProductsForHomeWithStock.query();
const { featuredProducts, newProducts } = products;
const brands = await api.brand.getAllBrandsWithStock.query();
const allCategories = await api.category.getAllCategoriesWithStock.query();

const preferredCategoryNames = [
  "Дархлаа",
  "Гоо сайхан",
  "Энерги",
  "Яс үе мөч",
  "Зүрх судас",
  "Ходоод гэдэс",
  "Нойр",
  "Тархи мэдрэл",
];

const orderedCategories = [
  ...preferredCategoryNames
    .map((name) => allCategories.find((c: { id: number; name: string }) => c.name === name))
    .filter(Boolean),
  ...allCategories.filter(
    (c: { id: number; name: string }) => !preferredCategoryNames.includes(c.name),
  ),
];

const categoriesForPills = orderedCategories.slice(0, 10) as Array<{
  id: number;
  name: string;
  slug: string;
}>;

const heroPatterns = ["bg-pattern-dots", "bg-pattern-blobs", "bg-pattern-diagonal", "bg-pattern-rings"];
const heroPatternColors = ["#E8C94A", "#D4A5A5", "#C4D89E", "#A8C8E0"];
---

<Layout
  image="/og-landing.png"
  imageAlt="Америк Витамин - АНУ-ын витамин, нэмэлт тэжээл"
>
  <!-- ==================== HERO ==================== -->
  <section class="border-b border-border bg-hero-warm">
    <!-- Mobile: stacked. Desktop: split -->
    <div class="grid lg:grid-cols-2">
      <!-- Text -->
      <div class="px-5 pt-8 pb-6 lg:px-14 lg:py-28 lg:border-r border-border flex flex-col justify-center min-w-0 overflow-hidden">
        <h1 class="text-[28px] leading-[1.05] sm:text-h1 font-extrabold tracking-tighter mb-4 break-words">
          Өргөн сонголттой<br/>
          <span class="relative inline-block text-foreground">
            витам<span class="relative">ин<span class="absolute -bottom-1 left-0 right-0 h-2 bg-primary/40 -z-10"></span></span>, боломжийн үнээр.
          </span>
        </h1>
        <p class="text-[13px] md:text-base font-semibold text-muted-foreground leading-relaxed mb-6 max-w-md break-words">
          Өдөр тутам авдаг витамин, нэмэлт тэжээлийг нэг дороос. Үнэ нь боломжийн, сонголт нь өргөн, хүргэлт нь шуурхай.
        </p>

        <!-- Trust row — compact on mobile -->
        <div class="relative flex gap-3 mb-5 overflow-x-auto scrollbar-hide -mx-5 px-5 pb-1">
          <div class="pointer-events-none absolute right-0 top-0 bottom-1 w-8 bg-gradient-to-l from-background to-transparent z-10" aria-hidden="true" />
          {[
            { val: "Хямд", label: "Үнэ" },
            { val: "Өргөн", label: "Сонголт" },
            { val: "Шуурхай", label: "Хүргэлт" },
          ].map((s) => (
            <div class="flex-none flex items-center gap-1.5 rounded-full px-3.5 py-2 border border-border bg-card shadow-soft-sm">
              <span class="w-1.5 h-1.5 rounded-full bg-primary"></span>
              <span class="font-bold text-sm">{s.val}</span>
              <span class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">{s.label}</span>
            </div>
          ))}
        </div>

        <div class="flex flex-wrap items-center gap-3">
          <a href="/products" class="px-7 py-3.5 rounded-lg bg-primary text-primary-foreground font-bold text-[13px] uppercase tracking-wider border border-primary shadow-soft hover:shadow-soft-lg hover:-translate-y-0.5 active:scale-[0.97] transition-[box-shadow,transform] duration-200 ease-out-quart">
            Бүтээгдэхүүн үзэх
          </a>
          <a href="#featured-products" class="px-5 py-3.5 rounded-lg bg-card text-foreground font-bold text-xs uppercase tracking-wider border border-border shadow-soft-sm hover:bg-muted hover:shadow-soft hover:border-primary active:scale-[0.97] transition-[background-color,box-shadow,transform,border-color] duration-200 ease-out-quart">
            Онцлох сонголт
          </a>
        </div>
      </div>

      <!-- Hero product showcase — rotating crossfade, one product at a time.
           CSS-only, no JS. Each product floats gently while visible.
           Pauses on hover/touch. Respects reduced-motion. -->
      <div class="hero-showcase relative border-t lg:border-t-0 border-border bg-hero-warm overflow-hidden h-[300px] lg:h-[520px]">
        {featuredProducts.slice(0, 4).map((p: ProductForHome, i: number) => {
          const heroPattern = heroPatterns[i % heroPatterns.length];
          const colorIdx = p.id % productColors.length;
          const cycleDelay = `${-i * 3.5}s`;
          return (
          <a
            href={`/products/${p.slug}-${p.id}/`}
            class="hero-product absolute inset-0 block active:scale-[0.97] transition-transform duration-200 ease-out-quart"
            style={`animation-delay: ${cycleDelay};`}
          >
            <div
              class={`relative h-full overflow-hidden ${heroPattern}`}
              style={`background-color: ${productColors[colorIdx]}; --pattern-color: ${heroPatternColors[i % heroPatternColors.length]}50;`}
            >
              {p.image && (
                <img
                  src={toProductImageUrl(p.image, "feature") || p.image}
                  alt={p.name}
                  class="absolute inset-0 w-full h-full object-contain p-8 md:p-12 lg:p-16 hero-product-img"
                  style={`animation-delay: ${cycleDelay};`}
                  width="480"
                  height="480"
                  loading="eager"
                  decoding="async"
                />
              )}
              <!-- Brand chip — top left -->
              <div class="absolute top-3 left-3 md:top-5 md:left-5">
                <span class="rounded-full bg-card/90 backdrop-blur-sm px-2.5 py-1 text-[10px] font-bold uppercase tracking-wider text-muted-foreground shadow-soft-sm">
                  {p.brand}
                </span>
              </div>
              <!-- Product name + price — bottom left, stacked -->
              <div class="absolute bottom-3 left-3 right-3 md:bottom-5 md:left-5 md:right-5">
                <div class="line-clamp-1 font-bold text-sm md:text-base text-foreground/80 mb-1.5">{p.name}</div>
                <span class="inline-flex items-center rounded-full bg-secondary px-3 py-1.5 text-sm font-bold text-secondary-foreground shadow-soft">
                  {formatCurrency(p.price)}
                </span>
              </div>
            </div>
          </a>
          );
        })}
        <!-- Dot indicators -->
        <div class="absolute top-3 right-3 md:top-5 md:right-5 flex gap-1.5 z-10">
          {featuredProducts.slice(0, 4).map((_: ProductForHome, i: number) => (
            <span
              class="hero-dot w-1.5 h-1.5 rounded-full bg-foreground/20"
              style={`animation-delay: ${-i * 3.5}s;`}
            />
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== BRAND MARQUEE ==================== -->
  <section class="border-b border-border bg-muted overflow-hidden">
    <div class="group/marquee">
      <div class="py-3 lg:py-3.5 flex items-center gap-8 whitespace-nowrap group-hover/marquee:[animation-play-state:paused] group-focus-within/marquee:[animation-play-state:paused]" style="animation: brand-scroll-4 35s linear infinite;">
        {[...Array(4)].map(() => brands.map((brand: {name: string; slug: string}) => (
          <a href={`/products/brand/${brand.slug}/1/`} class="text-sm lg:text-base font-extrabold uppercase tracking-wider text-foreground/80 flex items-center gap-8 hover:text-foreground transition-colors">
            {brand.name}
            <span class="w-2 h-2 bg-primary rotate-45 block"></span>
          </a>
        )))}
      </div>
    </div>
  </section>

  <!-- ==================== CATEGORIES — Swipeable pills ==================== -->
  <section class="border-b border-border">
    <div class="px-5 py-3.5 lg:px-8">
      <div class="flex gap-2 overflow-x-auto scrollbar-hide -mx-5 px-5">
        {categoriesForPills.map((cat) => (
          <a href={`/products/category/${cat.slug}/1/`} class="flex-none rounded-full px-4 py-2 border border-border bg-card font-bold text-xs uppercase tracking-wider shadow-soft-sm hover:bg-primary hover:text-primary-foreground hover:border-primary hover:shadow-soft active:scale-[0.97] transition-[box-shadow,transform,background-color,border-color] duration-200 ease-out-quart">
            {cat.name}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== FEATURED ==================== -->
  <section id="featured-products" class="border-b border-border scroll-mt-20">
    <div class="px-5 pt-[var(--space-section-sm)] pb-[var(--space-section-md)] lg:px-8 lg:py-[var(--space-section-lg)]">
      <!-- Section header -->
      <div class="mb-6">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2.5">
            <span class="w-1.5 h-7 rounded-full bg-primary"></span>
            <h2 class="text-h2 font-extrabold tracking-tight">Онцлох</h2>
          </div>
          <a href="/products?filter=featured" class="text-xs font-bold uppercase tracking-wider text-muted-foreground hover:text-primary transition-colors">Бүгд →</a>
        </div>
        <p class="text-sm text-muted-foreground font-semibold mt-1.5">Үнэ, эрэлт хоёроороо хамгийн их сонгогддог бүтээгдэхүүнүүд</p>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-2.5 lg:gap-4">
        {featuredProducts.map((p: ProductForHome) => (
          <HomeProductCard product={p} />
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== DELIVERY PROMO STRIP ==================== -->
  <section class="border-b border-border bg-secondary text-secondary-foreground">
    <div class="px-5 py-5 lg:px-8 lg:py-6 flex items-center gap-4 overflow-hidden">
      <div class="flex-1 min-w-0">
        <div class="flex items-baseline gap-2 flex-wrap">
          <span class="text-lg lg:text-xl font-extrabold tracking-tight">Захиалга өгсөн</span>
          <span class="text-lg lg:text-xl font-extrabold tracking-tight text-primary">маргааш хүргэгдэнэ</span>
        </div>
        <p class="text-sm font-semibold text-secondary-foreground/70 mt-0.5">Улаанбаатар хотоор, 6,000₮ шуурхай хүргэлт</p>
      </div>
      <div class="shrink-0 w-12 h-12 lg:w-14 lg:h-14 rounded-full bg-primary flex items-center justify-center">
        <svg class="w-6 h-6 lg:w-7 lg:h-7 text-primary-foreground" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 18a2 2 0 1 0 4 0a2 2 0 0 0 -4 0"/>
          <path d="M15 18a2 2 0 1 0 4 0a2 2 0 0 0 -4 0"/>
          <path d="M3 7l2 8h12l2 -8"/>
          <path d="M3 7l1.5 -4h15l1.5 4"/>
        </svg>
      </div>
    </div>
  </section>

  <!-- ==================== NEW ARRIVALS — Swipeable row ==================== -->
  <section class="border-b border-border">
    <div class="px-5 pt-[var(--space-section-sm)] pb-[var(--space-section-md)] lg:px-8 lg:py-[var(--space-section-lg)]">
      <div class="flex items-center justify-between mb-1">
        <div class="flex items-center gap-2.5">
          <span class="w-1.5 h-7 rounded-full bg-primary"></span>
          <h2 class="text-h2 font-extrabold tracking-tight">Шинэ ирсэн</h2>
        </div>
        <a href="/products?filter=recent" class="text-xs font-bold uppercase tracking-wider text-muted-foreground hover:text-primary transition-colors">Бүгд →</a>
      </div>
      <p class="text-sm text-muted-foreground font-semibold mb-5">Шинээр орж ирсэн болон шинээр нэмэгдсэн төрлүүд</p>

      <div class="flex gap-2.5 overflow-x-auto scrollbar-hide -mx-5 px-5 pb-2 snap-x snap-mandatory lg:grid lg:grid-cols-4 lg:mx-0 lg:px-0 lg:pb-0 lg:gap-4">
        {newProducts.map((p: ProductForHome) => (
          <HomeProductCard product={p} class="flex-none w-[165px] lg:w-auto snap-start" />
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== SHOP BY NEED — Visual category grid ==================== -->
  <section class="border-b border-border bg-muted/40">
    <div class="px-5 py-8 lg:px-8 lg:py-14">
      <div class="flex items-center gap-2.5 mb-1">
        <span class="w-1.5 h-7 rounded-full bg-primary"></span>
        <h2 class="text-h2 font-extrabold tracking-tight">Хэрэгцээгээрээ сонго</h2>
      </div>
      <p class="text-sm text-muted-foreground font-semibold mb-5">Өөрийн хэрэгцээнд тохирох төрлүүд</p>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-2.5 lg:gap-3">
        {[
          { name: "Дархлаа", slug: "darhlaa", color: "#F5DC7A", pattern: "#E8C94A", patternClass: "bg-pattern-dots", icon: "M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" },
          { name: "Гоо сайхан", slug: "goo-saihan", color: "#F4B0C4", pattern: "#E298AD", patternClass: "bg-pattern-blobs", icon: "M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 16.8 5.8 21.3l2.4-7.4L2 9.4h7.6z" },
          { name: "Энерги", slug: "energi", color: "#F5D05E", pattern: "#E8B53A", patternClass: "bg-pattern-diagonal", icon: "M13 2L3 14h9l-1 8 10-12h-9z" },
          { name: "Яс үе мөч", slug: "yas-uye-moch", color: "#B8DCA0", pattern: "#9CC870", patternClass: "bg-pattern-cross", icon: "M12 2a7 7 0 0 0-7 7c0 3 2 5 2 7v5h10v-5c0-2 2-4 2-7a7 7 0 0 0-7-7z" },
          { name: "Зүрх судас", slug: "zurh-sudas", color: "#F2A0A8", pattern: "#E0858E", patternClass: "bg-pattern-rings", icon: "M12 21s-7-4.5-9.5-9C0 8 2 4 6 4c2 0 4 1 6 3 2-2 4-3 6-3 4 0 6 4 3.5 8C19 16.5 12 21 12 21z" },
          { name: "Ходоод гэдэс", slug: "hodoog-gedes", color: "#A8D098", pattern: "#8CB860", patternClass: "bg-pattern-wave", icon: "M3 12c0-5 4-9 9-9s9 4 9 9c0 3-2 5-4 6l-2 3h-6l-2-3c-2-1-4-3-4-6z" },
          { name: "Нойр", slug: "noir", color: "#A0C4E0", pattern: "#84A8C8", patternClass: "bg-pattern-wave", icon: "M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z" },
          { name: "Тархи мэдрэл", slug: "tarhi-mydrel", color: "#9CD0C4", pattern: "#80B8A8", patternClass: "bg-pattern-rings", icon: "M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-5 0v-3a2.5 2.5 0 0 1-2.5-2.5 2.5 2.5 0 0 1 0-5A2.5 2.5 0 0 1 7 6.5v-2A2.5 2.5 0 0 1 9.5 2z" },
        ].map((cat) => (
          <a
            href={`/products/category/${cat.slug}/1/`}
            class={`group relative overflow-hidden rounded-xl border border-border p-4 lg:p-5 ${cat.patternClass} shadow-soft hover:shadow-soft-lg hover:-translate-y-0.5 active:scale-[0.97] transition-[box-shadow,transform] duration-200 ease-out-quart`}
            style={`background-color: ${cat.color}; --pattern-color: ${cat.pattern}60;`}
          >
            <div class="relative z-10 flex flex-col items-start gap-3">
              <div class="w-10 h-10 lg:w-11 lg:h-11 rounded-full bg-card/80 backdrop-blur-sm flex items-center justify-center border border-border shadow-soft-sm">
                <svg class="w-5 h-5 text-foreground" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d={cat.icon}/>
                </svg>
              </div>
              <div>
                <h3 class="font-extrabold text-sm lg:text-base leading-tight">{cat.name}</h3>
                <span class="text-xs font-bold uppercase tracking-wider text-foreground/60 mt-0.5 inline-block">Сонгох →</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== FINAL CTA ==================== -->
  <section class="px-5 py-10 lg:px-8 lg:py-16">
    <div class="rounded-2xl border border-primary bg-primary p-6 lg:p-14 shadow-soft-lg relative overflow-hidden bg-pattern-dots" style="--pattern-color: oklch(0.22 0.012 95 / 0.08);">
      <!-- Decorative yellow glow -->
      <div class="absolute -top-12 -right-12 w-48 h-48 rounded-full bg-primary-foreground/10 blur-2xl" aria-hidden="true"></div>
      <div class="absolute -bottom-16 -left-16 w-56 h-56 rounded-full bg-primary-foreground/10 blur-3xl" aria-hidden="true"></div>
      <div class="relative z-10 max-w-lg mx-auto text-center">
        <h2 class="text-h2 font-extrabold tracking-tight mb-3">Хэрэгтэйгээ нэг дороос сонго</h2>
        <p class="text-sm md:text-base font-semibold mb-6 text-primary-foreground/70">
          Боломжийн үнэтэй витамин, нэмэлт тэжээлийг ангилал бүрээр нь харьцуулж үзээд, захиалгаа хурдан өг.
        </p>
        <a href="/products" class="inline-flex px-8 py-3.5 rounded-lg bg-primary-foreground text-primary font-bold text-sm uppercase tracking-wider border border-primary-foreground shadow-soft hover:shadow-soft-lg hover:-translate-y-0.5 active:scale-[0.97] transition-[box-shadow,transform] duration-200 ease-out-quart">
          Бүх бүтээгдэхүүн үзэх
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  @keyframes brand-scroll-4 {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* === Hero rotating product showcase ===
     4 products, 14s total cycle, each visible 3.5s.
     Crossfade with slight scale. Negative animation-delay
     offsets each product to its slot in the cycle.
     Pauses on hover/touch via .hero-showcase:hover. */
  @keyframes hero-product-cycle {
    0% { opacity: 0; transform: scale(1.02); pointer-events: none; }
    3%, 22% { opacity: 1; transform: scale(1); pointer-events: auto; }
    25%, 100% { opacity: 0; transform: scale(0.98); pointer-events: none; }
  }

  .hero-product {
    animation: hero-product-cycle 14s var(--ease-in-out) infinite;
  }

  /* Image breathes gently while its parent is visible */
  @keyframes hero-img-breathe {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-8px) scale(1.04); }
  }

  .hero-product-img {
    animation: hero-img-breathe 5s var(--ease-in-out) infinite;
  }

  /* Dot indicators — active dot fills dark */
  @keyframes hero-dot-active {
    0%, 3% { background-color: oklch(0.30 0.012 95 / 0.2); transform: scale(1); }
    5%, 22% { background-color: oklch(0.22 0.012 95); transform: scale(1.3); }
    25%, 100% { background-color: oklch(0.30 0.012 95 / 0.2); transform: scale(1); }
  }

  .hero-dot {
    animation: hero-dot-active 14s var(--ease-in-out) infinite;
  }

  /* Pause on hover/touch */
  .hero-showcase:hover .hero-product,
  .hero-showcase:hover .hero-product-img,
  .hero-showcase:hover .hero-dot {
    animation-play-state: paused;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-product {
      animation: none;
      opacity: 1;
      position: relative;
    }
    .hero-product:not(:first-child) {
      display: none;
    }
    .hero-product-img,
    .hero-dot {
      animation: none;
    }
  }
</style>
