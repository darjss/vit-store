---
import HomeProductCard from "@/components/product/home-product-card.astro";
import Layout from "@/layouts/Layout.astro";
import { toProductImageUrl } from "@/lib/image";
import { api } from "@/lib/trpc";
import type { ProductForHome } from "@/lib/types";
import { formatCurrency } from "@/lib/utils";
import { washBg } from "@/lib/wash";
import IconTruck from "~icons/ri/truck-line";
import IconShield from "~icons/ri/shield-check-line";
import IconPhone from "~icons/ri/phone-line";

export const prerender = true;

type CategoryTile = {
  id: number;
  name: string;
  slug: string;
  productCount: number;
};

type BrandRow = {
  id: number;
  name: string;
  slug: string;
  logoUrl: string | null;
  productCount: number;
};

const products = await api.product.getProductsForHomeWithStock.query();
const { featuredProducts, newProducts } = products;
const brands = await api.brand.getAllBrandsWithStock.query();
const allCategories = await api.category.getAllCategoriesWithStock.query();

const preferredCategoryNames = [
  "Дархлаа",
  "Гоо сайхан",
  "Энерги",
  "Яс үе мөч",
  "Зүрх судас",
  "Ходоод гэдэс",
  "Нойр",
  "Тархи мэдрэл",
];

const orderedCategories = [
  ...preferredCategoryNames
    .map((name) => allCategories.find((c: CategoryTile) => c.name === name))
    .filter((c: CategoryTile | undefined): c is CategoryTile => Boolean(c)),
  ...allCategories.filter(
    (c: CategoryTile) => !preferredCategoryNames.includes(c.name),
  ),
];

const categoryTiles = orderedCategories.slice(0, 8);
const heroProduct: ProductForHome | undefined = featuredProducts[0];
const shelfProducts: ProductForHome[] = featuredProducts.slice(0, 8);
const gridProducts: ProductForHome[] = newProducts.slice(0, 4);
const brandRow: BrandRow[] = brands.slice(0, 10);
---

<Layout
  image="/og-landing.png"
  imageAlt="Америк Витамин - АНУ-ын витамин, нэмэлт тэжээл"
>
  <!-- ==================== 1. HERO ==================== -->
  <section class="bg-hero-warm">
    <div class="mx-auto grid max-w-6xl gap-8 px-5 pt-9 pb-12 lg:grid-cols-[1.1fr_1fr] lg:items-center lg:gap-14 lg:px-8 lg:pt-16 lg:pb-20">
      <!-- Text -->
      <div class="min-w-0">
        <h1 class="enter-rise font-display text-h1 font-semibold mb-4 break-words">
          Өргөн сонголттой витамин, боломжийн үнээр
        </h1>
        <p class="enter-rise stagger-1 text-sm md:text-base font-medium text-muted-foreground leading-relaxed mb-6 max-w-md break-words">
          Өдөр тутам авдаг витамин, нэмэлт тэжээлийг нэг дороос. Үнэ нь боломжийн, сонголт нь өргөн, хүргэлт нь шуурхай.
        </p>
        <div class="enter-rise stagger-2 mb-4">
          <a
            href="/products"
            class="inline-flex h-12 items-center justify-center rounded-full bg-primary px-7 text-sm md:text-base font-semibold text-primary-foreground shadow-lift transition-[transform,box-shadow] duration-[140ms] ease-out hover:-translate-y-[2px] hover:shadow-lift-lg active:translate-y-0 active:scale-[0.97] active:shadow-none"
          >
            Бүтээгдэхүүн үзэх
          </a>
        </div>
        <p class="enter-rise stagger-3 text-[13px] font-semibold text-muted-foreground">
          АНУ-аас албан ёсоор ирдэг жинхэнэ бүтээгдэхүүн · 10:30-аас өмнө захиалбал өдөртөө хүргэнэ
        </p>
      </div>

      <!-- Static product moment -->
      {heroProduct && (
        <div class="enter-scale stagger-2 relative">
          <a
            href={`/products/${heroProduct.slug}-${heroProduct.id}/`}
            class="group block active:scale-[0.98] transition-transform duration-200 ease-out-quart"
          >
            <div class="relative overflow-hidden rounded-3xl bg-wash-peach shadow-soft-lg aspect-[4/3] lg:aspect-square">
              <img
                src={toProductImageUrl(heroProduct.image, "feature") || heroProduct.image}
                alt={heroProduct.name}
                class="absolute inset-0 h-full w-full object-contain p-8 lg:p-14 transition-transform duration-300 ease-out-quart group-hover:scale-[1.03]"
                width="480"
                height="480"
                loading="eager"
                decoding="async"
              />
              <span class="absolute top-4 left-4 rounded-full bg-card/90 px-2.5 py-1 text-[10px] font-bold uppercase tracking-wider text-muted-foreground shadow-soft-sm">
                {heroProduct.brand}
              </span>
              <div class="absolute bottom-4 left-4 right-4 flex items-end justify-between gap-3">
                <span class="line-clamp-2 max-w-[60%] text-sm font-semibold leading-snug text-foreground/80">
                  {heroProduct.name}
                </span>
                <span class="inline-flex items-center rounded-full bg-card px-3.5 py-1.5 font-display text-sm font-semibold shadow-soft">
                  {formatCurrency(heroProduct.price)}
                </span>
              </div>
            </div>
          </a>
          <span class="hero-sticker absolute -top-3 right-5 inline-flex -rotate-3 items-center rounded-full border-2 border-cocoa bg-card px-3 py-1 text-xs font-bold text-foreground shadow-pop-sm">
            100% жинхэнэ
          </span>
        </div>
      )}
    </div>
  </section>

  <!-- ==================== BRAND MARQUEE ==================== -->
  <section class="border-b border-border bg-muted overflow-hidden">
    <div class="group/marquee">
      <div class="py-3 lg:py-3.5 flex items-center gap-8 whitespace-nowrap group-hover/marquee:[animation-play-state:paused] group-focus-within/marquee:[animation-play-state:paused]" style="animation: brand-scroll-4 35s linear infinite;">
        {[...Array(4)].map(() => brands.map((brand: {name: string; slug: string}) => (
          <a href={`/products/brand/${brand.slug}/1/`} class="text-sm lg:text-base font-extrabold uppercase tracking-wider text-foreground/80 flex items-center gap-8 hover:text-foreground transition-colors">
            {brand.name}
            <span class="w-2 h-2 bg-primary rotate-45 block"></span>
          </a>
        )))}
      </div>
    </div>
  </section>

  <!-- ==================== 2. CATEGORY TILES ==================== -->
  <section>
    <div class="mx-auto max-w-6xl px-5 pt-10 pb-8 lg:px-8 lg:pt-16 lg:pb-12">
      <h2 data-reveal class="font-display text-h2 font-semibold mb-1">Хэрэгцээгээрээ сонго</h2>
      <p data-reveal class="text-sm font-medium text-muted-foreground mb-5">Өөрийн хэрэгцээнд тохирох төрлүүд</p>
      <div data-reveal-group class="grid grid-cols-2 gap-2.5 lg:grid-cols-4 lg:gap-3">
        {categoryTiles.map((cat) => (
          <a
            href={`/products/category/${cat.slug}/1/`}
            class={`${washBg(cat.slug)} group flex min-h-[96px] flex-col justify-between rounded-2xl p-4 shadow-soft transition-[box-shadow,transform] duration-200 ease-out-quart hover:-translate-y-0.5 hover:shadow-soft-lg active:translate-y-0 active:scale-[0.98] lg:min-h-[112px] lg:p-5`}
          >
            <h3 class="text-sm font-bold leading-snug lg:text-base">{cat.name}</h3>
            <span class="text-xs font-semibold text-foreground/60">{cat.productCount} бүтээгдэхүүн</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== FEATURED ==================== -->
  <section id="featured-products" class="border-b border-border scroll-mt-20">
    <div class="px-5 pt-[var(--space-section-sm)] pb-[var(--space-section-md)] lg:px-8 lg:py-[var(--space-section-lg)]">
      <!-- Section header -->
      <div class="mb-6">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2.5">
            <span class="w-1.5 h-7 rounded-full bg-primary"></span>
            <h2 class="text-h2 font-extrabold tracking-tight">Онцлох</h2>
          </div>
          <a href="/products?filter=featured" class="text-xs font-bold uppercase tracking-wider text-muted-foreground hover:text-primary transition-colors">Бүгд →</a>
        </div>
        <p class="text-sm text-muted-foreground font-semibold mt-1.5">Үнэ, эрэлт хоёроороо хамгийн их сонгогддог бүтээгдэхүүнүүд</p>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-2.5 lg:gap-4">
        {featuredProducts.map((p: ProductForHome) => (
          <HomeProductCard product={p} />
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== DELIVERY PROMO STRIP ==================== -->
  <section class="border-b border-border bg-secondary text-secondary-foreground">
    <div class="px-5 py-5 lg:px-8 lg:py-6 flex items-center gap-4 overflow-hidden">
      <div class="flex-1 min-w-0">
        <div class="flex items-baseline gap-2 flex-wrap">
          <span class="text-lg lg:text-xl font-extrabold tracking-tight">Захиалга өгсөн</span>
          <span class="text-lg lg:text-xl font-extrabold tracking-tight text-primary">маргааш хүргэгдэнэ</span>
        </div>
        <p class="text-sm font-semibold text-secondary-foreground/70 mt-0.5">Улаанбаатар хотоор, 6,000₮ шуурхай хүргэлт</p>
      </div>
      <div class="shrink-0 w-12 h-12 lg:w-14 lg:h-14 rounded-full bg-primary flex items-center justify-center">
        <svg class="w-6 h-6 lg:w-7 lg:h-7 text-primary-foreground" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 18a2 2 0 1 0 4 0a2 2 0 0 0 -4 0"/>
          <path d="M15 18a2 2 0 1 0 4 0a2 2 0 0 0 -4 0"/>
          <path d="M3 7l2 8h12l2 -8"/>
          <path d="M3 7l1.5 -4h15l1.5 4"/>
        </svg>
      </div>
    </div>
  </section>

  <!-- ==================== NEW ARRIVALS — Swipeable row ==================== -->
  <section class="border-b border-border">
    <div class="px-5 pt-[var(--space-section-sm)] pb-[var(--space-section-md)] lg:px-8 lg:py-[var(--space-section-lg)]">
      <div class="flex items-center justify-between mb-1">
        <div class="flex items-center gap-2.5">
          <span class="w-1.5 h-7 rounded-full bg-primary"></span>
          <h2 class="text-h2 font-extrabold tracking-tight">Шинэ ирсэн</h2>
        </div>
        <a href="/products?filter=recent" class="text-xs font-bold uppercase tracking-wider text-muted-foreground hover:text-primary transition-colors">Бүгд →</a>
      </div>
      <p class="text-sm text-muted-foreground font-semibold mb-5">Шинээр орж ирсэн болон шинээр нэмэгдсэн төрлүүд</p>

      <div class="flex gap-2.5 overflow-x-auto scrollbar-hide -mx-5 px-5 pb-2 snap-x snap-mandatory lg:grid lg:grid-cols-4 lg:mx-0 lg:px-0 lg:pb-0 lg:gap-4">
        {newProducts.map((p: ProductForHome) => (
          <HomeProductCard product={p} class="flex-none w-[165px] lg:w-auto snap-start" />
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== FINAL CTA ==================== -->
  <section class="px-5 py-10 lg:px-8 lg:py-16">
    <div class="rounded-2xl border border-primary bg-primary p-6 lg:p-14 shadow-soft-lg relative overflow-hidden bg-pattern-dots" style="--pattern-color: oklch(0.22 0.012 95 / 0.08);">
      <!-- Decorative yellow glow -->
      <div class="absolute -top-12 -right-12 w-48 h-48 rounded-full bg-primary-foreground/10 blur-2xl" aria-hidden="true"></div>
      <div class="absolute -bottom-16 -left-16 w-56 h-56 rounded-full bg-primary-foreground/10 blur-3xl" aria-hidden="true"></div>
      <div class="relative z-10 max-w-lg mx-auto text-center">
        <h2 class="text-h2 font-extrabold tracking-tight mb-3">Хэрэгтэйгээ нэг дороос сонго</h2>
        <p class="text-sm md:text-base font-semibold mb-6 text-primary-foreground/70">
          Боломжийн үнэтэй витамин, нэмэлт тэжээлийг ангилал бүрээр нь харьцуулж үзээд, захиалгаа хурдан өг.
        </p>
        <a href="/products" class="inline-flex px-8 py-3.5 rounded-lg bg-primary-foreground text-primary font-bold text-sm uppercase tracking-wider border border-primary-foreground shadow-soft hover:shadow-soft-lg hover:-translate-y-0.5 active:scale-[0.97] transition-[box-shadow,transform] duration-200 ease-out-quart">
          Бүх бүтээгдэхүүн үзэх
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  @keyframes brand-scroll-4 {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* Sticker pops last: small spring overshoot after the staggered hero entrance. */
  @keyframes sticker-pop {
    from {
      opacity: 0;
      transform: scale(0.8) rotate(4deg);
    }
    to {
      opacity: 1;
      transform: scale(1) rotate(-3deg);
    }
  }

  .hero-sticker {
    animation: sticker-pop 450ms cubic-bezier(0.34, 1.56, 0.64, 1) 380ms backwards;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-sticker {
      animation: none;
    }
  }
</style>
