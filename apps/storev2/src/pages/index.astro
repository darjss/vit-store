---
import HomeProductCard from "@/components/product/home-product-card.astro";
import Layout from "@/layouts/Layout.astro";
import { productColors } from "@/lib/constant";
import { toProductImageUrl } from "@/lib/image";
import { api } from "@/lib/trpc";
import type { ProductForHome } from "@/lib/types";
import { formatCurrency } from "@/lib/utils";

export const prerender = true;

const products = await api.product.getProductsForHomeWithStock.query();
const { featuredProducts, newProducts } = products;
const brands = await api.brand.getAllBrandsWithStock.query();
const allCategories = await api.category.getAllCategoriesWithStock.query();

const preferredCategoryNames = [
  "Дархлаа",
  "Гоо сайхан",
  "Энерги",
  "Яс үе мөч",
  "Зүрх судас",
  "Ходоод гэдэс",
  "Нойр",
  "Тархи мэдрэл",
];

const orderedCategories = [
  ...preferredCategoryNames
    .map((name) => allCategories.find((c: { id: number; name: string }) => c.name === name))
    .filter(Boolean),
  ...allCategories.filter(
    (c: { id: number; name: string }) => !preferredCategoryNames.includes(c.name),
  ),
];

const categoriesForPills = orderedCategories.slice(0, 10) as Array<{
  id: number;
  name: string;
  slug: string;
}>;
---

<Layout
  image="/og-landing.png"
  imageAlt="Америк Витамин - АНУ-ын витамин, нэмэлт тэжээл"
>
  <!-- DESIGN 4 v2: "SPLIT EDITORIAL" — Mobile-first rewrite -->
  <!-- 99% mobile traffic. Every section designed for thumb-scrolling first. -->

  <!-- ==================== HERO ==================== -->
  <section class="border-b-2 border-border">
    <!-- Mobile: stacked. Desktop: split -->
    <div class="grid lg:grid-cols-2">
      <!-- Text -->
      <div class="px-5 pt-8 pb-6 lg:px-14 lg:py-28 lg:border-r-2 border-border flex flex-col justify-center">
        <span class="text-[10px] font-bold uppercase tracking-[0.25em] text-muted-foreground mb-3">amerikvitamin.mn</span>
        <h1 class="text-[32px] leading-[0.95] md:text-5xl lg:text-6xl font-black uppercase tracking-tighter mb-4">
          Өргөн сонголттой<br/>
          <span class="text-primary">витамин, боломжийн үнээр.</span>
        </h1>
        <p class="text-[13px] md:text-base font-medium text-muted-foreground leading-relaxed mb-6 max-w-md">
          Өдөр тутам авдаг витамин, нэмэлт тэжээлийг нэг дороос. Үнэ нь боломжийн, сонголт нь өргөн, хүргэлт нь шуурхай.
        </p>

        <!-- Trust row — compact on mobile -->
        <div class="relative flex gap-3 mb-5 overflow-x-auto scrollbar-hide -mx-5 px-5 pb-1">
          <div class="pointer-events-none absolute right-0 top-0 bottom-1 w-8 bg-gradient-to-l from-background to-transparent z-10" aria-hidden="true" />
          {[
            { val: "Хямд", label: "Үнэ" },
            { val: "Өргөн", label: "Сонголт" },
            { val: "Шуурхай", label: "Хүргэлт" },
          ].map((s) => (
            <div class="flex-none flex items-center gap-1.5 px-3 py-1.5 border-2 border-border bg-muted/30">
              <span class="font-black text-sm">{s.val}</span>
              <span class="text-[8px] font-bold uppercase tracking-wider text-muted-foreground">{s.label}</span>
            </div>
          ))}
        </div>

        <div class="flex flex-wrap items-center gap-2.5">
          <a href="/products" class="px-7 py-3 bg-foreground text-background font-black text-[13px] uppercase tracking-wider border-2 border-foreground shadow-hard-sm active:translate-x-[2px] active:translate-y-[2px] active:shadow-none transition-all">
            Бүтээгдэхүүн үзэх
          </a>
          <a href="#featured-products" class="px-4 py-3 bg-card text-foreground font-black text-[12px] uppercase tracking-wider border-2 border-border active:bg-primary transition-colors">
            Онцлох сонголт
          </a>
        </div>
      </div>

      <!-- Hero products: 2x2 grid, always visible -->
      <div class="grid grid-cols-2 border-t-2 lg:border-t-0 border-border">
        {featuredProducts.slice(0, 4).map((p: ProductForHome, i: number) => (
          <a href={`/products/${p.slug}-${p.id}/`} class={`group relative block min-w-0 overflow-hidden ${i < 2 ? 'border-b-2 border-border' : ''} ${i % 2 === 0 ? 'border-r-2 border-border' : ''}`}>
            <div class="relative aspect-square overflow-hidden" style={`background: ${productColors[p.id % productColors.length]}`}>
              {p.image && (
                <img src={toProductImageUrl(p.image, "feature") || p.image} alt={p.name} class="absolute inset-0 w-full h-full object-contain p-5 md:p-6 group-hover:scale-105 transition-transform duration-500" width="480" height="480" loading="eager" decoding="async" />
              )}
            </div>
            <!-- Always-visible label on mobile (no hover state needed) -->
            <div class="absolute bottom-0 inset-x-0 bg-card/95 border-t-2 border-border p-2 md:p-3">
              <div class="text-[8px] font-bold uppercase tracking-widest text-muted-foreground">{p.brand}</div>
              <div class="line-clamp-1 font-bold text-[10px] leading-tight md:text-xs">{p.name}</div>
              <div class="flex items-center justify-between mt-1">
                <span class="font-black text-xs md:text-sm">{formatCurrency(p.price)}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== BRAND MARQUEE ==================== -->
  <section class="border-b-2 border-border bg-muted overflow-hidden">
    <div class="group/marquee">
      <div class="py-3 lg:py-3.5 flex items-center gap-8 whitespace-nowrap group-hover/marquee:[animation-play-state:paused] group-focus-within/marquee:[animation-play-state:paused]" style="animation: brand-scroll-4 35s linear infinite;">
        {[...Array(4)].map(() => brands.map((brand: {name: string; slug: string}) => (
          <a href={`/products/brand/${brand.slug}/1/`} class="text-sm lg:text-base font-black uppercase tracking-wider text-foreground/45 flex items-center gap-8 hover:text-foreground transition-colors">
            {brand.name}
            <span class="w-1.5 h-1.5 bg-primary rotate-45 block"></span>
          </a>
        )))}
      </div>
    </div>
  </section>

  <!-- ==================== CATEGORIES — Swipeable pills ==================== -->
  <section class="border-b-2 border-border">
    <div class="px-5 py-3.5 lg:px-8">
      <div class="flex gap-2 overflow-x-auto scrollbar-hide -mx-5 px-5">
        {categoriesForPills.map((cat) => (
          <a href={`/products/category/${cat.slug}/1/`} class="flex-none px-3.5 py-2 border-2 border-border bg-card font-bold text-[11px] uppercase tracking-wider active:bg-foreground active:text-background transition-colors">
            {cat.name}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== FEATURED ==================== -->
  <section id="featured-products" class="border-b-2 border-border scroll-mt-20">
    <div class="px-5 pt-8 pb-10 lg:px-8 lg:py-16">
      <!-- Section header -->
      <div class="mb-6">
        <div class="flex items-center justify-between">
          <h2 class="text-2xl md:text-3xl font-black uppercase tracking-tight">Онцлох</h2>
          <a href="/products?filter=featured" class="text-[11px] font-bold uppercase tracking-wider text-muted-foreground active:text-foreground">Бүгд →</a>
        </div>
        <p class="text-[12px] text-muted-foreground font-medium mt-1">Үнэ, эрэлт хоёроороо хамгийн их сонгогддог бүтээгдэхүүнүүд</p>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-2.5 lg:gap-4">
        {featuredProducts.map((p: ProductForHome) => (
          <HomeProductCard product={p} />
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== WHY US — Horizontal scroll cards on mobile ==================== -->
  <section class="border-b-2 border-border bg-muted/20">
    <div class="px-5 py-8 lg:px-8 lg:py-14">
      <h2 class="text-xl md:text-2xl font-black uppercase tracking-tight mb-1">Яагаад манайх гэж</h2>
      <p class="text-[12px] text-muted-foreground font-medium mb-5">Хэрэгтэйгээ төвөггүй олохын тулд</p>

      <div class="flex gap-2.5 overflow-x-auto scrollbar-hide -mx-5 px-5 pb-2 lg:grid lg:grid-cols-4 lg:mx-0 lg:px-0 lg:pb-0 lg:gap-3">
        {[
          { num: "01", title: "Боломжийн үнэ", desc: "Өдөр бүр хэрэгтэй бүтээгдэхүүнээ хэт өндөр үнээр авахгүй. Боломжийн үнийг барихыг хичээдэг." },
          { num: "02", title: "Өргөн сонголт", desc: "Витамин, эрдэс, нэмэлт тэжээлээ нэг дороос харьцуулж сонгох боломжтой." },
          { num: "03", title: "Шуурхай хүргэлт", desc: "Захиалгыг удаалалгүй, аль болох хурдан хүргэхэд анхаардаг." },
          { num: "04", title: "Хэрэгцээний төрлүүд", desc: "Дархлаа, гоо сайхан, яс үе, ходоод гэдэс гээд түгээмэл хэрэгцээний төрлүүд бий." },
        ].map((item) => (
          <div class="flex-none w-[240px] lg:w-auto border-2 border-border bg-card p-4 lg:p-5">
            <span class="text-[10px] font-black text-primary tracking-widest">{item.num}</span>
            <h3 class="font-black text-[13px] md:text-sm uppercase tracking-wider mt-1 mb-1.5">{item.title}</h3>
            <p class="text-[11px] md:text-xs font-medium text-muted-foreground leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== NEW ARRIVALS — Swipeable row ==================== -->
  <section class="border-b-2 border-border">
    <div class="px-5 pt-8 pb-10 lg:px-8 lg:py-16">
      <div class="flex items-center justify-between mb-1">
        <h2 class="text-2xl md:text-3xl font-black uppercase tracking-tight">Шинэ ирсэн</h2>
        <a href="/products?filter=recent" class="text-[11px] font-bold uppercase tracking-wider text-muted-foreground active:text-foreground">Бүгд →</a>
      </div>
      <p class="text-[12px] text-muted-foreground font-medium mb-5">Шинээр орж ирсэн болон шинээр нэмэгдсэн төрлүүд</p>

      <div class="flex gap-2.5 overflow-x-auto scrollbar-hide -mx-5 px-5 pb-2 snap-x snap-mandatory lg:grid lg:grid-cols-4 lg:mx-0 lg:px-0 lg:pb-0 lg:gap-4">
        {newProducts.map((p: ProductForHome) => (
          <HomeProductCard product={p} class="flex-none w-[165px] lg:w-auto snap-start" />
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== TRUST & CERTIFICATIONS ==================== -->
  <section class="border-b-2 border-border bg-muted/30">
    <div class="px-5 py-8 lg:px-8 lg:py-12">
      <div class="text-center mb-6">
        <h2 class="text-lg md:text-xl font-black uppercase tracking-tight">Баталгаат чанар</h2>
        <p class="text-xs font-medium text-muted-foreground mt-1">АНУ-ын стандартын дагуу үйлдвэрлэгдсэн бүтээгдэхүүн</p>
      </div>
      <div class="flex flex-wrap items-center justify-center gap-3">
        {[
          { label: "GMP", sub: "Certified", desc: "Good Manufacturing Practice" },
          { label: "FDA", sub: "Registered", desc: "Food & Drug Administration" },
          { label: "NSF", sub: "Certified", desc: "National Sanitation Foundation" },
          { label: "USP", sub: "Verified", desc: "United States Pharmacopeia" },
          { label: "Non-GMO", sub: "Project", desc: "Non-GMO Project Verified" },
          { label: "USDA", sub: "Organic", desc: "USDA Certified Organic" },
        ].map((cert) => (
          <div class="group flex items-center gap-2 px-3 py-2 border-3 border-border bg-card shadow-hard-sm hover:shadow-hard hover:-translate-y-0.5 transition-all">
            <div class="w-8 h-8 border-2 border-border bg-primary flex items-center justify-center shrink-0">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                <path d="M9 12l2 2 4-4"/>
              </svg>
            </div>
            <div>
              <div class="font-black text-xs uppercase tracking-wider leading-none">{cert.label}</div>
              <div class="text-[9px] font-bold text-muted-foreground uppercase tracking-wide">{cert.sub}</div>
            </div>
          </div>
        ))}
      </div>
      <p class="text-center text-[10px] font-semibold text-muted-foreground mt-5 max-w-lg mx-auto leading-relaxed">
        Бидний борлуулж буй бүтээгдэхүүнүүд АНУ-ын GMP баталгаат үйлдвэрүүдэд үйлдвэрлэгдсэн, FDA бүртгэлтэй, чанарын өндөр стандарт хангасан жинхэнэ бүтээгдэхүүнүүд юм.
      </p>
    </div>
  </section>

  <!-- ==================== FINAL CTA ==================== -->
  <section class="px-5 py-10 lg:px-8 lg:py-16">
    <div class="border-3 border-border bg-primary p-6 lg:p-14 shadow-hard-lg relative overflow-hidden">
      <div class="absolute inset-0 bg-grid-pattern opacity-[0.08] pointer-events-none"></div>
      <div class="relative z-10 max-w-lg mx-auto text-center">
        <h2 class="text-2xl md:text-4xl font-black uppercase tracking-tight mb-3">Хэрэгтэйгээ нэг дороос сонго</h2>
        <p class="text-[12px] md:text-sm font-medium mb-6 text-foreground/70">
          Боломжийн үнэтэй витамин, нэмэлт тэжээлийг ангилал бүрээр нь харьцуулж үзээд, захиалгаа хурдан өг.
        </p>
        <a href="/products" class="inline-flex px-8 py-3.5 bg-foreground text-background font-black text-[13px] uppercase tracking-wider border-2 border-foreground active:scale-[0.97] transition-transform">
          Бүх бүтээгдэхүүн үзэх
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  @keyframes brand-scroll-4 {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>
