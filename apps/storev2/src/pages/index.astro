---
import HomeProductCard from "@/components/product/home-product-card.astro";
import InventoryReconciler from "@/components/product/inventory-reconciler";
import MobileSearchBar from "@/components/search/mobile-search-bar";
import Layout from "@/layouts/Layout.astro";
import { toProductImageUrl } from "@/lib/image";
import { api } from "@/lib/trpc";
import type { ProductForHome } from "@/lib/types";
import { formatCurrency } from "@/lib/utils";
import { washBg } from "@/lib/wash";
import IconTruck from "~icons/ri/truck-line";
import IconShield from "~icons/ri/shield-check-line";
import IconPhone from "~icons/ri/phone-line";

type CategoryTile = {
  id: number;
  name: string;
  slug: string;
  productCount: number;
};

type BrandRow = {
  id: number;
  name: string;
  slug: string;
  logoUrl: string | null;
  productCount: number;
};

const products = await api.product.getProductsForHome.query();
const { featuredProducts, newProducts, discountedProducts } = products;
const brands = await api.brand.getAllBrandsWithStock.query();
const allCategories = await api.category.getAllCategoriesWithStock.query();

const preferredCategoryNames = [
  "Дархлаа",
  "Гоо сайхан",
  "Энерги",
  "Яс үе мөч",
  "Зүрх судас",
  "Ходоод гэдэс",
  "Нойр",
  "Тархи мэдрэл",
];

const orderedCategories = [
  ...preferredCategoryNames
    .map((name) => allCategories.find((c: CategoryTile) => c.name === name))
    .filter((c: CategoryTile | undefined): c is CategoryTile => Boolean(c)),
  ...allCategories.filter(
    (c: CategoryTile) => !preferredCategoryNames.includes(c.name),
  ),
];

const categoryTiles = orderedCategories.slice(0, 8);
const heroProducts: ProductForHome[] = featuredProducts.slice(0, 4);
const shelfProducts: ProductForHome[] = featuredProducts.slice(0, 8);
const gridProducts: ProductForHome[] = newProducts.slice(0, 4);
const brandRow: BrandRow[] = brands.slice(0, 10);

Astro.cache.set({
	maxAge: 86400,
	swr: 604800,
	tags: ["site-shell", "home", "catalog"],
});
---

<Layout
  image="/og-landing.png"
  imageAlt="Америк Витамин - АНУ-ын витамин, нэмэлт тэжээл"
>
  <!-- Persistent mobile search bar (below header) -->
  <div class="md:hidden border-b border-border bg-background px-4 py-3">
    <MobileSearchBar client:idle />
  </div>

  <!-- ==================== 1. HERO ==================== -->
  <section class="bg-hero-warm">
    <div class="mx-auto grid max-w-6xl gap-8 px-5 pt-9 pb-12 lg:grid-cols-[1.1fr_1fr] lg:items-center lg:gap-14 lg:px-8 lg:pt-16 lg:pb-20">
      <!-- Text -->
      <div class="min-w-0">
        <h1 class="enter-rise font-display text-h1 font-semibold mb-4 break-words">
          Өргөн сонголттой витамин, боломжийн үнээр
        </h1>
        <p class="enter-rise stagger-1 text-sm md:text-base font-medium text-muted-foreground leading-relaxed mb-6 max-w-md break-words">
          Өдөр тутам авдаг витамин, нэмэлт тэжээлийг нэг дороос. Үнэ нь боломжийн, сонголт нь өргөн, хүргэлт нь шуурхай.
        </p>
        <div class="enter-rise stagger-2 mb-4">
          <a
            href="/products"
            class="inline-flex h-12 items-center justify-center rounded-full bg-primary px-7 text-sm md:text-base font-semibold text-primary-foreground shadow-lift transition-[transform,box-shadow] duration-[140ms] ease-out hover:-translate-y-[2px] hover:shadow-lift-lg active:translate-y-0 active:scale-[0.97] active:shadow-none"
          >
            Бүтээгдэхүүн үзэх
          </a>
        </div>
        <p class="enter-rise stagger-3 text-[13px] font-semibold text-muted-foreground">
          АНУ-аас албан ёсоор ирдэг жинхэнэ бүтээгдэхүүн · 10:30-аас өмнө захиалбал өдөртөө хүргэнэ
        </p>
      </div>

      <!-- Rotating product showcase -->
      {heroProducts.length > 0 && (
        <div class="enter-scale stagger-2 relative" data-hero-rotator>
          <div class="hero-frame relative overflow-hidden rounded-3xl bg-wash-peach shadow-soft-lg aspect-[4/3] lg:aspect-square">
            {heroProducts.map((p, i) => (
              <a
                href={`/products/${p.slug}-${p.id}/`}
                class:list={["hero-slide group absolute inset-0 block", { "is-active": i === 0 }]}
                aria-hidden={i === 0 ? "false" : "true"}
                tabindex={i === 0 ? undefined : -1}
              >
                <img
                  src={toProductImageUrl(p.image, "feature") || p.image}
                  alt={p.name}
                  class="absolute inset-0 h-full w-full object-contain p-8 lg:p-14 transition-transform duration-300 ease-out-quart group-hover:scale-[1.03]"
                  width="480"
                  height="480"
                  loading={i === 0 ? "eager" : "lazy"}
                  decoding="async"
                />
                <span class="absolute top-4 left-4 rounded-full bg-card/90 px-2.5 py-1 text-[10px] font-bold uppercase tracking-wider text-muted-foreground shadow-soft-sm">
                  {p.brand}
                </span>
                <div class="absolute bottom-4 left-4 right-4 flex items-end justify-between gap-3">
                  <span class="line-clamp-2 max-w-[60%] text-sm font-semibold leading-snug text-foreground/80">
                    {p.name}
                  </span>
                  <span class="inline-flex items-center rounded-full bg-card px-3.5 py-1.5 font-display text-sm font-semibold shadow-soft">
                    {formatCurrency(p.price)}
                  </span>
                </div>
              </a>
            ))}
          </div>
          <span class="hero-sticker absolute -top-3 right-5 inline-flex -rotate-3 items-center rounded-full border-2 border-cocoa bg-card px-3 py-1 text-xs font-bold text-foreground shadow-pop-sm">
            100% жинхэнэ
          </span>
          {heroProducts.length > 1 && (
            <div class="hero-dots mt-4 flex items-center justify-center gap-1" role="tablist" aria-label="Онцлох бүтээгдэхүүн">
              {heroProducts.map((p, i) => (
                <button
                  type="button"
                  class:list={["hero-dot grid place-items-center p-2.5", { "is-active": i === 0 }]}
                  role="tab"
                  aria-selected={i === 0 ? "true" : "false"}
                  aria-label={p.name}
                >
                  <span class="block h-2 w-2 rounded-full bg-foreground/25"></span>
                </button>
              ))}
            </div>
          )}
        </div>
      )}
    </div>
  </section>

  <InventoryReconciler
    client:load
    productIds={[
      ...new Set([
        ...featuredProducts.map((product) => product.id),
        ...newProducts.map((product) => product.id),
        ...discountedProducts.map((product) => product.id),
      ]),
    ]}
  />

  <!-- ==================== 2. CATEGORY TILES ==================== -->
  <section>
    <div class="mx-auto max-w-6xl px-5 pt-10 pb-8 lg:px-8 lg:pt-16 lg:pb-12">
      <h2 data-reveal class="font-display text-h2 font-semibold mb-1">Хэрэгцээгээрээ сонго</h2>
      <p data-reveal class="text-sm font-medium text-muted-foreground mb-5">Өөрийн хэрэгцээнд тохирох төрлүүд</p>
      <div data-reveal-group class="grid grid-cols-2 gap-2.5 lg:grid-cols-4 lg:gap-3">
        {categoryTiles.map((cat) => (
          <a
            href={`/products/category/${cat.slug}/1/`}
            class={`${washBg(cat.slug)} group flex min-h-[96px] flex-col justify-between rounded-2xl p-4 shadow-soft transition-[box-shadow,transform] duration-200 ease-out-quart hover:-translate-y-0.5 hover:shadow-soft-lg active:translate-y-0 active:scale-[0.98] lg:min-h-[112px] lg:p-5`}
          >
            <h3 class="text-sm font-bold leading-snug lg:text-base">{cat.name}</h3>
            <span class="text-xs font-semibold text-foreground/60">{cat.productCount} бүтээгдэхүүн</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== 3. FEATURED PRODUCTS ==================== -->
  <section id="featured-products" class="scroll-mt-20">
    <div class="mx-auto max-w-6xl px-5 py-8 lg:px-8 lg:py-14">
      <!-- Snap shelf -->
      <div class="mb-1 flex items-center justify-between">
        <h2 data-reveal class="font-display text-h2 font-semibold">Онцлох</h2>
        <a href="/products?filter=featured" class="py-2 text-xs font-bold uppercase tracking-wider text-muted-foreground transition-colors hover:text-foreground">Бүгд →</a>
      </div>
      <p data-reveal class="mb-5 text-sm font-medium text-muted-foreground">Үнэ, эрэлт хоёроороо хамгийн их сонгогддог бүтээгдэхүүнүүд</p>
      <div data-reveal-group class="-mx-5 flex snap-x snap-mandatory gap-2.5 overflow-x-auto scrollbar-hide px-5 pb-2 lg:-mx-8 lg:gap-4 lg:px-8">
        {shelfProducts.map((p: ProductForHome) => (
          <HomeProductCard product={p} class="w-[140px] flex-none snap-start lg:w-[220px]" />
        ))}
      </div>

      <!-- Small new-arrivals grid -->
      <div class="mt-9 mb-1 flex items-center justify-between lg:mt-12">
        <h2 data-reveal class="font-display text-h2 font-semibold">Шинэ ирсэн</h2>
        <a href="/products?filter=recent" class="py-2 text-xs font-bold uppercase tracking-wider text-muted-foreground transition-colors hover:text-foreground">Бүгд →</a>
      </div>
      <p data-reveal class="mb-5 text-sm font-medium text-muted-foreground">Шинээр орж ирсэн болон шинээр нэмэгдсэн төрлүүд</p>
      <div data-reveal-group class="grid grid-cols-2 gap-2.5 lg:grid-cols-4 lg:gap-4">
        {gridProducts.map((p: ProductForHome) => (
          <HomeProductCard product={p} />
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== 4. TRUST / DELIVERY STRIP ==================== -->
  <section class="bg-secondary text-secondary-foreground">
    <div class="mx-auto grid max-w-6xl gap-4 px-5 py-7 sm:grid-cols-3 lg:gap-6 lg:px-8 lg:py-9">
      <div class="flex items-center gap-3">
        <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-secondary-foreground/10">
          <IconTruck class="h-5 w-5" aria-hidden="true" />
        </span>
        <div class="min-w-0">
          <p class="text-sm font-bold leading-snug">Өдөртөө хүргэнэ</p>
          <p class="text-[13px] font-medium text-secondary-foreground/70">10:30-аас өмнөх захиалгыг Улаанбаатар хотоор</p>
        </div>
      </div>
      <div class="flex items-center gap-3">
        <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-secondary-foreground/10">
          <IconShield class="h-5 w-5" aria-hidden="true" />
        </span>
        <div class="min-w-0">
          <p class="text-sm font-bold leading-snug">100% жинхэнэ</p>
          <p class="text-[13px] font-medium text-secondary-foreground/70">АНУ-аас албан ёсоор оруулж ирдэг</p>
        </div>
      </div>
      <a href="tel:+97699993950" class="flex items-center gap-3">
        <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-secondary-foreground/10">
          <IconPhone class="h-5 w-5" aria-hidden="true" />
        </span>
        <div class="min-w-0">
          <p class="text-sm font-bold leading-snug">Тусламж хэрэгтэй юу?</p>
          <p class="text-[13px] font-medium text-secondary-foreground/70">9999-3950 · Даваа-Баасан 10:00-18:00</p>
        </div>
      </a>
    </div>
  </section>

  <!-- ==================== 5. BRANDS + FINAL CTA ==================== -->
  <section>
    <div class="mx-auto max-w-6xl px-5 pt-10 pb-12 lg:px-8 lg:pt-14 lg:pb-20">
      <p data-reveal class="mb-4 text-[11px] font-bold uppercase tracking-[0.12em] text-muted-foreground">Брэндүүд</p>
      <div data-reveal-group class="flex flex-wrap gap-2">
        {brandRow.map((brand: BrandRow) => (
          <a
            href={`/products/brand/${brand.slug}/1/`}
            class="inline-flex min-h-11 items-center gap-2 rounded-full border border-border bg-card px-4 py-2 text-sm font-bold shadow-soft-sm transition-[box-shadow,transform] duration-200 ease-out-quart hover:-translate-y-0.5 hover:shadow-soft active:translate-y-0 active:scale-[0.97]"
          >
            {brand.logoUrl && (
              <img
                src={brand.logoUrl}
                alt=""
                class="h-5 w-5 rounded-full object-contain"
                width="20"
                height="20"
                loading="lazy"
                decoding="async"
              />
            )}
            {brand.name}
          </a>
        ))}
      </div>

      <div data-reveal class="mt-10 rounded-3xl bg-wash-lilac p-7 text-center shadow-soft lg:mt-14 lg:p-14">
        <h2 class="font-display text-h2 font-semibold mb-3">Хэрэгтэйгээ нэг дороос сонго</h2>
        <p class="mx-auto mb-6 max-w-md text-sm font-medium text-foreground/70 md:text-base">
          Боломжийн үнэтэй витамин, нэмэлт тэжээлийг ангилал бүрээр нь харьцуулж үзээд, захиалгаа хурдан өг.
        </p>
        <a
          href="/products"
          class="inline-flex h-12 items-center justify-center rounded-full bg-primary px-7 text-sm md:text-base font-semibold text-primary-foreground shadow-lift transition-[transform,box-shadow] duration-[140ms] ease-out hover:-translate-y-[2px] hover:shadow-lift-lg active:translate-y-0 active:scale-[0.97] active:shadow-none"
        >
          Бүх бүтээгдэхүүн үзэх
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* CSS-only scroll reveal (replaces `motion` library). Elements start
     hidden and transition in when .is-revealed is added by the
     IntersectionObserver in the page script. Stagger via --enter-delay. */
  @media (prefers-reduced-motion: no-preference) {
    [data-reveal] {
      opacity: 0;
      transform: translateY(10px);
      transition: opacity 350ms cubic-bezier(0.25, 1, 0.5, 1),
                  transform 350ms cubic-bezier(0.25, 1, 0.5, 1);
    }
    [data-reveal].is-revealed {
      opacity: 1;
      transform: translateY(0);
    }
    [data-reveal-group] > * {
      opacity: 0;
      transform: translateY(12px);
      transition: opacity 350ms cubic-bezier(0.25, 1, 0.5, 1),
                  transform 350ms cubic-bezier(0.25, 1, 0.5, 1);
      transition-delay: calc(min(var(--stagger-i, 0), 7) * 40ms);
    }
    [data-reveal-group].is-revealed > * {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Sticker pops last: small spring overshoot after the staggered hero entrance. */
  @keyframes sticker-pop {
    from {
      opacity: 0;
      transform: scale(0.8) rotate(4deg);
    }
    to {
      opacity: 1;
      transform: scale(1) rotate(-3deg);
    }
  }

  .hero-sticker {
    animation: sticker-pop 450ms cubic-bezier(0.34, 1.56, 0.64, 1) 380ms backwards;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-sticker {
      animation: none;
    }
  }

  /* Rotating hero showcase: slides crossfade in place, no layout shift. */
  .hero-slide {
    opacity: 0;
    transform: scale(0.96);
    filter: blur(2px);
    pointer-events: none;
  }
  .hero-slide.is-active {
    opacity: 1;
    transform: scale(1);
    filter: blur(0);
    pointer-events: auto;
  }
  .hero-dot > span {
    transition: background-color 300ms var(--ease-out), transform 300ms var(--ease-out);
  }
  .hero-dot.is-active > span {
    background-color: color-mix(in oklch, var(--color-foreground) 70%, transparent);
    transform: scale(1.35);
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero-slide {
      transition:
        opacity 500ms var(--ease-out),
        transform 500ms var(--ease-out),
        filter 500ms var(--ease-out);
    }
  }
</style>

<script>
  // CSS-only scroll reveal — replaces the `motion` library (~30kb) with a
  // tiny IntersectionObserver that toggles a class. The animation itself is
  // a CSS transition on opacity + transform, gated behind
  // prefers-reduced-motion. Stagger is achieved via --enter-delay on children.
  function revealOnScroll() {
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      // No animation — just make everything visible immediately.
      document.querySelectorAll<HTMLElement>("[data-reveal], [data-reveal-group]")
        .forEach((el) => el.classList.add("is-revealed"));
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-revealed");
            observer.unobserve(entry.target);
          }
        }
      },
      { rootMargin: "0px 0px -10% 0px", threshold: 0.1 },
    );

    for (const el of document.querySelectorAll<HTMLElement>(
      "[data-reveal], [data-reveal-group]",
    )) {
      if (el.dataset.revealed) continue;
      el.dataset.revealed = "true";
      // Set stagger index on group children so CSS can compute
      // transition-delay per item.
      if (el.hasAttribute("data-reveal-group")) {
        Array.from(el.children).forEach((child, i) => {
          (child as HTMLElement).style.setProperty("--stagger-i", String(i));
        });
      }
      observer.observe(el);
    }
  }

  document.addEventListener("astro:page-load", revealOnScroll);

  function initHeroRotator() {
    const rotator = document.querySelector<HTMLElement>("[data-hero-rotator]");
    if (!rotator || rotator.dataset.init) return;

    const slides = Array.from(rotator.querySelectorAll<HTMLElement>(".hero-slide"));
    const dots = Array.from(rotator.querySelectorAll<HTMLElement>(".hero-dot"));
    const count = slides.length;
    if (count <= 1) return;
    rotator.dataset.init = "true";

    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let idx = Math.max(0, slides.findIndex((s) => s.classList.contains("is-active")));
    let paused = false;
    let stopped = reduce;
    let timer: number | null = null;

    function show(n: number) {
      idx = (n + count) % count;
      slides.forEach((s, i) => {
        const on = i === idx;
        s.classList.toggle("is-active", on);
        s.setAttribute("aria-hidden", on ? "false" : "true");
        if (on) s.removeAttribute("tabindex");
        else s.setAttribute("tabindex", "-1");
      });
      dots.forEach((d, i) => {
        const on = i === idx;
        d.classList.toggle("is-active", on);
        d.setAttribute("aria-selected", on ? "true" : "false");
      });
    }

    function start() {
      if (stopped || timer !== null) return;
      timer = window.setInterval(() => {
        if (!paused) show(idx + 1);
      }, 5000);
    }

    function stopAuto() {
      stopped = true;
      if (timer !== null) {
        clearInterval(timer);
        timer = null;
      }
    }

    rotator.addEventListener("pointerenter", () => (paused = true));
    rotator.addEventListener("pointerleave", () => (paused = false));
    rotator.addEventListener("focusin", () => (paused = true));
    rotator.addEventListener("focusout", () => (paused = false));

    dots.forEach((d, i) =>
      d.addEventListener("click", () => {
        stopAuto();
        show(i);
      }),
    );

    const frame = rotator.querySelector<HTMLElement>(".hero-frame") ?? rotator;
    let sx = 0;
    let sy = 0;
    let swiped = false;
    frame.addEventListener(
      "touchstart",
      (e) => {
        sx = e.touches[0].clientX;
        sy = e.touches[0].clientY;
      },
      { passive: true },
    );
    frame.addEventListener(
      "touchend",
      (e) => {
        const dx = e.changedTouches[0].clientX - sx;
        const dy = e.changedTouches[0].clientY - sy;
        if (Math.abs(dx) > 40 && Math.abs(dx) > Math.abs(dy)) {
          swiped = true;
          stopAuto();
          show(idx + (dx < 0 ? 1 : -1));
        }
      },
      { passive: true },
    );
    frame.addEventListener(
      "click",
      (e) => {
        if (swiped) {
          e.preventDefault();
          e.stopPropagation();
          swiped = false;
        }
      },
      true,
    );

    if (!reduce) start();
  }

  document.addEventListener("astro:page-load", initHeroRotator);
</script>
