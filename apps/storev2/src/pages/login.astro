---
import LoginForm from "@/components/auth/login-form";
import Layout from "@/layouts/Layout.astro";

const title = "Нэвтрэх";
const description = "Америк Витамин дэлгүүрт нэвтрэх. Захиалгын түүхээ харах, профайлаа удирдах.";
---

<Layout title={title} description={description} noindex>
    <div class="relative min-h-screen bg-background">
        <div class="absolute top-16 left-10 hidden h-24 w-24 rounded-full bg-wash-lemon/70 md:block" aria-hidden="true"></div>
        <div class="absolute right-16 bottom-24 hidden h-20 w-20 rounded-full bg-wash-peach/60 md:block" aria-hidden="true"></div>
        <div class="absolute top-1/3 right-10 hidden h-14 w-14 rounded-full bg-wash-mint/60 lg:block" aria-hidden="true"></div>

        <LoginForm client:only="solid-js">
            <div slot="fallback" class="container mx-auto flex min-h-[70vh] items-center justify-center px-4 py-16">
                <div class="enter-scale w-full max-w-md rounded-2xl border border-border bg-card p-8 shadow-soft">
                    <div class="mx-auto mb-8 h-9 w-40 animate-pulse rounded-xl bg-muted"></div>
                    <div class="space-y-4">
                        <div class="h-12 animate-pulse rounded-xl bg-muted"></div>
                        <div class="h-12 animate-pulse rounded-xl bg-muted"></div>
                        <div class="h-12 animate-pulse rounded-full bg-primary/30"></div>
                    </div>
                </div>
            </div>
        </LoginForm>
    </div>
</Layout>
