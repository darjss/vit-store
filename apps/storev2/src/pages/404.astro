---















import Layout from "@/layouts/Layout.astro";
import IconInfoCircle from "~icons/ri/information-line";
import IconLightbulb from "~icons/ri/lightbulb-line";
import IconQuestion from "~icons/ri/question-line";

export const prerender = true;

const title = "404 - Хуудас олдсонгүй";
const description = "Таны хайсан хуудас байхгүй байна. Нүүр хуудас руу буцна уу.";
---

<Layout title={title} description={description} noindex>
    <div class="min-h-[80vh] flex items-center justify-center px-4 py-16">
        <div class="max-w-2xl w-full">
            <div
                class="bg-[oklch(0.92_0.18_15)] border border-border shadow-soft-lg p-8 md:p-12 relative overflow-hidden"
            >
                <div
                    class="absolute inset-0 opacity-10"
                    style="background-image: repeating-linear-gradient(45deg, transparent, transparent 10px, rgba(0,0,0,0.1) 10px, rgba(0,0,0,0.1) 20px);"
                >
                </div>

                <div class="relative z-10">
                    <!-- 404  -->
                    <div class="mb-6">
                        <h1
                            class="text-8xl md:text-9xl font-extrabold leading-none inline-block"
                        >
                            404
                        </h1>
                        <div
                            class="mt-4 h-2 w-32 bg-foreground shadow-soft-lg"
                        >
                        </div>
                    </div>

                    <h2 class="text-h2 font-extrabold mb-4">
                        Ийм хуудас байхгүй байна
                    </h2>
                    <p class="text-lg md:text-xl font-bold mb-8 max-w-md">
                        Хайсан хуудас тань устсан эсвэл хэзээ ч байгаагүй бололтой. URL-аа шалгаад үзээрэй.
                    </p>

                    <div class="my-8 flex gap-4 flex-wrap">
                        <div
                            class="bg-background border-[3px] border-border p-4 shadow-soft-lg inline-block"
                        >
                            <IconInfoCircle class="h-8 w-8" />
                        </div>
                        <div
                            class="border border-border bg-foreground text-background p-4 shadow-soft-lg inline-block font-extrabold text-xl"
                        >
                            ?
                        </div>
                        <div
                            class="bg-primary border-[3px] border-border p-4 shadow-soft-lg inline-block"
                        >
                            <IconQuestion class="h-8 w-8" />
                        </div>
                    </div>

                    <!-- Action Buttons -->
                    <div class="flex flex-wrap gap-4 mt-8">
                        <a href="/">
                            <button
                                type="button"
                                class="border border-border bg-foreground text-background px-8 py-4 font-extrabold text-lg shadow-soft-lg hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-soft-sm transition-all"
                            >
                                ← Нүүр хуудас руу
                            </button>
                        </a>
                        <a href="/products/">
                            <button
                                type="button"
                                class="bg-background border-[3px] border-border px-8 py-4 font-extrabold text-lg shadow-soft-lg hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-soft-sm transition-all"
                            >
                                Бүтээгдэхүүн үзэх
                            </button>
                        </a>
                    </div>

                    <!-- Help Text -->
                    <div class="mt-8 pt-6 border-t border-border/20">
                        <p class="font-bold text-sm flex items-center gap-2">
                            <IconLightbulb class="h-5 w-5" /> <strong>Зөвлөмж:</strong> Хаягаа дахин шалгах эсвэл доорх товчоор нүүр хуудас руу буцна уу.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Shadow Element -->
            <div class="mt-2 ml-2 h-full w-full bg-foreground/10 -z-10"></div>
        </div>
    </div>
</Layout>
