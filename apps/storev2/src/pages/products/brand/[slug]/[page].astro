---
// Server-rendered: full HTML generated at request time for maximum reliability

import Pagination from "@/components/product/pagination.astro";
import ServerProductCard from "@/components/product/server-product-card.astro";
import SortBar from "@/components/product/sort-bar.astro";
import Layout from "@/layouts/Layout.astro";
import { getBrandLogoUrl } from "@/lib/image";
import { api } from "@/lib/trpc";
import { WASH_BG, washFor } from "@/lib/wash";

const PAGE_SIZE = 24;
const SITE_URL = "https://amerikvitamin.mn";

const { slug, page: pageParam } = Astro.params;
if (!slug || !pageParam) {
	return Astro.redirect("/404");
}

const page = Number.parseInt(pageParam, 10);

const sortParam = Astro.url.searchParams.get("sort");
const dirParam = Astro.url.searchParams.get("dir");
const sortField =
	sortParam === "price" || sortParam === "createdAt" || sortParam === "stock"
		? sortParam
		: undefined;
const sortDirection =
	dirParam === "asc" || dirParam === "desc" ? dirParam : undefined;
const sortQuery = sortField
	? `?sort=${sortField}&dir=${sortDirection ?? "desc"}`
	: "";

const brand = await api.brand.getBrandBySlug.query({ slug });
if (!brand) {
	return Astro.redirect("/404");
}

// Treat known placeholder/non-image logo URLs as missing so we render the
// designed brand-initial monogram fallback instead of a broken image.
// See GitHub issue #11.
const brandLogoUrl = getBrandLogoUrl(brand.logoUrl);
const brandLogoOnError =
	"this.outerHTML='<div class=&quot;h-12 w-12 sm:h-16 sm:w-16 shrink-0 border border-border bg-card rounded-xl flex items-center justify-center font-bold font-display text-sm sm:text-lg&quot;>'+this.alt.substring(0,2).toUpperCase()+'</div>';this.onerror=null";

const { items: products, pagination } = await api.product.getPaginatedProducts.query({
	page,
	pageSize: PAGE_SIZE,
	brandId: brand.id,
	sortField,
	sortDirection,
});
if (pagination.totalCount <= 0) {
	return Astro.redirect("/404");
}

const baseUrl = `/products/brand/${slug}`;
const washClass = WASH_BG[washFor(`brand-${brand.id}`)];

const seoTitle = page === 1
	? (brand.seoTitle || `${brand.name} - Витамин, нэмэлт тэжээл`)
	: (brand.seoTitle || `${brand.name} - Хуудас ${page}`);
const seoDescription = brand.seoDescription ||
	`${brand.name} брэндийн ${pagination.totalCount} витамин, нэмэлт тэжээл.${page > 1 ? ` Хуудас ${page}/${pagination.totalPages}.` : ""}`;
const brandIntro = brand.description ||
	`${brand.name} брэндийн АНУ-ын витамин, нэмэлт тэжээлийг Америк Витамин дэлгүүрээс сонгон захиалаарай. Үнэ, хэмжээ, найрлага болон бүтээгдэхүүний мэдээллийг харьцуулж өөрт тохирох сонголтоо олоорой.`;

const breadcrumbSchema = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	itemListElement: [
		{ "@type": "ListItem", position: 1, name: "Нүүр", item: SITE_URL },
		{ "@type": "ListItem", position: 2, name: "Бүтээгдэхүүн", item: `${SITE_URL}/products` },
		{ "@type": "ListItem", position: 3, name: brand.name, item: `${SITE_URL}${baseUrl}/1` },
		...(page > 1 ? [{ "@type": "ListItem", position: 4, name: `Хуудас ${page}`, item: `${SITE_URL}${baseUrl}/${page}` }] : []),
	],
};

const itemListSchema = {
	"@context": "https://schema.org",
	"@type": "ItemList",
	name: brand.name,
	numberOfItems: pagination.totalCount,
	itemListElement: products.map((p, i) => ({
		"@type": "ListItem",
		position: (page - 1) * PAGE_SIZE + i + 1,
		url: `${SITE_URL}/products/${p.slug}-${p.id}`,
		name: p.name,
	})),
};

---

<Layout title={seoTitle} description={seoDescription}>
	<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
	<script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />

	<div class="mx-auto max-w-screen-2xl px-3 py-4 sm:px-6 sm:py-6 lg:px-8">
		<!-- Breadcrumb -->
		<nav aria-label="Breadcrumb" class="mb-3 flex flex-wrap items-center gap-1.5 font-medium text-muted-foreground text-xs sm:mb-4 sm:text-sm">
			<a href="/" class="hover:text-foreground hover:underline">Нүүр</a>
			<span>/</span>
			<a href="/products" class="hover:text-foreground hover:underline">Бүтээгдэхүүн</a>
			<span>/</span>
			<a href={`${baseUrl}/1`} class="hover:text-foreground hover:underline">{brand.name}</a>
			{page > 1 && (
				<>
					<span>/</span>
					<span class="text-foreground">Хуудас {page}</span>
				</>
			)}
		</nav>

		<!-- Header on brand-keyed wash tint -->
		<header class={`enter-rise mb-3 flex items-center gap-3 rounded-2xl border border-border ${washClass} px-4 py-4 sm:mb-4 sm:px-6 sm:py-5`}>
			{brandLogoUrl ? (
				<img
					src={brandLogoUrl}
					alt={brand.name}
					class="h-12 w-12 rounded-xl border border-border bg-card object-contain p-1 shadow-soft-sm sm:h-16 sm:w-16 sm:p-2"
					width="64"
					height="64"
					onerror={brandLogoOnError}
				/>
			) : (
				<div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl border border-border bg-card font-bold font-display text-sm shadow-soft-sm sm:h-16 sm:w-16 sm:text-lg">
					{brand.name.substring(0, 2).toUpperCase()}
				</div>
			)}
			<div>
				<h1 class="font-bold font-display text-xl tracking-tight sm:text-2xl lg:text-3xl">
					{brand.name}
				</h1>
				<p class="mt-1 font-medium text-foreground/70 text-xs sm:text-sm">
					Нийт {pagination.totalCount} бүтээгдэхүүн{page > 1 ? ` — Хуудас ${page}/${pagination.totalPages}` : ""}
				</p>
			</div>
		</header>

		<!-- Banner -->
		{brand.bannerImage && (
			<div class="mb-3 overflow-hidden rounded-2xl border border-border shadow-soft sm:mb-4">
				<img
					src={brand.bannerImage}
					alt={brand.name}
					class="h-32 w-full object-cover sm:h-48"
					width="1200"
					height="300"
				/>
			</div>
		)}

		<div class="mb-4 rounded-2xl border border-border bg-card p-3 shadow-soft-sm sm:mb-5 sm:p-4">
			<p class="text-sm leading-relaxed sm:text-base">{brandIntro}</p>
		</div>

		<SortBar baseUrl={baseUrl} sort={sortField ?? null} dir={sortDirection ?? null} />

		<!-- Products Grid -->
		<div class="grid grid-cols-2 gap-2.5 sm:gap-4 lg:grid-cols-3 xl:grid-cols-4">
			{products.map((product, index) => (
				<div
					class="enter-rise"
					style={`--enter-delay:${Math.min(index, 8) * 40}ms`}
				>
					<ServerProductCard product={product} />
				</div>
			))}
		</div>

		<!-- Pagination -->
		{pagination.totalPages > 1 && (
			<Pagination page={page} totalPages={pagination.totalPages} baseUrl={baseUrl} search={sortQuery} />
		)}
	</div>
</Layout>
