---
import Layout from "@/layouts/Layout.astro";

export const prerender = false;

const scoreLabel = (s: number | null) => {
  if (s === null) return "N/A";
  if (s >= 0.9) return "Good";
  if (s >= 0.5) return "Needs Work";
  return "Poor";
};
const scoreColor = (s: number | null) => {
  if (s === null) return "text-gray-400";
  if (s >= 0.9) return "text-green-500";
  if (s >= 0.5) return "text-orange-500";
  return "text-red-500";
};
const scoreBg = (s: number | null) => {
  if (s === null) return "bg-gray-100";
  if (s >= 0.9) return "bg-green-100";
  if (s >= 0.5) return "bg-orange-100";
  return "bg-red-100";
};
const priorityBadge = (p: number) => {
  const colors: Record<number, string> = { 1: "bg-red-600", 2: "bg-orange-500", 3: "bg-yellow-500", 4: "bg-blue-500", 5: "bg-gray-500" };
  return colors[p] || "bg-gray-400";
};
const effortBadge = (e: string) => {
  const m: Record<string, string> = { low: "bg-green-100 text-green-800", medium: "bg-yellow-100 text-yellow-800", high: "bg-red-100 text-red-800" };
  return m[e] || "bg-gray-100 text-gray-800";
};

const data = {
  metadata: {
    url: "https://amerikvitamin.mn",
    api_url: "https://api.amerikvitamin.mn",
    date: "2026-05-13",
  },
  lighthouse: {
    home: { url: "/", scores: { performance: 0.74, bestPractices: 1.0, seo: 1.0 }, metrics: { lcp: 3557, fcp: 1211, si: 2787, tbt: 637, cls: 0, ttfb: 34 }, transfer_bytes: 670551, unused_js_bytes: 85000 },
    products: { url: "/products", scores: { performance: 0.53, bestPractices: null, seo: 1.0 }, metrics: { lcp: 5871, fcp: 1125, si: 2785, tbt: 1372, cls: 0, ttfb: 88 }, transfer_bytes: 630498, unused_js_bytes: 84000 },
    product_detail: { url: "/products/[slug]", scores: { performance: 0.57, bestPractices: null, seo: 1.0 }, metrics: { lcp: 5021, fcp: 1726, si: 5094, tbt: 875, cls: 0, ttfb: 110 }, transfer_bytes: 438406, unused_js_bytes: 83000 },
    cart: { url: "/cart", scores: { performance: 0.99, bestPractices: null, seo: null }, metrics: { lcp: 1378, fcp: 1378, si: 1446, tbt: 124, cls: 0, ttfb: 187 }, transfer_bytes: null, unused_js_bytes: 0 },
    checkout: { url: "/checkout", scores: { performance: 0.86, bestPractices: null, seo: null }, metrics: { lcp: 3820, fcp: 1096, si: 1988, tbt: 161, cls: 0, ttfb: 434 }, transfer_bytes: null, unused_js_bytes: 250 },
  },
  api_latency: {
    endpoints: [
      { name: "GET /", ttfb: 265, total: 265, size: 2 },
      { name: "GET /health-check (cold)", ttfb: 661, total: 661, size: 17 },
      { name: "GET /trpc/store/healthCheck", ttfb: 214, total: 214, size: 33 },
      { name: "GET /trpc/store/healthCheck (proxy)", ttfb: 341, total: 341, size: 33, note: "+130ms proxy" },
      { name: "GET product.getProductsForHome", ttfb: 1071, total: 1071, size: 4377 },
      { name: "GET category.getAllCategories", ttfb: 843, total: 844, size: 1852 },
      { name: "GET category.getAllCategoryNames", ttfb: 451, total: 452, size: 687 },
      { name: "GET product.getAllProducts", ttfb: 612, total: 674, size: 41518 },
    ],
    cold_start_penalty_ms: 400,
  },
  recommendations: [
    { priority: 1, id: "PH-001", title: "Defer/async PostHog scripts", effort: "low", impact: "high", description: "Add async/defer to PostHog script tags to eliminate 637-1372ms TBT overhead" },
    { priority: 2, id: "LCP-001", title: "Optimize LCP with image preloading", effort: "medium", impact: "high", description: "Preload hero images, use fetchpriority=high, implement CDN image transforms for WebP/AVIF" },
    { priority: 3, id: "API-001", title: "Cache API responses at edge", effort: "medium", impact: "medium", description: "Cache tRPC responses in KV with stale-while-revalidate. Categories 5min, products 1min." },
    { priority: 4, id: "TBT-001", title: "Reduce main thread blocking", effort: "high", impact: "medium", description: "Split Solid.js hydration, defer non-critical JS, reduce third-party impact" },
    { priority: 5, id: "SEO-001", title: "Fix search page SSR", effort: "low", impact: "low", description: "Ensure /search has SSR fallback content and proper meta tags" },
  ],
  good_findings: [
    "Excellent TTFB on static pages (34-187ms) — CF Workers edge is fast",
    "Zero CLS across all pages (0.000)",
    "SEO scores perfect (1.0) on crawlable pages",
    "Cart page near-perfect (0.99 perf) with minimal JS",
    "Best Practices 1.0 on homepage",
  ],
};

const pages = Object.entries(data.lighthouse) as [string, any][];
const pageLabels: Record<string, string> = { home: "Home", products: "Products", product_detail: "Product Detail", cart: "Cart", checkout: "Checkout" };
const metricUnits: Record<string, string> = { lcp: "ms", fcp: "ms", si: "ms", tbt: "ms", cls: "", ttfb: "ms" };
const metricNames: Record<string, string> = { lcp: "LCP", fcp: "FCP", si: "Speed Index", tbt: "TBT", cls: "CLS", ttfb: "TTFB" };
const barMax = (key: string) => key === "cls" ? 0.1 : key === "ttfb" ? 500 : key === "tbt" ? 1500 : 6000;
---

<Layout title="Performance Audit — amerikvitamin.mn" noindex nofollow>
  <style>
    .gauge-ring { fill: none; stroke-width: 8; }
    .gauge-bg { stroke: #e5e7eb; }
    .gauge-fg-good { stroke: #22c55e; }
    .gauge-fg-ok { stroke: #f97316; }
    .gauge-fg-bad { stroke: #ef4444; }
    .bar-track { background: #f3f4f6; border-radius: 4px; overflow: hidden; height: 28px; position: relative; }
    .bar-fill { height: 100%; border-radius: 4px; display: flex; align-items: center; padding-left: 8px; font-size: 12px; font-weight: 600; color: white; min-width: 40px; }
    .api-row:nth-child(even) { background: #f9fafb; }
    .rec-card { transition: transform 0.15s; }
    .rec-card:hover { transform: translateY(-2px); }
    .tooltip { position: absolute; bottom: 100%; left: 50%; transform: translateX(-50%); background: #1f2937; color: white; padding: 4px 8px; border-radius: 4px; font-size: 11px; white-space: nowrap; pointer-events: none; opacity: 0; transition: opacity 0.2s; }
    .tooltip-parent:hover .tooltip { opacity: 1; }
  </style>

  <div class="container mx-auto px-4 py-8 max-w-6xl">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-foreground mb-1">Performance Audit</h1>
      <p class="text-muted-foreground">{data.metadata.url} &middot; {data.metadata.date}</p>
    </div>

    <!-- Score Gauges -->
    <section class="mb-10">
      <h2 class="text-xl font-semibold text-foreground mb-4">Lighthouse Scores</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-4">
        {pages.map(([key, page]: [string, any]) => {
          const p = page.scores.performance ?? 0;
          const circumference = 2 * Math.PI * 40;
          const offset = circumference - (p * circumference);
          const colorClass = p >= 0.9 ? 'gauge-fg-good' : p >= 0.5 ? 'gauge-fg-ok' : 'gauge-fg-bad';
          return (
            <div class={`rounded-xl p-4 text-center ${scoreBg(p)}`}>
              <svg viewBox="0 0 100 100" class="w-24 h-24 mx-auto">
                <circle cx="50" cy="50" r="40" class="gauge-ring gauge-bg"/>
                <circle cx="50" cy="50" r="40" class={`gauge-ring ${colorClass}`}
                  stroke-dasharray={circumference} stroke-dashoffset={offset}
                  transform="rotate(-90 50 50)"/>
                <text x="50" y="54" text-anchor="middle" class={`text-2xl font-bold ${scoreColor(p)}`}>
                  {p === 0 ? "–" : Math.round(p * 100)}
                </text>
              </svg>
              <p class="mt-2 font-medium text-foreground text-sm">{pageLabels[key] || key}</p>
              <p class="text-xs text-muted-foreground">{page.url}</p>
            </div>
          );
        })}
      </div>
    </section>

    <!-- Core Web Vitals -->
    <section class="mb-10">
      <h2 class="text-xl font-semibold text-foreground mb-4">Core Web Vitals</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="border-b-2 border-border">
              <th class="text-left py-2 px-3 text-muted-foreground font-medium">Page</th>
              {Object.keys(metricNames).map(k => (
                <th class="text-right py-2 px-3 text-muted-foreground font-medium">{metricNames[k]}<br/><span class="text-xs font-normal">({metricUnits[k] || ''})</span></th>
              ))}
            </tr>
          </thead>
          <tbody>
            {pages.map(([key, page]: [string, any]) => {
              const m = page.metrics;
              const c = (base: string, val: number, good: number, ok: number) => `${base} ${val === 0 ? 'text-gray-400' : val <= good ? 'text-green-600' : val <= ok ? 'text-orange-600' : 'text-red-600'}`;
              const clsColor = m.cls === 0 ? 'text-green-600' : 'text-red-600';
              return (
                <tr class="border-b border-border hover:bg-muted/50">
                  <td class="py-2 px-3 font-medium text-foreground">{pageLabels[key]}</td>
                  <td class={c('text-right py-2 px-3 font-mono', m.lcp, 2500, 4000)}>{m.lcp || '–'}</td>
                  <td class={c('text-right py-2 px-3 font-mono', m.fcp, 1800, 3000)}>{m.fcp || '–'}</td>
                  <td class={c('text-right py-2 px-3 font-mono', m.si, 3400, 5800)}>{m.si || '–'}</td>
                  <td class={c('text-right py-2 px-3 font-mono', m.tbt, 200, 600)}>{m.tbt || '–'}</td>
                  <td class={`text-right py-2 px-3 font-mono ${clsColor}`}>{m.cls}</td>
                  <td class={c('text-right py-2 px-3 font-mono', m.ttfb, 200, 500)}>{m.ttfb || '–'}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
      <div class="flex gap-4 mt-3 text-xs text-muted-foreground">
        <span class="flex items-center gap-1"><span class="w-3 h-3 rounded-full bg-green-500 inline-block"></span> Good</span>
        <span class="flex items-center gap-1"><span class="w-3 h-3 rounded-full bg-orange-500 inline-block"></span> Needs Improvement</span>
        <span class="flex items-center gap-1"><span class="w-3 h-3 rounded-full bg-red-500 inline-block"></span> Poor</span>
      </div>
    </section>

    <!-- Transfer Size -->
    <section class="mb-10">
      <h2 class="text-xl font-semibold text-foreground mb-4">Transfer Size & Unused JS</h2>
      <div class="space-y-4">
        {pages.map(([key, page]: [string, any]) => {
          if (page.transfer_bytes === null) return null;
          const kb = Math.round(page.transfer_bytes / 1024);
          const unusedKb = Math.round(page.unused_js_bytes / 1024);
          const pct = page.transfer_bytes > 0 ? Math.round((page.unused_js_bytes / page.transfer_bytes) * 100) : 0;
          return (
            <div>
              <div class="flex justify-between text-sm mb-1">
                <span class="font-medium text-foreground">{pageLabels[key]}</span>
                <span class="text-muted-foreground">{kb} KB total &middot; {unusedKb} KB unused JS ({pct}%)</span>
              </div>
              <div class="bar-track">
                <div class="bar-fill bg-blue-500" style={`width: ${Math.min(pct * 2, 100)}%`}>{pct}%</div>
              </div>
            </div>
          );
        })}
      </div>
    </section>

    <!-- API Latency -->
    <section class="mb-10">
      <h2 class="text-xl font-semibold text-foreground mb-4">API Latency <span class="text-sm font-normal text-muted-foreground">(warm, ms)</span></h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="border-b-2 border-border">
              <th class="text-left py-2 px-3 text-muted-foreground font-medium">Endpoint</th>
              <th class="text-right py-2 px-3 text-muted-foreground font-medium">TTFB</th>
              <th class="text-right py-2 px-3 text-muted-foreground font-medium">Total</th>
              <th class="text-right py-2 px-3 text-muted-foreground font-medium">Size</th>
              <th class="text-left py-2 px-3 text-muted-foreground font-medium">Note</th>
            </tr>
          </thead>
          <tbody>
            {data.api_latency.endpoints.map((ep: any) => {
              const latencyColor = ep.ttfb < 300 ? 'text-green-600' : ep.ttfb < 800 ? 'text-orange-600' : 'text-red-600';
              return (
                <tr class="api-row border-b border-border">
                  <td class="py-2 px-3 font-mono text-xs text-foreground">{ep.name}</td>
                  <td class={`text-right py-2 px-3 font-mono font-semibold ${latencyColor}`}>{ep.ttfb}ms</td>
                  <td class="text-right py-2 px-3 font-mono text-foreground">{ep.total}ms</td>
                  <td class="text-right py-2 px-3 font-mono text-foreground">{ep.size ? `${(ep.size / 1024).toFixed(1)}KB` : '–'}</td>
                  <td class="py-2 px-3 text-xs text-muted-foreground">{ep.note || ''}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
        <p class="mt-2 text-xs text-muted-foreground">Cold start penalty: ~{data.api_latency.cold_start_penalty_ms}ms</p>
      </div>
    </section>

    <!-- Prioritized Recommendations -->
    <section class="mb-10">
      <h2 class="text-xl font-semibold text-foreground mb-4">Recommendations</h2>
      <div class="space-y-3">
        {data.recommendations.map((rec: any) => (
          <div class={`rec-card rounded-lg border-2 p-4 ${rec.impact === 'high' ? 'border-red-300 bg-red-50' : rec.impact === 'medium' ? 'border-orange-300 bg-orange-50' : 'border-blue-300 bg-blue-50'}`}>
            <div class="flex items-start gap-3">
              <span class={`inline-flex items-center justify-center w-7 h-7 rounded-full text-white text-xs font-bold shrink-0 ${priorityBadge(rec.priority)}`}>
                {rec.priority}
              </span>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 flex-wrap">
                  <h3 class="font-semibold text-foreground">{rec.title}</h3>
                  <span class={`text-xs px-2 py-0.5 rounded-full font-medium ${effortBadge(rec.effort)}`}>
                    {rec.effort} effort
                  </span>
                  <span class="text-xs px-2 py-0.5 rounded-full bg-gray-100 text-gray-700 font-medium">
                    {rec.impact} impact
                  </span>
                </div>
                <p class="text-sm text-muted-foreground mt-1">{rec.description}</p>
                <p class="text-xs text-muted-foreground mt-1 font-mono">{rec.id}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Good Findings -->
    <section class="mb-10">
      <h2 class="text-xl font-semibold text-foreground mb-4">What's Working Well</h2>
      <ul class="space-y-2">
        {data.good_findings.map((f: string) => (
          <li class="flex items-start gap-2">
            <span class="text-green-500 mt-0.5">&#10003;</span>
            <span class="text-foreground text-sm">{f}</span>
          </li>
        ))}
      </ul>
    </section>

    <p class="text-xs text-muted-foreground text-center mt-8 border-t border-border pt-4">
      Generated {data.metadata.date} &middot; Lighthouse CLI v13.3.0 &middot; {data.metadata.url}
    </p>
  </div>
</Layout>
