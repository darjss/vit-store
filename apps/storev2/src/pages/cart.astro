---















import CartList from "@/components/cart/cart-list";
import Layout from "@/layouts/Layout.astro";

export const prerender = true;

const title = "Сагс";
const description = "Таны сагсанд байгаа бүтээгдэхүүнүүд. Захиалгаа баталгаажуулж, төлбөрөө хийгээрэй.";
---

<Layout title={title} description={description} noindex>
    <div class="container mx-auto px-4 py-8 min-h-screen">
        <CartList client:load>
            <div slot="fallback" class="space-y-6 min-h-[calc(100vh-200px)]">
                <div class="border border-border p-6 bg-card rounded-2xl shadow-soft">
                    <div class="h-8 bg-foreground/10 w-48 mb-4 animate-pulse rounded-lg"></div>
                    <div class="space-y-4">
                        <div class="flex gap-4 p-4 border border-border rounded-2xl">
                            <div class="w-24 h-24 bg-foreground/10 animate-pulse rounded-xl"></div>
                            <div class="flex-1 space-y-2">
                                <div class="h-6 bg-foreground/10 w-3/4 animate-pulse rounded-lg"></div>
                                <div class="h-4 bg-foreground/10 w-1/2 animate-pulse rounded-lg"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </CartList>
    </div>
</Layout>
