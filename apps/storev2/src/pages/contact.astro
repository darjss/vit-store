---
import Layout from "@/layouts/Layout.astro";
import IconPhone from "~icons/ri/phone-line";
import IconMail from "~icons/ri/mail-line";
import IconMapPin from "~icons/ri/map-pin-line";
import IconFacebook from "~icons/ri/facebook-fill";
import IconInstagram from "~icons/ri/instagram-line";

const title = "Бидэнтэй холбогдох";
const description = "Amerik Vitamin - бидэнтэй холбогдох мэдээлэл. Утас, и-мэйл, сошиал медиа.";

const contactMethods = [
  {
    icon: IconPhone,
    label: "Утас",
    value: "9999-3950",
    href: "tel:+97699993950",
    desc: "Даваа-Баасан 10:00-18:00",
  },
  {
    icon: IconMail,
    label: "И-мэйл",
    value: "info@amerikvitamin.mn",
    href: "mailto:info@amerikvitamin.mn",
    desc: "24/7 хариу өгнө",
  },
  {
    icon: IconMapPin,
    label: "Хүргэлт",
    value: "Улаанбаатар + Хөдөө",
    href: "/shipping",
    desc: "Өдөр бүр 12:00-с хойш",
  },
];

const socials = [
  {
    icon: IconFacebook,
    label: "Facebook",
    href: "https://www.facebook.com/profile.php?id=100057596651892",
    handle: "Amerik Vitamin",
  },
  {
    icon: IconInstagram,
    label: "Instagram",
    href: "https://www.instagram.com/amerikhunsbaraa/",
    handle: "@amerikhunsbaraa",
  },
];
---

<Layout title={title} description={description}>
  <div class="container mx-auto px-5 py-8 lg:px-8 lg:py-14 max-w-4xl">
    <!-- Header -->
    <div class="mb-8 lg:mb-10">
      <div class="border border-border bg-primary p-4 lg:p-6 shadow-soft-lg mb-4 rounded-lg">
        <h1 class="text-2xl md:text-3xl lg:text-4xl font-bold uppercase tracking-tight">
          Бидэнтэй холбогдох
        </h1>
        <p class="text-sm font-medium text-foreground/70 mt-2">
          Асуулт, санал, захиалгын талаар холбогдоно уу
        </p>
      </div>
    </div>

    <!-- Contact Methods -->
    <div class="grid gap-4 md:grid-cols-3 mb-10">
      {contactMethods.map((method) => (
        <a
          href={method.href}
          class="group border border-border bg-card p-5 shadow-soft-sm hover:shadow-soft hover:-translate-y-0.5 active:scale-[0.97] transition-[box-shadow,transform] duration-200 ease-out-quart rounded-lg"
        >
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 border border-border bg-primary flex items-center justify-center rounded-lg">
              <method.icon class="w-5 h-5" />
            </div>
            <span class="text-[10px] font-bold uppercase tracking-widest text-muted-foreground">{method.label}</span>
          </div>
          <div class="font-bold text-lg uppercase tracking-tight">{method.value}</div>
          <p class="text-xs font-medium text-muted-foreground mt-1">{method.desc}</p>
        </a>
      ))}
    </div>

    <!-- Important Notice -->
    <div class="border border-border bg-yellow-50 p-5 lg:p-6 shadow-soft-sm mb-10 rounded-lg">
      <div class="flex items-start gap-3">
        <div class="w-8 h-8 border border-border bg-primary flex items-center justify-center shrink-0 mt-0.5 rounded-lg">
          <span class="font-bold text-xs">!</span>
        </div>
        <div>
          <h3 class="font-bold text-sm uppercase tracking-wider mb-2">Чухал мэдэгдэл</h3>
          <p class="text-sm font-medium leading-relaxed">
            Бид <strong>зөвхөн Монгол улсын дотоодод</strong> хүргэлт хийдэг. Олон улсын хүргэлт хийдэггүй.
            Бараа буцаах, эсвэл мөнгө буцаан олгох боломжгүй тул бүтээгдэхүүнээ сайтар сонгоно уу.
          </p>
        </div>
      </div>
    </div>

    <!-- Social Media -->
    <div class="border border-border bg-card p-5 lg:p-6 shadow-soft-sm rounded-lg">
      <h2 class="text-xl font-bold uppercase tracking-tight mb-4">Сошиал медиа</h2>
      <p class="text-sm font-medium text-muted-foreground mb-5">
        Шинэ бараа, мэдээллийг сошиал хуудсаасаа хүлээн авна уу
      </p>
      <div class="grid gap-3 md:grid-cols-2">
        {socials.map((social) => (
          <a
            href={social.href}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center gap-4 border border-border bg-background p-4 shadow-soft-sm hover:shadow-soft hover:-translate-y-0.5 active:scale-[0.97] transition-[box-shadow,transform] duration-200 ease-out-quart rounded-lg"
          >
            <div class="w-12 h-12 border border-border bg-primary flex items-center justify-center group-hover:scale-105 transition-transform rounded-lg">
              <social.icon class="w-6 h-6" />
            </div>
            <div>
              <div class="font-bold text-sm uppercase tracking-wider">{social.label}</div>
              <div class="text-xs font-bold text-muted-foreground">{social.handle}</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</Layout>
