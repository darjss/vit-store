---
import Layout from "@/layouts/Layout.astro";
import IconPhone from "~icons/ri/phone-line";
import IconMail from "~icons/ri/mail-line";
import IconMapPin from "~icons/ri/map-pin-line";
import IconFacebook from "~icons/ri/facebook-fill";
import IconInstagram from "~icons/ri/instagram-line";
import IconArrowRight from "~icons/ri/arrow-right-s-line";

const title = "Бидэнтэй холбогдох";
const description = "Amerik Vitamin - бидэнтэй холбогдох мэдээлэл. Утас, и-мэйл, сошиал медиа.";

const contactMethods = [
  {
    icon: IconPhone,
    label: "Утас",
    value: "9999-3950",
    href: "tel:+97699993950",
    desc: "Даваа-Баасан 10:00-18:00",
    wash: "bg-wash-peach",
  },
  {
    icon: IconMail,
    label: "И-мэйл",
    value: "info@amerikvitamin.mn",
    href: "mailto:info@amerikvitamin.mn",
    desc: "24/7 хариу өгнө",
    wash: "bg-wash-sky",
  },
  {
    icon: IconMapPin,
    label: "Хүргэлт",
    value: "Улаанбаатар + Хөдөө",
    href: "/shipping",
    desc: "Өдөр бүр 12:00-с хойш",
    wash: "bg-wash-mint",
  },
];

const socials = [
  {
    icon: IconFacebook,
    label: "Facebook",
    href: "https://www.facebook.com/profile.php?id=100057596651892",
    handle: "Amerik Vitamin",
    wash: "bg-wash-lilac",
  },
  {
    icon: IconInstagram,
    label: "Instagram",
    href: "https://www.instagram.com/amerikhunsbaraa/",
    handle: "@amerikhunsbaraa",
    wash: "bg-wash-blush",
  },
];
---

<Layout title={title} description={description}>
  <div class="container mx-auto max-w-2xl px-5 py-8 lg:px-8 lg:py-14">
    <!-- Header -->
    <div class="enter-rise mb-8 lg:mb-10">
      <h1 class="mb-2 font-display text-foreground text-h2">Бидэнтэй холбогдох</h1>
      <p class="text-muted-foreground text-sm md:text-base">
        Асуулт, санал, захиалгын талаар холбогдоно уу
      </p>
    </div>

    <!-- Contact Methods -->
    <div class="enter-rise stagger-1 mb-6 divide-y divide-border overflow-hidden rounded-2xl border border-border bg-card shadow-soft">
      {contactMethods.map((method) => (
        <a
          href={method.href}
          class="group flex min-h-[44px] items-center gap-4 p-4 transition-[background-color] duration-150 ease-out hover:bg-muted/60 md:p-5"
        >
          <div class={`flex h-11 w-11 flex-shrink-0 items-center justify-center rounded-full text-foreground ${method.wash}`}>
            <method.icon class="h-5 w-5" />
          </div>
          <div class="min-w-0 flex-1">
            <div class="text-muted-foreground text-xs uppercase tracking-wide">{method.label}</div>
            <div class="truncate font-semibold text-foreground text-sm md:text-base">{method.value}</div>
            <p class="text-muted-foreground text-xs">{method.desc}</p>
          </div>
          <IconArrowRight class="h-5 w-5 flex-shrink-0 text-muted-foreground transition-transform duration-150 ease-out group-hover:translate-x-0.5" />
        </a>
      ))}
    </div>

    <!-- Important Notice -->
    <div class="enter-rise stagger-2 mb-6 rounded-2xl bg-wash-lemon/70 p-5 md:p-6">
      <h3 class="mb-2 font-display text-foreground text-sm">Чухал мэдэгдэл</h3>
      <p class="text-foreground text-sm leading-relaxed">
        Бид <strong>зөвхөн Монгол улсын дотоодод</strong> хүргэлт хийдэг. Олон улсын хүргэлт хийдэггүй.
        Бараа буцаах, эсвэл мөнгө буцаан олгох боломжгүй тул бүтээгдэхүүнээ сайтар сонгоно уу.
      </p>
    </div>

    <!-- Social Media -->
    <div class="enter-rise stagger-3 rounded-2xl border border-border bg-card p-5 shadow-soft md:p-6">
      <h2 class="mb-1 font-display text-foreground text-lg">Сошиал медиа</h2>
      <p class="mb-5 text-muted-foreground text-sm">
        Шинэ бараа, мэдээллийг сошиал хуудсаасаа хүлээн авна уу
      </p>
      <div class="grid gap-3 md:grid-cols-2">
        {socials.map((social) => (
          <a
            href={social.href}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center gap-4 rounded-xl border border-border bg-card p-4 shadow-soft-sm transition-[transform,box-shadow] duration-150 ease-out hover:-translate-y-0.5 hover:shadow-soft active:scale-[0.98]"
          >
            <div class={`flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-full text-foreground ${social.wash}`}>
              <social.icon class="h-6 w-6" />
            </div>
            <div>
              <div class="font-semibold text-foreground text-sm">{social.label}</div>
              <div class="text-muted-foreground text-xs">{social.handle}</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</Layout>
