---
import Layout from "@/layouts/Layout.astro";
import IconTruck from "~icons/ri/truck-line";
import IconMapPin from "~icons/ri/map-pin-line";
import IconTime from "~icons/ri/time-line";
import IconAlert from "~icons/ri/alert-line";

const title = "Хүргэлтийн мэдээлэл";
const description = "Amerik Vitamin - хүргэлтийн бүс, хүргэлтийн хураамж, хөдөө рүү хүргэлт. Зөвхөн Монгол улсын дотоодод.";

const deliveryInfo = [
  {
    icon: IconMapPin,
    title: "Улаанбаатар",
    desc: "Улаанбаатар хотын бүх дүүрэгт хүргэлт хийнэ. Доорх газрын зураг дээр хүргэлтийн бүсийг харна уу.",
  },
  {
    icon: IconTruck,
    title: "Хөдөө орон нутаг",
    desc: 'Улаанбаатарын бусад аймаг, сумдад "Замын Унаа"-ар хүргэлт хийнэ. Тээврийн зардал харилцагчийн өөрийн зөөлөг болно.',
  },
  {
    icon: IconTime,
    title: "Хүргэлтийн хугацаа",
    desc: "Захиалгыг өдөр бүр 12:00 цагаас хойш хүргэнэ. Өглөөний захиалгыг өдөрт нь, оройн захиалгыг маргааш хүргэнэ.",
  },
];
---

<Layout title={title} description={description}>
  <div class="container mx-auto px-5 py-8 lg:px-8 lg:py-14 max-w-4xl">
    <!-- Header -->
    <div class="mb-8 lg:mb-10">
      <div class="border border-border bg-primary p-4 lg:p-6 shadow-soft-lg mb-4">
        <h1 class="text-2xl md:text-3xl lg:text-4xl font-extrabold uppercase tracking-tight">
          Хүргэлтийн мэдээлэл
        </h1>
        <p class="text-sm font-medium text-foreground/70 mt-2">
          Зөвхөн Монгол улсын дотоодод хүргэлт хийнэ
        </p>
      </div>
    </div>

    <!-- Delivery Zone Map -->
    <div class="border border-border bg-card p-4 lg:p-6 shadow-soft-sm mb-8">
      <h2 class="text-lg font-extrabold uppercase tracking-tight mb-4">Улаанбаатар хотын хүргэлтийн бүс</h2>
      <div class="border border-border bg-muted/30 overflow-hidden">
        <img
          src="/delivery-zone.png"
          alt="Улаанбаатар хотын хүргэлтийн бүсийн зураг"
          class="w-full h-auto object-contain"
          loading="lazy"
        />
      </div>
      <p class="text-xs font-medium text-muted-foreground mt-3">
        Дээрх зураг дээрх бүсүүдэд стандарт хүргэлтийн хураамж тооцогдоно.
      </p>
    </div>

    <!-- Delivery Info Cards -->
    <div class="grid gap-4 md:grid-cols-3 mb-8">
      {deliveryInfo.map((item) => (
        <div class="border border-border bg-card p-5 shadow-soft-sm">
          <div class="w-10 h-10 border border-border bg-primary flex items-center justify-center mb-3">
            <item.icon class="w-5 h-5" />
          </div>
          <h3 class="font-extrabold text-sm uppercase tracking-wider mb-2">{item.title}</h3>
          <p class="text-xs font-medium text-muted-foreground leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>

    <!-- Important Notice -->
    <div class="border border-border bg-yellow-50 p-5 lg:p-6 shadow-soft-sm">
      <div class="flex items-start gap-3">
        <div class="w-8 h-8 border border-border bg-primary flex items-center justify-center shrink-0 mt-0.5">
          <IconAlert class="w-4 h-4" />
        </div>
        <div>
          <h3 class="font-extrabold text-sm uppercase tracking-wider mb-2">Чухал анхааруулга</h3>
          <ul class="text-sm font-medium leading-relaxed space-y-1.5">
            <li>• Хүргэлт <strong>зөвхөн Монгол улсын дотоодод</strong> хийгдэнэ.</li>
            <li>• Олон улсын хүргэлт хийдэггүй.</li>
            <li>• Хөдөө рүү хүргэхдээ "Замын Унаа"-ар илгээдэг бөгөөд тээврийн зардал хүлээн авагчийн хариуцах болно.</li>
            <li>• Хүргэлтийн хураамж захиалгын дүн дээр нэмэгдэнэ.</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</Layout>
