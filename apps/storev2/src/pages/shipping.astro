---
import Layout from "@/layouts/Layout.astro";
import { DeliveryIcon as IconTruck, MapPointIcon as IconMapPin, ClockCircleIcon as IconTime } from "@solar-icons/solid/linear";

const title = "Хүргэлтийн мэдээлэл";
const description = "Amerik Vitamin - хүргэлтийн бүс, хүргэлтийн хураамж, хөдөө рүү хүргэлт. Зөвхөн Монгол улсын дотоодод.";

const deliveryInfo = [
  {
    icon: IconMapPin,
    title: "Улаанбаатар",
    desc: "Улаанбаатар хотын бүх дүүрэгт хүргэлт хийнэ. Доорх газрын зураг дээр хүргэлтийн бүсийг харна уу.",
    wash: "bg-wash-sky",
  },
  {
    icon: IconTruck,
    title: "Хөдөө орон нутаг",
    desc: 'Улаанбаатарын бусад аймаг, сумдад "Замын Унаа"-ар хүргэлт хийнэ. Тээврийн зардал харилцагчийн өөрийн зөөлөг болно.',
    wash: "bg-wash-peach",
  },
  {
    icon: IconTime,
    title: "Хүргэлтийн хугацаа",
    desc: "Захиалгыг өдөр бүр 12:00 цагаас хойш хүргэнэ. Өглөөний захиалгыг өдөрт нь, оройн захиалгыг маргааш хүргэнэ.",
    wash: "bg-wash-mint",
  },
];
---

<Layout title={title} description={description}>
  <div class="container mx-auto max-w-[65ch] px-5 py-8 lg:px-8 lg:py-14">
    <!-- Header -->
    <header class="enter-rise mb-10">
      <h1 class="mb-2 font-display text-foreground text-h2">Хүргэлтийн мэдээлэл</h1>
      <p class="text-muted-foreground text-sm md:text-base">
        Зөвхөн Монгол улсын дотоодод хүргэлт хийнэ
      </p>
    </header>

    <div class="space-y-10">
      <!-- Delivery Zone Map -->
      <section class="enter-rise stagger-1">
        <h2 class="mb-4 font-display text-foreground text-lg">Улаанбаатар хотын хүргэлтийн бүс</h2>
        <div class="overflow-hidden rounded-2xl border border-border bg-card shadow-soft">
          <img
            src="/delivery-zone.png"
            alt="Улаанбаатар хотын хүргэлтийн бүсийн зураг"
            class="h-auto w-full object-contain"
            loading="lazy"
          />
        </div>
        <p class="mt-3 text-muted-foreground text-xs">
          Дээрх зураг дээрх бүсүүдэд стандарт хүргэлтийн хураамж тооцогдоно.
        </p>
      </section>

      <!-- Delivery Info -->
      <section class="enter-rise stagger-2 space-y-6">
        {deliveryInfo.map((item) => (
          <div class="flex items-start gap-4">
            <div class={`flex h-11 w-11 flex-shrink-0 items-center justify-center rounded-full text-foreground ${item.wash}`}>
              <item.icon class="h-5 w-5" />
            </div>
            <div>
              <h3 class="mb-1 font-display text-foreground text-sm">{item.title}</h3>
              <p class="text-muted-foreground text-sm leading-relaxed md:text-base">{item.desc}</p>
            </div>
          </div>
        ))}
      </section>

      <!-- Important Notice -->
      <section class="enter-rise stagger-3 rounded-2xl bg-wash-lemon/70 p-5 md:p-6">
        <h3 class="mb-3 font-display text-foreground text-sm">Чухал анхааруулга</h3>
        <ul class="space-y-2 text-foreground text-sm leading-relaxed">
          <li>Хүргэлт <strong>зөвхөн Монгол улсын дотоодод</strong> хийгдэнэ.</li>
          <li>Олон улсын хүргэлт хийдэггүй.</li>
          <li>Хөдөө рүү хүргэхдээ "Замын Унаа"-ар илгээдэг бөгөөд тээврийн зардал хүлээн авагчийн хариуцах болно.</li>
          <li>Хүргэлтийн хураамж захиалгын дүн дээр нэмэгдэнэ.</li>
        </ul>
      </section>
    </div>
  </div>
</Layout>
