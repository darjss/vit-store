---
import PaymentStatus from "@/components/payment/payment-status";
import { env } from "cloudflare:workers";
import Layout from "@/layouts/Layout.astro";
import { loadOrderOrRedirect } from "@/lib/server-loaders";
import { createServerClient } from "@/lib/trpc";
import ProductImageFallback from "@/components/product/product-image-fallback.tsx";
import IconCheck from "~icons/ri/check-line";
import IconHome from "~icons/ri/home-4-line";
import IconMail from "~icons/ri/mail-line";
import IconMapPin from "~icons/ri/map-pin-line";
import IconPhone from "~icons/ri/phone-line";
import IconUser from "~icons/ri/user-line";
import { orderStatusLabels } from "@vit/shared";
import type { OrderStatusType } from "@vit/shared/types";

const { orderNumber } = Astro.params;
const checkoutToken = Astro.url.searchParams.get("ct") || undefined;
const cookieHeader = Astro.request.headers.get("cookie") || "";
const serverApi = createServerClient(cookieHeader, env.server);
if (!orderNumber) {
    return Astro.redirect("/404");
}
const result = await loadOrderOrRedirect(serverApi, orderNumber, checkoutToken, Astro.redirect);
if ("redirect" in result) return result.redirect;
const order = result.order;

const timelineSteps: OrderStatusType[] = ["pending", "shipped", "delivered"];
const currentStepIndex = timelineSteps.indexOf((order.status ?? "pending") as OrderStatusType);

const statusBadgeClasses: Record<string, string> = {
    created: "bg-card border border-border text-foreground",
    pending: "bg-warning text-warning-foreground",
    shipped: "bg-info text-info-foreground",
    delivered: "bg-success text-success-foreground",
    cancelled: "bg-error text-error-foreground",
    refunded: "bg-secondary text-secondary-foreground",
};
---

<Layout>
    <div class="container mx-auto max-w-4xl px-4 py-8 lg:py-12">
        {order.payments[0] ? (
            <PaymentStatus payment={{ ...order.payments[0], checkoutToken }} client:load />
        ) : (
            <div class="mb-12 text-center">
                <div class="mb-6 inline-flex size-20 items-center justify-center rounded-full bg-muted text-muted-foreground shadow-soft-lg">
                    <IconCheck class="h-10 w-10" aria-hidden="true" />
                </div>
                <h1 class="mb-3 font-display text-2xl text-foreground">Захиалга хүлээн авагдлаа</h1>
                <p class="text-lg text-muted-foreground">Төлбөрийн мэдээлэл олдсонгүй. Хүргэгчтэй холбогдоно уу.</p>
            </div>
        )}

        <div class="enter-rise mb-6 overflow-hidden rounded-2xl border border-border bg-card shadow-soft">
            <div class="flex flex-col justify-between gap-4 border-border border-b bg-wash-lemon/70 p-6 md:flex-row md:items-center md:p-8">
                <div>
                    <h2 class="mb-1 font-display text-foreground text-h3">Захиалгын мэдээлэл</h2>
                    <div class="flex items-center gap-3">
                        <span class="text-muted-foreground text-sm">Захиалгын дугаар:</span>
                        <span class="font-display text-base text-foreground">{orderNumber}</span>
                    </div>
                </div>
                <div>
                    <span class={`inline-flex items-center rounded-full px-3 py-1 font-semibold text-xs ${statusBadgeClasses[order?.status ?? "pending"] ?? "bg-success text-success-foreground"}`}>
                        {orderStatusLabels[order?.status as OrderStatusType] ?? order?.status ?? 'Хүлээгдэж буй'}
                    </span>
                </div>
            </div>

            <div class="p-6 md:p-8">
                {currentStepIndex >= 0 && (
                    <div class="mb-6 rounded-xl bg-wash-mint/40 p-4">
                        <div class="flex items-start">
                            {timelineSteps.map((timelineStep, index) => (
                                <>
                                    {index > 0 && (
                                        <div class={`mt-4 h-px flex-1 ${index <= currentStepIndex ? "bg-success-foreground/40" : "bg-border"}`}></div>
                                    )}
                                    <div class="flex w-16 flex-col items-center gap-1.5">
                                        <div class={`flex h-8 w-8 items-center justify-center rounded-full text-xs ${index <= currentStepIndex ? "bg-success text-success-foreground" : "border border-border bg-card text-muted-foreground"}`}>
                                            {index <= currentStepIndex ? (
                                                <IconCheck class="h-4 w-4" />
                                            ) : (
                                                <span class="font-semibold">{index + 1}</span>
                                            )}
                                        </div>
                                        <span class={`text-center text-[11px] leading-tight ${index === currentStepIndex ? "font-semibold text-foreground" : "text-muted-foreground"}`}>
                                            {orderStatusLabels[timelineStep]}
                                        </span>
                                    </div>
                                </>
                            ))}
                        </div>
                    </div>
                )}

                <div class="grid gap-6 md:grid-cols-2">
                    <div>
                        <h3 class="mb-3 font-display text-base text-foreground">Хүргэлтийн мэдээлэл</h3>
                        <div class="space-y-3">
                            <div class="flex items-start gap-3">
                                <IconMapPin class="mt-0.5 h-5 w-5 flex-shrink-0 text-muted-foreground" />
                                <div>
                                    <p class="text-muted-foreground text-sm">Хүргэлтийн хаяг</p>
                                    <p class="font-medium text-foreground">{order?.address}</p>
                                </div>
                            </div>
                            <div class="flex items-start gap-3">
                                <IconPhone class="mt-0.5 h-5 w-5 flex-shrink-0 text-muted-foreground" />
                                <div>
                                    <p class="text-muted-foreground text-sm">Холбоо барих дугаар</p>
                                    <p class="font-medium text-foreground">{order?.customerPhone}</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div>
                        <h3 class="mb-3 font-display text-base text-foreground">Захиалгын дүн</h3>
                        <div class="space-y-2">
                            <div class="flex justify-between">
                                <span class="text-muted-foreground text-sm">Захиалсан огноо:</span>
                                <span class="font-medium text-foreground text-sm">{new Date(order?.createdAt || '').toLocaleDateString()}</span>
                            </div>
                            <div class="flex justify-between">
                                <span class="text-muted-foreground text-sm">Хүргэлтийн арга:</span>
                                <span class="font-medium text-foreground text-sm">{order?.deliveryProvider === 'tu-delivery' ? 'TU Delivery' : order?.deliveryProvider === 'self' ? 'Өөрөө авах' : order?.deliveryProvider?.replace('-', ' ') || 'TU Delivery'}</span>
                            </div>
                            {order?.notes && (
                                <div class="flex justify-between gap-4">
                                    <span class="text-muted-foreground text-sm">Тэмдэглэл:</span>
                                    <span class="font-medium text-foreground text-sm">{order.notes}</span>
                                </div>
                            )}
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {order.orderDetails && order.orderDetails.length > 0 && (
            <div class="enter-rise stagger-1 mb-6">
                <h2 class="mb-4 font-display text-foreground text-h3">Захиалсан бүтээгдэхүүн</h2>
                <div class="space-y-3">
                    {order.orderDetails.map((detail) => (
                        <div class="rounded-2xl border border-border bg-card p-4 shadow-soft md:p-5">
                            <div class="flex items-center gap-4">
                                <div class="relative h-16 w-16 flex-shrink-0 overflow-hidden rounded-xl bg-muted md:h-20 md:w-20">
                                    {detail.product.images[0]?.url ? (
                                        <img
                                            src={detail.product.images[0].url}
                                            alt={detail.product.name}
                                            class="h-full w-full object-cover"
                                        />
                                    ) : (
                                        <ProductImageFallback name={detail.product.name} brand={detail.product.brand?.name ?? null} />
                                    )}
                                </div>
                                <div class="min-w-0 flex-1">
                                    <h3 class="mb-0.5 truncate font-semibold text-foreground text-sm md:text-base">{detail.product.name}</h3>
                                    {detail.product.brand?.name && (
                                        <p class="mb-2 text-muted-foreground text-xs">{detail.product.brand.name}</p>
                                    )}
                                    <div class="flex items-center justify-between">
                                        <span class="rounded-full bg-muted px-2.5 py-0.5 font-semibold text-foreground text-xs">{detail.quantity}x</span>
                                        <span class="font-display text-foreground text-sm md:text-base">₮{detail.product.price.toLocaleString()}</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        )}

        <div class="enter-rise stagger-2 mb-10">
            <div class="rounded-2xl border border-border bg-wash-lemon/70 p-6 shadow-soft md:p-8">
                <div class="flex items-center justify-between gap-4">
                    <div>
                        <h3 class="font-display text-foreground text-lg">Нийт дүн</h3>
                        <p class="text-muted-foreground text-sm">Татвар, шимтгэл багтсан</p>
                    </div>
                    <p class="font-display text-2xl text-foreground md:text-3xl">₮{(order?.total || 0).toLocaleString()}</p>
                </div>
            </div>
        </div>

        <div class="enter-rise stagger-3 flex flex-col justify-center gap-3 sm:flex-row">
            <a
                href="/"
                class="inline-flex min-h-12 items-center justify-center gap-2 rounded-full bg-primary px-8 py-3 font-semibold text-primary-foreground text-sm shadow-lift transition-[transform,box-shadow] duration-150 ease-out hover:-translate-y-0.5 hover:shadow-lift-lg active:scale-[0.97] md:text-base"
            >
                <IconHome class="h-4 w-4" />
                Худалдан авалтыг үргэлжлүүлэх
            </a>
            <a
                href="/profile"
                class="inline-flex min-h-12 items-center justify-center gap-2 rounded-full border border-border bg-card px-8 py-3 font-semibold text-foreground text-sm shadow-soft-sm transition-[transform,box-shadow,background-color] duration-150 ease-out hover:bg-muted hover:shadow-soft active:scale-[0.97] md:text-base"
            >
                <IconUser class="h-4 w-4" />
                Миний захиалгууд
            </a>
        </div>

        <!-- Help Section -->
        <div class="enter-rise stagger-4 mx-auto mt-12 text-center">
            <div class="rounded-2xl border border-border bg-card p-6 shadow-soft md:p-8">
                <h3 class="mb-2 font-display text-foreground text-lg">Тусламж хэрэгтэй юу?</h3>
                <p class="mb-6 text-muted-foreground text-sm">Хэрэв таны захиалгатай холбоотой асуулт байвал бидэнтэй холбогдоорой.</p>
                <div class="flex flex-col justify-center gap-3 sm:flex-row">
                    <a
                        href="tel:+97699993950"
                        class="inline-flex min-h-11 items-center justify-center gap-2 rounded-full border border-border bg-card px-6 py-2.5 font-semibold text-foreground text-sm shadow-soft-sm transition-[transform,box-shadow,background-color] duration-150 ease-out hover:bg-muted hover:shadow-soft active:scale-[0.97]"
                    >
                        <IconPhone class="h-4 w-4" />
                        Утсаар залгах
                    </a>
                    <a
                        href="mailto:info@amerikvitamin.mn"
                        class="inline-flex min-h-11 items-center justify-center gap-2 rounded-full border border-border bg-card px-6 py-2.5 font-semibold text-foreground text-sm shadow-soft-sm transition-[transform,box-shadow,background-color] duration-150 ease-out hover:bg-muted hover:shadow-soft active:scale-[0.97]"
                    >
                        <IconMail class="h-4 w-4" />
                        Имэйл илгээх
                    </a>
                </div>
            </div>
        </div>
    </div>
</Layout>
