---















import Layout from "@/layouts/Layout.astro";
import { createServerClient } from "@/lib/trpc";
import IconShoppingBag from "~icons/ri/shopping-bag-line";

// Get cookies from Astro's request context
const cookieHeader = Astro.request.headers.get("cookie") || "";
const serverApi = createServerClient(
	cookieHeader,
	Astro.locals.runtime.env.server,
	Astro.redirect, // Pass redirect function - will automatically redirect on unauthorized
);

// Auth guard: profile is auth-gated. On 401, the tRPC link calls
// redirectFn("/login") but the client still throws TRPCClientError.
// Redirect ONLY on UNAUTHORIZED; any other auth.check error is fatal.
let user;
try {
	user = await serverApi.auth.check.query();
} catch (err) {
	const code = (err as { data?: { code?: string } })?.data?.code ?? (err as { code?: string })?.code;
	if (code === "UNAUTHORIZED") return Astro.redirect("/login");
	throw err;
}

// Orders query is non-fatal: degrade gracefully (empty orders) instead of 500
// if order.getOrdersByCustomerId throws (e.g. INTERNAL_SERVER_ERROR).
let orders: Awaited<ReturnType<typeof serverApi.order.getOrdersByCustomerId.query>> = [];
try {
	orders = await serverApi.order.getOrdersByCustomerId.query();
} catch (err) {
	console.error("[profile] order.getOrdersByCustomerId failed; rendering empty orders", err);
}

const title = "Миний профайл";
const description = "Таны захиалгын түүх, профайлын мэдээлэл.";

// Format date helper
const formatDate = (timestamp: Date) => {
	return new Date(timestamp).toLocaleDateString("mn-MN", {
		year: "numeric",
		month: "long",
		day: "numeric",
	});
};

// Format phone helper
const formatPhone = (phone?: number) => {
	if (!phone) return "";
	const phoneStr = phone.toString();
	return `+976 ${phoneStr.slice(0, 4)} ${phoneStr.slice(4)}`;
};

// Status badges
const statusColors: Record<string, string> = {
	pending: "bg-warning text-warning-foreground",
	processing: "bg-info text-info-foreground",
	completed: "bg-success text-success-foreground",
	cancelled: "bg-error text-error-foreground",
};

const statusLabels: Record<string, string> = {
	pending: "Хүлээгдэж буй",
	processing: "Боловсруулж байна",
	completed: "Дууссан",
	cancelled: "Цуцлагдсан",
};
---

<Layout title={title} description={description} noindex nofollow>
	<div class="container mx-auto px-4 py-8 max-w-4xl">
		<!-- Header -->
		<div class="enter-rise mb-8">
			<h1 class="font-display text-h2 text-foreground">Миний профайл</h1>
		</div>

		<!-- User Info Card -->
		<div class="enter-rise stagger-1 mb-8 overflow-hidden rounded-2xl border border-border bg-card shadow-soft">
			<div class="bg-wash-lemon/70 p-6">
				<div class="flex items-center gap-4">
					<div class="flex h-14 w-14 flex-shrink-0 items-center justify-center rounded-full bg-primary font-display text-foreground text-lg">
						{user?.phone.toString().slice(-2)}
					</div>
					<div class="min-w-0 flex-1">
						<h2 class="truncate font-semibold text-foreground text-lg">
							{formatPhone(user?.phone)}
						</h2>
					</div>
					<div class="text-right">
						<div class="text-muted-foreground text-xs uppercase tracking-wide">
							Нийт захиалга
						</div>
						<div class="font-display text-foreground text-xl">{orders.length}</div>
					</div>
				</div>
			</div>

			{user?.address && (
				<div class="border-border border-t p-6">
					<div class="mb-1 text-muted-foreground text-xs uppercase tracking-wide">
						Хүргэлтийн хаяг
					</div>
					<div class="text-foreground text-sm leading-relaxed">{user.address}</div>
				</div>
			)}
		</div>

		<!-- Orders Section -->
		<section class="enter-rise stagger-2">
			<h2 class="mb-4 font-display text-foreground text-h3">Захиалгын түүх</h2>

			{orders.length === 0 ? (
				<div class="rounded-2xl border border-border bg-card px-6 py-12 text-center shadow-soft">
					<div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-full bg-wash-peach/70 text-foreground">
						<IconShoppingBag class="h-8 w-8" />
					</div>
					<h3 class="mb-2 font-display text-foreground text-lg">
						Захиалга олдсонгүй
					</h3>
					<p class="mb-6 text-muted-foreground text-sm">
						Та одоохондоо ямар ч захиалга хийгээгүй байна
					</p>
					<a
						href="/products"
						class="inline-flex min-h-11 items-center justify-center rounded-full bg-primary px-6 py-3 font-semibold text-foreground text-sm shadow-lift transition-[transform,box-shadow] duration-150 ease-out hover:-translate-y-0.5 hover:shadow-lift-lg active:scale-[0.97]"
					>
						Бүтээгдэхүүн үзэх
					</a>
				</div>
			) : (
				<div class="space-y-4">
					{orders.map((order, index) => (
						<article
							class={`enter-rise overflow-hidden rounded-2xl border border-border bg-card shadow-soft ${index < 8 ? `stagger-${Math.min(index + 2, 8)}` : ""}`}
						>
							<!-- Order header -->
							<div class="flex flex-wrap items-center justify-between gap-4 border-border border-b bg-muted/40 p-4">
								<div class="flex items-center gap-5">
									<div>
										<div class="mb-1 text-muted-foreground text-xs uppercase tracking-wide">
											Захиалга №
										</div>
										<div class="font-display text-base text-foreground">
											{order.orderNumber}
										</div>
									</div>
									<div>
										<div class="mb-1 text-muted-foreground text-xs uppercase tracking-wide">
											Огноо
										</div>
										<div class="font-medium text-foreground text-sm">
											{formatDate(order.createdAt)}
										</div>
									</div>
								</div>

								<div class="flex items-center gap-4">
									<span
										class={`rounded-full px-3 py-1 font-semibold text-xs ${statusColors[order.status]}`}
									>
										{statusLabels[order.status]}
									</span>
									<div class="text-right">
										<div class="mb-1 text-muted-foreground text-xs uppercase tracking-wide">
											Нийт дүн
										</div>
										<div class="font-display text-base text-foreground">
											{order.total.toLocaleString()}₮
										</div>
									</div>
								</div>
							</div>

							<!-- Order details -->
							<div class="p-4">
								<!-- Products -->
								<div class="mb-4 divide-y divide-border">
									{order.products.map((product) => (
										<div class="flex items-center gap-4 py-3 first:pt-0 last:pb-0">
											{product.imageUrl && (
												<img
													src={product.imageUrl}
													alt={product.name}
													class="h-14 w-14 rounded-xl bg-muted object-cover"
													loading="lazy"
												/>
											)}
											<div class="min-w-0 flex-1">
												<div class="truncate font-semibold text-foreground text-sm">
													{product.name}
												</div>
												<div class="text-muted-foreground text-xs">
													{product.brandName}
												</div>
											</div>
											<div class="flex-shrink-0 text-right">
												<div class="font-semibold text-foreground text-sm">
													{product.quantity}x
												</div>
												<div class="text-muted-foreground text-xs">
													{product.sellingPrice.toLocaleString()}₮
												</div>
											</div>
										</div>
									))}
								</div>

								<!-- Address -->
								<div class="rounded-xl bg-muted/50 p-3">
									<div class="mb-1 text-muted-foreground text-xs uppercase tracking-wide">
										Хүргэлтийн хаяг
									</div>
									<div class="text-foreground text-sm">{order.address}</div>
								</div>

								<!-- Notes -->
								{order.notes && (
									<div class="mt-2 rounded-xl bg-wash-lemon/50 p-3">
										<div class="mb-1 text-muted-foreground text-xs uppercase tracking-wide">
											Тэмдэглэл
										</div>
										<div class="text-foreground text-sm">{order.notes}</div>
									</div>
								)}
							</div>
						</article>
					))}
				</div>
			)}
		</section>
	</div>
</Layout>
