---
import Layout from "@/layouts/Layout.astro";
import IconLightbulb from "~icons/ri/lightbulb-line";
import IconRefresh from "~icons/ri/refresh-line";

export const prerender = true;

const title = "500 - Серверийн алдаа";
const description = "Системд түр зуурын алдаа гарлаа. Удахгүй засагдана.";
---

<Layout title={title} description={description} noindex>
    <div class="flex min-h-[75vh] items-center justify-center px-4 py-16">
        <div class="w-full max-w-md text-center">
            <div class="enter-rise relative mx-auto mb-6 inline-block">
                <span
                    aria-hidden="true"
                    class="absolute -top-4 -left-10 h-10 w-10 animate-float-1 rounded-full bg-wash-apricot md:-left-14 md:h-12 md:w-12"
                ></span>
                <span
                    aria-hidden="true"
                    class="absolute -bottom-2 -right-8 h-7 w-7 animate-float-3 rounded-full bg-wash-lilac md:-right-12"
                ></span>
                <h1 class="relative font-display text-[7rem] leading-none text-foreground md:text-[9rem]">
                    500
                </h1>
                <span
                    class="absolute -top-3 -right-6 inline-flex -rotate-2 animate-float-2 items-center rounded-full border-2 border-cocoa bg-card px-3 py-1 font-bold text-foreground text-xs shadow-pop-sm md:-right-10"
                >
                    Түр зуурын алдаа
                </span>
            </div>

            <h2 class="enter-rise stagger-1 mb-3 font-display text-foreground text-h3">
                Ямар нэг зүйл буруу боллоо
            </h2>
            <p class="enter-rise stagger-2 mx-auto mb-8 max-w-sm text-muted-foreground text-sm leading-relaxed md:text-base">
                Системд гэнэтийн алдаа гарлаа. Бид шууд засаж байгаа тул хэсэг хугацааны дараа дахин оролдоно уу.
            </p>

            <div class="enter-rise stagger-3 flex flex-col items-center gap-3 sm:flex-row sm:justify-center">
                <button
                    type="button"
                    onclick="location.reload()"
                    class="inline-flex min-h-12 items-center justify-center gap-2 rounded-full bg-primary px-8 py-3 font-semibold text-primary-foreground text-sm shadow-lift transition-[transform,box-shadow] duration-150 ease-out hover:-translate-y-0.5 hover:shadow-lift-lg active:scale-[0.97] md:text-base"
                >
                    <IconRefresh class="h-4 w-4" />
                    Дахин оролдох
                </button>
                <a
                    href="/"
                    class="inline-flex min-h-12 items-center justify-center rounded-full border border-border bg-card px-8 py-3 font-semibold text-foreground text-sm shadow-soft-sm transition-[transform,box-shadow,background-color] duration-150 ease-out hover:bg-muted hover:shadow-soft active:scale-[0.97] md:text-base"
                >
                    Нүүр хуудас руу
                </a>
            </div>

            <p class="enter-rise stagger-4 mt-8 inline-flex items-center gap-2 text-muted-foreground text-xs">
                <IconLightbulb class="h-4 w-4" />
                Зөвлөмж: Хуудсыг дахин ачааллаж үзэх эсвэл хэсэг хугацааны дараа эргэн ирээрэй.
            </p>
        </div>
    </div>
</Layout>
