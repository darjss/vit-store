---
import ProductQuantitySelector from "@/components/product/product-add-to-cart";
import { formatCurrency } from "@/lib/utils";
import IconBox from "~icons/ri/box-3-line";
import IconMuscle from "~icons/ri/boxing-line";
import IconCheck from "~icons/ri/checkbox-circle-fill";
import IconFlask from "~icons/ri/flask-line";
import IconPriceTag from "~icons/ri/price-tag-3-fill";
import IconRefund from "~icons/ri/refund-2-line";
import IconShield from "~icons/ri/shield-check-line";
import IconTruck from "~icons/ri/truck-line";

interface Props {
	product: {
		id: number;
		name: string;
		slug: string;
		price: number;
		brand: { name: string };
		category: { name: string };
		status: string;
		stock: number;
		amount?: string | null;
		potency?: string | null;
	};
	primaryImage: string;
}

const { product, primaryImage } = Astro.props;
const isInStock = product.status === "active" && product.stock > 0;
---

<div class="space-y-4 sm:space-y-6">
	<div
		transition:name={`product-brand-${product.id}`}
		class="inline-flex items-center gap-2 rounded-md border border-border bg-background px-3 py-1.5 sm:px-4 sm:py-2 font-bold text-xs sm:text-sm uppercase shadow-soft-sm"
	>
		<IconPriceTag class="w-4 h-4 text-amber-500" />
		<span>{product.brand.name}</span>
	</div>

	<h1
		transition:name={`product-name-${product.id}`}
		class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-extrabold leading-[1.05] tracking-tight uppercase"
	>
		{product.name}
	</h1>

	<div class="flex flex-wrap gap-2">
		<div
			class="flex items-center gap-2 rounded-md border border-border bg-muted px-3 py-1.5 text-xs sm:text-sm font-bold uppercase tracking-wide"
		>
			<IconBox class="w-4 h-4 text-blue-500" /> {product.category.name}
		</div>
		{
			product.amount && (
				<div class="flex items-center gap-2 rounded-md border border-border bg-muted px-3 py-1.5 text-xs sm:text-sm font-bold uppercase tracking-wide">
					<IconFlask class="w-4 h-4 text-purple-500" /> {product.amount}
				</div>
			)
		}
		{
			product.potency && (
				<div class="flex items-center gap-2 rounded-md border border-border bg-muted px-3 py-1.5 text-xs sm:text-sm font-bold uppercase tracking-wide">
					<IconMuscle class="w-4 h-4 text-green-500" /> {product.potency}
				</div>
			)
		}
	</div>

	<div class="rounded-lg border border-border bg-card p-4 shadow-soft sm:p-6">
		<div class="mb-4 flex items-end justify-between gap-3 border-b border-border pb-3">
			<div>
				<div class="text-xs font-bold text-muted-foreground uppercase tracking-wider">
					Үнэ
				</div>
				<div class="text-3xl sm:text-5xl font-extrabold text-foreground tracking-tight" transition:name={`product-price-${product.id}`}>
					{formatCurrency(product.price)}
				</div>
			</div>
			{!isInStock && (
				<div class="rounded-md border border-border px-3 py-1.5 text-[10px] font-bold uppercase tracking-wider bg-destructive text-destructive-foreground">
					Дууссан
				</div>
			)}
		</div>

		<div id="product-main-cta" transition:name={`product-add-to-cart-button-${product.id}`}>
			<ProductQuantitySelector
				client:only="solid-js"
				isInStock={isInStock}
				stock={product.stock}
				cartItem={{
					productId: product.id,
					quantity: 1,
					name: product.name,
					price: product.price,
					image: primaryImage,
					slug: product.slug,
				}}
			>
				<div slot="fallback" class="space-y-4">
					<div class="flex items-center gap-3">
						<div class="h-14 w-14 sm:h-16 sm:w-16 rounded-lg border border-border bg-muted/30 shadow-soft animate-pulse"></div>
						<div class="h-14 flex-1 rounded-lg border border-border bg-muted/30 shadow-soft animate-pulse"></div>
						<div class="h-14 w-14 sm:h-16 sm:w-16 rounded-lg border border-border bg-muted/30 shadow-soft animate-pulse"></div>
					</div>
					<div class="h-14 sm:h-16 w-full rounded-lg border border-border bg-muted/30 shadow-soft animate-pulse"></div>
				</div>
			</ProductQuantitySelector>
		</div>
	</div>

	<div class="rounded-lg border border-border bg-background p-4 sm:p-6 shadow-soft">
		<div class="grid grid-cols-2 gap-4">
			<div class="flex items-center gap-3 text-xs sm:text-sm font-bold text-foreground/80 uppercase tracking-wide">
				<IconCheck class="w-5 h-5 text-green-500" />
				<span>Баталгаатай</span>
			</div>
			<div class="flex items-center gap-3 text-xs sm:text-sm font-bold text-foreground/80 uppercase tracking-wide">
				<IconTruck class="w-5 h-5 text-blue-500" />
				<span>Хурдан хүргэлт</span>
			</div>
			<div class="flex items-center gap-3 text-xs sm:text-sm font-bold text-foreground/80 uppercase tracking-wide">
				<IconShield class="w-5 h-5 text-purple-500" />
				<span>Найдвартай</span>
			</div>
			<div class="flex items-center gap-3 text-xs sm:text-sm font-bold text-foreground/80 uppercase tracking-wide">
				<IconRefund class="w-5 h-5 text-orange-500" />
				<span>Буцаалт</span>
			</div>
		</div>
	</div>
</div>
