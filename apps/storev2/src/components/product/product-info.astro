---
import { LOW_STOCK_THRESHOLD } from "@vit/shared/domain/product";
import ProductQuantitySelector from "@/components/product/product-add-to-cart";
import { formatCurrency } from "@/lib/utils";
import IconCheck from "~icons/ri/checkbox-circle-fill";
import IconRefund from "~icons/ri/refund-2-line";
import IconShield from "~icons/ri/shield-check-line";
import IconTruck from "~icons/ri/truck-line";

interface Props {
	product: {
		id: number;
		name: string;
		slug: string;
		price: number;
		brand: { name: string };
		category: { name: string };
		status: string;
		stock: number;
		amount?: string | null;
		potency?: string | null;
	};
	primaryImage: string;
}

const { product, primaryImage } = Astro.props;
const isInStock = product.status === "active" && product.stock > 0;
---

<div class="space-y-4 sm:space-y-5">
	<div
		transition:name={`product-brand-${product.id}`}
		class="inline-flex items-center rounded-full border border-border bg-card px-3 py-1 text-xs font-semibold text-muted-foreground shadow-soft-sm"
	>
		{product.brand.name}
	</div>

	<h1
		transition:name={`product-name-${product.id}`}
		class="font-display text-2xl leading-[1.2] sm:text-3xl lg:text-4xl"
	>
		{product.name}
	</h1>

	<div class="flex flex-wrap gap-2">
		<span class="inline-flex items-center rounded-full bg-muted px-3 py-1 text-xs font-medium text-muted-foreground">
			{product.category.name}
		</span>
		{
			product.amount && (
				<span class="inline-flex items-center rounded-full bg-muted px-3 py-1 text-xs font-medium text-muted-foreground">
					{product.amount}
				</span>
			)
		}
		{
			product.potency && (
				<span class="inline-flex items-center rounded-full bg-muted px-3 py-1 text-xs font-medium text-muted-foreground">
					{product.potency}
				</span>
			)
		}
	</div>

	<div class="space-y-4 rounded-2xl border border-border bg-card p-4 shadow-soft sm:p-6">
		<div class="flex items-end justify-between gap-3">
			<div>
				<div class="text-[11px] font-semibold uppercase tracking-wider text-muted-foreground">
					Үнэ
				</div>
				<div
					class="font-display text-4xl text-foreground sm:text-5xl"
					data-inventory-price={product.id}
					transition:name={`product-price-${product.id}`}
				>
					{formatCurrency(product.price)}
				</div>
			</div>
			<span
				data-inventory-stock-badge={product.id}
				class="rounded-full bg-muted px-3 py-1.5 text-xs font-semibold text-muted-foreground"
			>
				{isInStock
					? product.stock <= LOW_STOCK_THRESHOLD
						? `Цөөхөн үлдсэн (${product.stock})`
						: "Бэлэн байна"
					: "Дууссан"}
			</span>
		</div>

		<div
			data-inventory-stock-meta={product.id}
			class:list={[
				"flex flex-wrap items-center gap-x-3 gap-y-1.5 text-xs text-muted-foreground sm:text-sm",
				{ hidden: !isInStock },
			]}
		>
				<span class="inline-flex items-center gap-1.5">
					<IconTruck class="h-4 w-4 text-cocoa/70" aria-hidden="true" />
					УБ-д өнөөдөр эсвэл маргааш хүргэнэ
				</span>
		</div>

		<div id="product-main-cta" transition:name={`product-add-to-cart-button-${product.id}`}>
			<ProductQuantitySelector
				client:only="solid-js"
				isInStock={isInStock}
				stock={product.stock}
				cartItem={{
					productId: product.id,
					quantity: 1,
					name: product.name,
					price: product.price,
					image: primaryImage,
					slug: product.slug,
				}}
			>
				<div slot="fallback" class="flex items-center gap-3">
					<div class="h-12 w-36 animate-pulse rounded-full border border-border bg-muted/30"></div>
					<div class="h-12 flex-1 animate-pulse rounded-full bg-muted/40"></div>
				</div>
			</ProductQuantitySelector>
		</div>
	</div>

	<div class="flex flex-wrap items-center gap-x-5 gap-y-2 px-1 text-xs text-muted-foreground sm:text-sm">
		<span class="inline-flex items-center gap-1.5">
			<IconCheck class="h-4 w-4 text-cocoa/70" aria-hidden="true" />
			Баталгаатай
		</span>
		<span class="inline-flex items-center gap-1.5">
			<IconTruck class="h-4 w-4 text-cocoa/70" aria-hidden="true" />
			Хурдан хүргэлт
		</span>
		<span class="inline-flex items-center gap-1.5">
			<IconShield class="h-4 w-4 text-cocoa/70" aria-hidden="true" />
			Найдвартай
		</span>
		<span class="inline-flex items-center gap-1.5">
			<IconRefund class="h-4 w-4 text-cocoa/70" aria-hidden="true" />
			Буцаалт
		</span>
	</div>
</div>
