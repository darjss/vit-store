---

import { productStockState } from "@vit/shared/domain/product";
import CardAddButton from "@/components/product/card-add-button.tsx";
import ProductImageFallback from "@/components/product/product-image-fallback.tsx";
import { toProductImageUrl } from "@/lib/image";
import type { ProductForHome } from "@/lib/types";
import { formatCurrency } from "@/lib/utils";
import { washBg } from "@/lib/wash";

interface Props {
	product: ProductForHome;
	aspectRatio?: string;
	imageSize?: "feature" | "card";
	class?: string;
}

const {
	product,
	aspectRatio = "aspect-4/5",
	imageSize = "feature",
	class: className = "",
} = Astro.props;

const wash = washBg(product.brand || product.id);
const productUrl = `/products/${product.slug}-${product.id}`;
const stockState = productStockState(product.stock);
const isOutOfStock = stockState === "out";
const isLowStock = stockState === "low";
---

<div
	class={`group hover:-translate-y-[3px] relative flex h-full min-w-0 flex-col overflow-hidden rounded-2xl border border-border bg-card shadow-soft transition-[transform,box-shadow] duration-200 ease-out hover:shadow-soft-lg ${className}`}
>
	<a href={productUrl} class="relative block" aria-hidden="true" tabindex="-1">
		<div
			class={`relative ${aspectRatio} ${wash} ${isOutOfStock ? "saturate-[0.35]" : ""}`}
			transition:name={`product-image-${product.id}`}
		>
			{product.image ? (
				<>
					<img
						src={toProductImageUrl(product.image, imageSize) || product.image}
						alt=""
						class={`absolute inset-0 h-full w-full object-contain p-3 transition-transform duration-300 ease-out-quart group-hover:scale-105 sm:p-4 ${isOutOfStock ? "opacity-70 grayscale" : ""}`}
						width="480"
						height="480"
						loading="lazy"
						decoding="async"
						onerror="this.style.display='none';this.parentElement.querySelector('[data-image-fallback]').hidden=false"
					/>
					<div data-image-fallback hidden>
						<ProductImageFallback name={product.name} brand={product.brand} />
					</div>
				</>
			) : (
				<ProductImageFallback name={product.name} brand={product.brand} />
			)}
			{product.discount && !isOutOfStock ? (
				<span class="-rotate-2 absolute top-2 left-2 inline-flex items-center rounded-full bg-sale px-2 py-0.5 font-semibold text-[11px] text-sale-foreground">
					-{product.discount}%
				</span>
			) : null}
			{isLowStock ? (
				<span class="absolute bottom-2 left-2 inline-flex items-center rounded-full bg-warning px-2 py-0.5 font-semibold text-[10px] text-warning-foreground">
					Цөөн үлдсэн
				</span>
			) : null}
			{isOutOfStock ? (
				<span class="absolute bottom-2 left-2 inline-flex items-center rounded-full border border-border bg-card px-2 py-0.5 font-semibold text-[10px] text-foreground">
					Дууссан
				</span>
			) : null}
		</div>
	</a>
	<div class="flex flex-1 flex-col gap-1 p-3">
		{product.brand ? (
			<p class="font-semibold text-[10px] text-muted-foreground uppercase tracking-wide">
				{product.brand}
			</p>
		) : null}
		<a href={productUrl} class="block">
			<h3 class="line-clamp-2 font-medium text-foreground text-sm leading-snug group-hover:underline">
				{product.name}
				{product.brand ? <span class="sr-only">, {product.brand}</span> : null}
			</h3>
		</a>
		<div class="mt-auto flex items-end justify-between gap-2 pt-2">
			<div class="font-bold font-display text-base tracking-tight">
				{formatCurrency(product.price)}
			</div>
			<CardAddButton
				client:load
				outOfStock={isOutOfStock}
				productName={product.name}
				cartItem={{
					productId: product.id,
					quantity: 1,
					name: product.name,
					price: product.price,
					image: product.image,
					slug: product.slug,
				}}
			/>
		</div>
	</div>
</div>
