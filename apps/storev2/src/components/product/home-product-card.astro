---



import type { ProductForHome } from "@/lib/types";
import ServerProductCard from "./server-product-card.astro";

interface Props {
	product: ProductForHome;
	aspectRatio?: string;
	imageSize?: "feature" | "card";
	class?: string;
}

const { product, aspectRatio, imageSize, class: className } = Astro.props;
---

<ServerProductCard
	product={{
		id: product.id,
		name: product.name,
		name_mn: product.nameMn,
		potency: product.potency,
		amount: product.amount,
		slug: product.slug,
		price: product.price,
		brand: product.brand ? { name: product.brand } : null,
		images: [{ url: product.image }],
		stock: product.stock,
		discount: product.discount,
	}}
	aspectRatio={aspectRatio}
	imageSize={imageSize}
	class={className}
/>
