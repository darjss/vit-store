---
import IconArrowDown from "~icons/ri/arrow-down-s-line";
import IconBarChart from "~icons/ri/bar-chart-line";
import IconCalendar from "~icons/ri/calendar-line";
import IconCapsule from "~icons/ri/capsule-line";
import IconCheck from "~icons/ri/check-line";
import IconFileText from "~icons/ri/file-text-line";
import IconStrong from "~icons/ri/heart-pulse-line";
import IconInfo from "~icons/ri/information-line";
import IconMoon from "~icons/ri/moon-line";
import IconScale from "~icons/ri/scales-line";
import IconSunrise from "~icons/ri/sun-line";
import IconTestTube from "~icons/ri/test-tube-line";

interface Props {
	product: {
		description?: string | null;
		ingredients?: string[] | null;
		dailyIntake?: number | null;
		weightGrams?: number | null;
		amount?: string | null;
		potency?: string | null;
		expirationDate?: string | null;
	};
}

const { product } = Astro.props;

const hasDescription = !!(
	product.description && product.description.trim().length > 0
);
const hasIngredients = Boolean(
	product.ingredients &&
	Array.isArray(product.ingredients) &&
	product.ingredients.length > 0
);
const hasSpecs = !!(
	product.dailyIntake ||
	product.weightGrams ||
	product.expirationDate ||
	product.amount ||
	product.potency
);
const expirationDisplay = product.expirationDate
	? (() => {
		const [year, month] = product.expirationDate.split("-");
		return year && month ? `${month}/${year}` : product.expirationDate;
	})()
	: null;

const specRows = [
	product.amount && { icon: IconScale, label: "Тоо ширхэг", value: product.amount },
	product.potency && { icon: IconStrong, label: "Идэвхтэй бодис", value: product.potency },
	product.dailyIntake && { icon: IconCalendar, label: "Өдрийн тун", value: `${product.dailyIntake} ширхэг` },
	product.weightGrams && { icon: IconScale, label: "Жин", value: `${product.weightGrams}г` },
	expirationDisplay && { icon: IconCalendar, label: "Дуусах хугацаа", value: expirationDisplay },
].filter(Boolean) as Array<{
	icon: typeof IconScale;
	label: string;
	value: string;
}>;
---

<div class="w-full space-y-6">
	<h2 class="font-display text-h3 sm:text-h2">Дэлгэрэнгүй мэдээлэл</h2>

	<div class="overflow-hidden rounded-2xl border border-border bg-card shadow-soft divide-y divide-border">
		{hasDescription && (
			<details name="product-details" class="group" open>
				<summary class="flex min-h-14 cursor-pointer select-none items-center gap-3 px-4 py-4 sm:px-6">
					<IconFileText class="h-5 w-5 shrink-0 text-cocoa/70" aria-hidden="true" />
					<span class="flex-1 font-semibold text-base">Тайлбар</span>
					<IconArrowDown class="h-5 w-5 shrink-0 text-muted-foreground transition-transform duration-200 ease-out group-open:rotate-180" aria-hidden="true" />
				</summary>
				<div class="acc-body px-4 pb-5 sm:px-6">
					<p class="whitespace-pre-line text-sm leading-relaxed text-foreground/80 sm:text-base">
						{product.description}
					</p>
				</div>
			</details>
		)}

		<details name="product-details" class="group" open={!hasDescription}>
			<summary class="flex min-h-14 cursor-pointer select-none items-center gap-3 px-4 py-4 sm:px-6">
				<IconCapsule class="h-5 w-5 shrink-0 text-cocoa/70" aria-hidden="true" />
				<span class="flex-1 font-semibold text-base">Хэрэглээ</span>
				<IconArrowDown class="h-5 w-5 shrink-0 text-muted-foreground transition-transform duration-200 ease-out group-open:rotate-180" aria-hidden="true" />
			</summary>
			<div class="acc-body space-y-5 px-4 pb-5 sm:px-6">
				<div>
					<h3 class="mb-1.5 font-semibold text-sm sm:text-base">Тун болон хэрэглэх арга</h3>
					{product.dailyIntake ? (
						<p class="text-sm leading-relaxed text-foreground/80 sm:text-base">
							Өдөрт <span class="font-semibold text-foreground">{product.dailyIntake}</span> ширхэг, хоолны дараа усаар хамт уух.
						</p>
					) : (
						<p class="text-sm leading-relaxed text-foreground/80 sm:text-base">
							Багцын заавар эсвэл эмчийн зааварчилгааг дагана уу
						</p>
					)}
				</div>

				<div>
					<h3 class="mb-2 font-semibold text-sm sm:text-base">Хэзээ уух вэ?</h3>
					<div class="space-y-2">
						<div class="flex items-center gap-3 text-sm text-foreground/80 sm:text-base">
							<IconSunrise class="h-4 w-4 shrink-0 text-cocoa/70" aria-hidden="true" />
							<span><span class="font-medium text-foreground">Өглөө</span> - өглөөний цайны дараа</span>
						</div>
						<div class="flex items-center gap-3 text-sm text-foreground/80 sm:text-base">
							<IconMoon class="h-4 w-4 shrink-0 text-cocoa/70" aria-hidden="true" />
							<span><span class="font-medium text-foreground">Орой</span> - оройн хоолны дараа</span>
						</div>
					</div>
				</div>

				<div class="rounded-xl bg-sand/40 p-4">
					<h4 class="mb-2 flex items-center gap-2 font-semibold text-sm">
						<IconInfo class="h-4 w-4 text-cocoa/80" aria-hidden="true" />
						Анхаарах зүйлс
					</h4>
					<ul class="space-y-1.5 text-xs leading-relaxed text-foreground/75 sm:text-sm">
						<li>Зааврын дагуу хэрэглэнэ үү</li>
						<li>Жирэмсэн, хөхүүл эх эмчтэй зөвлөлдөнө үү</li>
						<li>Хадгалах: Сэрүүн, хуурай газарт</li>
					</ul>
				</div>
			</div>
		</details>

		{hasIngredients && (
			<details name="product-details" class="group">
				<summary class="flex min-h-14 cursor-pointer select-none items-center gap-3 px-4 py-4 sm:px-6">
					<IconTestTube class="h-5 w-5 shrink-0 text-cocoa/70" aria-hidden="true" />
					<span class="flex-1 font-semibold text-base">Найрлага</span>
					<IconArrowDown class="h-5 w-5 shrink-0 text-muted-foreground transition-transform duration-200 ease-out group-open:rotate-180" aria-hidden="true" />
				</summary>
				<div class="acc-body px-4 pb-5 sm:px-6">
					<ul class="grid gap-x-6 gap-y-2 sm:grid-cols-2">
						{product.ingredients?.map((ingredient) => (
							<li class="flex items-center gap-2.5 text-sm text-foreground/80 sm:text-base">
								<IconCheck class="h-4 w-4 shrink-0 text-cocoa/70" aria-hidden="true" />
								<span>{ingredient}</span>
							</li>
						))}
					</ul>
				</div>
			</details>
		)}

		{hasSpecs && (
			<details name="product-details" class="group">
				<summary class="flex min-h-14 cursor-pointer select-none items-center gap-3 px-4 py-4 sm:px-6">
					<IconBarChart class="h-5 w-5 shrink-0 text-cocoa/70" aria-hidden="true" />
					<span class="flex-1 font-semibold text-base">Үзүүлэлт</span>
					<IconArrowDown class="h-5 w-5 shrink-0 text-muted-foreground transition-transform duration-200 ease-out group-open:rotate-180" aria-hidden="true" />
				</summary>
				<div class="acc-body px-4 pb-5 sm:px-6">
					<dl class="divide-y divide-border/70">
						{specRows.map(({ icon: Icon, label, value }) => (
							<div class="flex items-center justify-between gap-4 py-2.5 text-sm sm:text-base">
								<dt class="flex items-center gap-2 text-muted-foreground">
									<Icon class="h-4 w-4 shrink-0 text-cocoa/60" aria-hidden="true" />
									{label}
								</dt>
								<dd class="text-right font-semibold">{value}</dd>
							</div>
						))}
					</dl>
				</div>
			</details>
		)}
	</div>

	<!-- Medical note - quiet and informative, never an alarm -->
	<div class="flex items-start gap-2.5 rounded-xl bg-muted p-4">
		<IconInfo class="mt-0.5 h-4 w-4 shrink-0 text-cocoa/70" aria-hidden="true" />
		<p class="text-xs leading-relaxed text-muted-foreground sm:text-sm">
			Эмнэлгийн зөвлөгөө биш. Мэргэжлийн эмчид хандана уу.
		</p>
	</div>
</div>

<style>
	summary {
		list-style: none;
	}
	summary::-webkit-details-marker {
		display: none;
	}
	details[open] .acc-body {
		animation: acc-in 250ms var(--ease-out);
	}
	@keyframes acc-in {
		from {
			opacity: 0;
			transform: translateY(4px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}
	@media (prefers-reduced-motion: reduce) {
		details[open] .acc-body {
			animation: none;
		}
	}
</style>
