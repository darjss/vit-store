---















import IconArrowRight from "~icons/ri/arrow-right-s-line";
import IconHome from "~icons/ri/home-line";

interface BreadcrumbItem {
	label: string;
	href: string;
}

interface Props {
	items: BreadcrumbItem[];
}

const { items } = Astro.props;
// Get only category for mobile display
const categoryItem = items.length > 1 ? items[0] : null;
---

<nav aria-label="Навигацийн зам" class="mb-4 sm:mb-6">
	<!-- Mobile breadcrumb - Simplified -->
	<div class="flex sm:hidden items-center gap-2 text-xs">
		<a
			href="/"
			class="inline-flex items-center border-2 border-border bg-card px-2 py-1 hover:bg-primary transition-colors shadow-hard-sm active:shadow-none active:translate-x-px active:translate-y-px"
		>
			<IconHome class="h-4 w-4" />
		</a>
		<IconArrowRight class="h-5 w-5 font-black" aria-hidden="true" />
		{categoryItem && (
			<>
				<a
					href={categoryItem.href}
					class="inline-flex items-center border-2 border-border bg-card px-2 py-1 hover:bg-primary transition-colors shadow-hard-sm active:shadow-none active:translate-x-px active:translate-y-px font-bold truncate max-w-[120px]"
				>
					{categoryItem.label}
				</a>
			</>
		)}
	</div>

	<!-- Desktop breadcrumb - Full path -->
	<ol class="hidden sm:flex items-center gap-2 text-sm font-bold">
		<li>
			<a
				href="/"
				class="inline-flex items-center gap-1.5 border-2 border-border bg-card px-3 py-1.5 hover:bg-primary transition-colors shadow-hard-sm hover:shadow-none hover:translate-x-px hover:translate-y-px"
			>
				<IconHome class="h-4 w-4" /> Нүүр
			</a>
		</li>
		{
			items.map((item, index) => (
				<>
					<li aria-hidden="true">
						<IconArrowRight class="h-5 w-5" />
					</li>
					<li>
						{index === items.length - 1 ? (
							<span aria-current="page" class="inline-flex items-center gap-1.5 border-2 border-border bg-primary px-3 py-1.5 shadow-hard-sm font-black truncate max-w-[200px]">
								{item.label}
							</span>
						) : (
							<a
								href={item.href}
								class="inline-flex items-center gap-1.5 border-2 border-border bg-card px-3 py-1.5 hover:bg-primary transition-colors shadow-hard-sm hover:shadow-none hover:translate-x-px hover:translate-y-px"
							>
								{item.label}
							</a>
						)}
					</li>
				</>
			))
		}
	</ol>
</nav>
