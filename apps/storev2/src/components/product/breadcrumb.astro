---















import IconArrowRight from "~icons/ri/arrow-right-s-line";
import IconHome from "~icons/ri/home-line";

interface BreadcrumbItem {
	label: string;
	href: string;
}

interface Props {
	items: BreadcrumbItem[];
}

const { items } = Astro.props;
// Get only category for mobile display
const categoryItem = items.length > 1 ? items[0] : null;
---

<nav aria-label="Навигацийн зам" class="mb-4 sm:mb-6">
	<!-- Mobile breadcrumb - Simplified -->
	<div class="flex sm:hidden items-center gap-1.5 text-xs text-muted-foreground">
		<a
			href="/"
			class="inline-flex min-h-8 items-center transition-colors duration-150 hover:text-foreground"
			aria-label="Нүүр"
		>
			<IconHome class="h-4 w-4" />
		</a>
		<IconArrowRight class="h-4 w-4 text-muted-foreground/60" aria-hidden="true" />
		{categoryItem && (
			<a
				href={categoryItem.href}
				class="inline-flex min-h-8 max-w-[160px] items-center truncate font-medium transition-colors duration-150 hover:text-foreground"
			>
				{categoryItem.label}
			</a>
		)}
	</div>

	<!-- Desktop breadcrumb - Full path -->
	<ol class="hidden sm:flex items-center gap-1.5 text-sm text-muted-foreground">
		<li>
			<a
				href="/"
				class="inline-flex items-center gap-1.5 transition-colors duration-150 hover:text-foreground"
			>
				<IconHome class="h-4 w-4" /> Нүүр
			</a>
		</li>
		{
			items.map((item, index) => (
				<>
					<li aria-hidden="true">
						<IconArrowRight class="h-4 w-4 text-muted-foreground/60" />
					</li>
					<li>
						{index === items.length - 1 ? (
							<span aria-current="page" class="inline-block max-w-[240px] truncate align-middle font-medium text-foreground">
								{item.label}
							</span>
						) : (
							<a
								href={item.href}
								class="transition-colors duration-150 hover:text-foreground"
							>
								{item.label}
							</a>
						)}
					</li>
				</>
			))
		}
	</ol>
</nav>
