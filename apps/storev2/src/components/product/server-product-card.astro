---



import { formatCurrency } from "@vit/shared";
import { productStockState, projectProductCardDisplay } from "@vit/shared/domain/product";
import CardAddButton from "@/components/product/card-add-button.tsx";
import ProductImageFallback from "@/components/product/product-image-fallback.tsx";
import { toProductImageUrl } from "@/lib/image";
import { washBg } from "@/lib/wash";
import { unverifiedInventoryCardPresentation } from "./inventory-card-state";

interface Props {
	product: {
		id: number;
		name: string;
		name_mn?: string | null;
		potency?: string | null;
		amount?: string | null;
		slug: string;
		price: number;
		brand: { name: string } | null;
		images: { url: string | null }[];
		stock?: number;
		discount?: number | null;
		categoryId?: number;
	};
	aspectRatio?: string;
	imageSize?: "feature" | "card";
	class?: string;
}

const {
	product,
	aspectRatio = "aspect-4/5",
	imageSize = "card",
	class: className = "",
} = Astro.props;
const washClass = washBg(product.categoryId ?? "uncategorized");
const imageUrl = product.images[0]?.url || "";
const productUrl = `/products/${product.slug}-${product.id}`;
const isOutOfStock = productStockState(product.stock) === "out";
const initialInventory = unverifiedInventoryCardPresentation("checking");
const hasSale = (product.discount ?? 0) > 0;
const display = projectProductCardDisplay({
	name: product.name,
	nameMn: product.name_mn,
	brand: product.brand?.name,
	potency: product.potency,
	amount: product.amount,
});
---

<div
	class={`group @container hover:-translate-y-[3px] relative flex h-full min-w-0 flex-col overflow-hidden rounded-2xl border border-border bg-card shadow-soft transition-[transform,box-shadow] duration-200 ease-out hover:shadow-soft-lg ${className}`}
	data-product-id={product.id}
	data-server-product-card={product.id}
	data-inventory-state={initialInventory.state}
>
	<div class="relative block" aria-hidden="true">
		<div
			class={`relative ${aspectRatio} ${washClass}`}
			data-card-image-frame
			transition:name={`product-image-${product.id}`}
		>
			{imageUrl ? (
				<>
					<img
						src={toProductImageUrl(imageUrl, imageSize) || imageUrl}
						alt=""
						width="400"
						height="500"
						loading="lazy"
						decoding="async"
						class="absolute inset-0 h-full w-full object-contain p-3 transition-[transform,filter,opacity] duration-300 ease-out-quart group-hover:scale-105 sm:p-4"
						data-card-image
						onerror="this.style.display='none';this.parentElement.querySelector('[data-image-fallback]').hidden=false"
					/>
					<div data-image-fallback hidden>
						<ProductImageFallback name={product.name} brand={product.brand?.name ?? null} />
					</div>
				</>
			) : (
				<ProductImageFallback name={product.name} brand={product.brand?.name ?? null} />
			)}
		</div>
	</div>
	{hasSale && (
		<span
			class="-rotate-2 absolute top-2 left-2 inline-flex items-center rounded-full bg-sale px-2 py-0.5 font-semibold text-[11px] text-sale-foreground"
			data-card-sale
			aria-label={`Хямдрал ${product.discount} хувь`}
		>
			-{product.discount}%
		</span>
	)}

	<div class="flex flex-1 flex-col gap-1 p-3">
		{product.brand && (
			<p class="font-semibold text-[10px] text-muted-foreground uppercase tracking-wide">
				{product.brand.name}
			</p>
		)}
		<a
			href={productUrl}
			class="block rounded-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
			aria-label={`${display.accessibleName}, ${formatCurrency(product.price)}`}
		>
			<h3 class="line-clamp-2 font-semibold text-foreground text-sm leading-snug group-hover:underline">
				{display.shortName}
			</h3>
		</a>
		{display.dose && (
			<p class="line-clamp-2 font-semibold text-[11px] text-foreground/80 leading-snug">{display.dose}</p>
		)}
		{(display.form || display.count || display.packageQuantity) && (
			<p class="text-[11px] text-muted-foreground leading-snug">
				{[display.form, display.count, display.packageQuantity].filter(Boolean).join(" · ")}
			</p>
		)}
		<p data-card-stock class="font-semibold text-[11px]">
			{initialInventory.availabilityLabel}
		</p>

		<div class="mt-auto grid min-w-0 grid-cols-[minmax(0,1fr)_44px] items-end gap-2 pt-2">
			<div class="min-w-0 font-bold text-sm leading-tight tracking-tight [overflow-wrap:anywhere] sm:text-base" data-inventory-price={product.id}>
				{formatCurrency(product.price)}
			</div>
			<CardAddButton
				client:load
				outOfStock={isOutOfStock}
				productName={display.shortName}
				cartItem={{
					productId: product.id,
					quantity: 1,
					name: product.name,
					price: product.price,
					image: imageUrl || "",
					slug: product.slug,
				}}
			/>
		</div>
	</div>
</div>

<style>
	[data-server-product-card][data-inventory-state="checking"] [data-card-image-frame],
	[data-server-product-card][data-inventory-state="degraded"] [data-card-image-frame] {
		filter: saturate(0.55);
	}
	[data-server-product-card][data-inventory-state="checking"] [data-card-image],
	[data-server-product-card][data-inventory-state="degraded"] [data-card-image] {
		opacity: 0.72;
	}
	[data-server-product-card][data-inventory-state="degraded"] [data-card-image] {
		filter: grayscale(0.55);
	}
	[data-server-product-card][data-inventory-state="checking"] [data-card-stock] {
		color: var(--color-muted-foreground);
	}
	[data-server-product-card][data-inventory-state="degraded"] [data-card-stock] {
		color: var(--color-destructive);
	}
	[data-server-product-card][data-inventory-state="out"] [data-card-image-frame] {
		filter: saturate(0.35);
	}
	[data-server-product-card][data-inventory-state="out"] [data-card-image] {
		filter: grayscale(1);
		opacity: 0.7;
	}
	[data-server-product-card][data-inventory-state="out"] [data-card-stock] {
		color: var(--color-destructive);
	}
	[data-server-product-card]:is(
		[data-inventory-state="checking"],
		[data-inventory-state="degraded"],
		[data-inventory-state="out"]
	) [data-card-sale] {
		display: none;
	}
	[data-server-product-card][data-inventory-state="low"] [data-card-stock] {
		color: var(--color-warning-foreground);
	}
	[data-server-product-card][data-inventory-state="in"] [data-card-stock] {
		color: var(--color-success-foreground);
	}
</style>
