---
import { formatCurrency } from "@vit/shared";
import { productStockState } from "@vit/shared/domain/product";
import CardAddButton from "@/components/product/card-add-button.tsx";
import ProductImageFallback from "@/components/product/product-image-fallback.tsx";
import { toProductImageUrl } from "@/lib/image";
import { washBg } from "@/lib/wash";

interface Props {
	product: {
		id: number;
		name: string;
		slug: string;
		price: number;
		brand: { name: string } | null;
		images: { url: string | null }[];
		stock?: number;
		discount?: number;
		categoryId?: number;
	};
}

const { product } = Astro.props;
const washClass = washBg(product.categoryId ?? "uncategorized");
const imageUrl = product.images[0]?.url || "";
const productUrl = `/products/${product.slug}-${product.id}`;
const stockState = productStockState(product.stock);
const isOutOfStock = stockState === "out";
const isLowStock = stockState === "low";
const hasSale = (product.discount ?? 0) > 0;
---

<div
	class="group hover:-translate-y-[3px] relative flex h-full flex-col overflow-hidden rounded-2xl border border-border bg-card shadow-soft transition-[transform,box-shadow] duration-200 ease-out hover:shadow-soft-lg"
	data-product-id={product.id}
>
	<a href={productUrl} class="relative block" aria-hidden="true" tabindex="-1">
		<div
			class={`relative aspect-4/5 ${washClass} ${isOutOfStock ? "saturate-[0.35]" : ""}`}
			transition:name={`product-image-${product.id}`}
		>
			{imageUrl ? (
				<>
					<img
						src={toProductImageUrl(imageUrl, "card") || imageUrl}
						alt={product.name}
						width="400"
						height="500"
						loading="lazy"
						decoding="async"
						class={`absolute inset-0 h-full w-full object-contain p-3 transition-transform duration-300 ease-out-quart group-hover:scale-105 sm:p-4 ${isOutOfStock ? "opacity-70 grayscale" : ""}`}
						onerror="this.style.display='none';this.parentElement.querySelector('[data-image-fallback]').hidden=false"
					/>
					<div data-image-fallback hidden>
						<ProductImageFallback name={product.name} brand={product.brand?.name ?? null} />
					</div>
				</>
			) : (
				<ProductImageFallback name={product.name} brand={product.brand?.name ?? null} />
			)}
			{hasSale && !isOutOfStock && (
				<span class="-rotate-2 absolute top-2 left-2 inline-flex items-center rounded-full bg-sale px-2 py-0.5 font-semibold text-[11px] text-sale-foreground">
					-{product.discount}%
				</span>
			)}
			<span data-inventory-stock-low={product.id} hidden={!isLowStock} class="absolute bottom-2 left-2 inline-flex items-center rounded-full bg-warning px-2 py-0.5 font-semibold text-[10px] text-warning-foreground">
					Цөөн үлдсэн
				</span>
			<span data-inventory-stock-out={product.id} hidden={!isOutOfStock} class="absolute bottom-2 left-2 inline-flex items-center rounded-full border border-border bg-card px-2 py-0.5 font-semibold text-[10px] text-foreground">
					Дууссан
				</span>
		</div>
	</a>

	<div class="flex flex-1 flex-col gap-1 p-3">
		{product.brand && (
			<p class="font-semibold text-[10px] text-muted-foreground uppercase tracking-wide">
				{product.brand.name}
			</p>
		)}
		<a href={productUrl} class="block">
			<h3 class="line-clamp-2 font-medium text-foreground text-sm leading-snug group-hover:underline">
				{product.name}
				{product.brand ? <span class="sr-only">, {product.brand.name}</span> : null}
			</h3>
		</a>

		<div class="mt-auto flex items-end justify-between gap-2 pt-2">
			<div class="font-bold font-display text-base tracking-tight" data-inventory-price={product.id}>
				{formatCurrency(product.price)}
			</div>
			<CardAddButton
				client:load
				outOfStock={isOutOfStock}
				productName={product.name}
				cartItem={{
					productId: product.id,
					quantity: 1,
					name: product.name,
					price: product.price,
					image: imageUrl || "",
					slug: product.slug,
				}}
			/>
		</div>
	</div>
</div>
