---
import { formatCurrency, productColors } from "@vit/shared";
import { toProductImageUrl } from "@/lib/image";
import AddToCartButton from "@/components/cart/add-to-cart-button";
import ProductImageFallback from "@/components/product/product-image-fallback.tsx";

interface Props {
	product: {
		id: number;
		name: string;
		slug: string;
		price: number;
		brand: { name: string } | null;
		images: { url: string }[];
	};
}

const { product } = Astro.props;
const bgColor = productColors[product.id % productColors.length];
const imageUrl = product.images[0]?.url || "";
const productUrl = `/products/${product.slug}-${product.id}`;
---

<div
	class="group hover:-translate-y-0.5 relative flex flex-col border border-border bg-card shadow-soft transition-all duration-200 hover:shadow-soft-lg sm:border sm:shadow-soft-lg sm:hover:shadow-soft-lg"
	data-product-id={product.id}
>
	<a
		href={productUrl}
		class="relative block overflow-hidden border-border border-b sm:border-b-3"
		aria-hidden="true"
		tabindex="-1"
	>
		<div
			class="relative aspect-4/5"
			style={`background: ${bgColor}`}
			transition:name={`product-image-${product.id}`}
		>
			<div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_20%,rgba(0,0,0,0.07)_2px,transparent_0)] bg-size-[14px_14px]" />
			{imageUrl ? (
				<img
					src={toProductImageUrl(imageUrl, "card") || imageUrl}
					alt={product.name}
					width="400"
					height="500"
					loading="lazy"
					decoding="async"
					class="absolute inset-0 h-full w-full object-contain p-3 transition-transform duration-300 group-hover:scale-105 sm:p-4"
				/>
			) : (
				<ProductImageFallback name={product.name} brand={product.brand?.name ?? null} />
			)}
			{product.brand && (
				<div class="absolute right-1.5 bottom-1.5 border border-border bg-card px-1.5 py-0.5 font-extrabold text-[11px] uppercase tracking-tight shadow-soft-sm sm:right-3 sm:bottom-3 sm:px-2.5 sm:py-1 sm:text-[11px]">
					{product.brand.name}
				</div>
			)}
		</div>
	</a>

	<div class="flex flex-1 flex-col p-2 sm:p-3">
		<a href={productUrl} class="block">
			<h3 class="line-clamp-2 font-bold text-[11px] leading-tight tracking-tight group-hover:underline sm:text-sm sm:leading-snug">
				{product.name}
				{product.brand ? <span class="sr-only">, {product.brand.name}</span> : null}
			</h3>
		</a>
	</div>

	<div class="flex items-center justify-between gap-2 border-border border-t bg-primary/10 px-3 py-2.5 sm:gap-3 sm:border-t sm:px-4 sm:py-3">
		<div class="font-extrabold text-sm tracking-tight sm:text-lg">
			{formatCurrency(product.price)}
		</div>
		<AddToCartButton
			client:load
			compact
			cartItem={{
				productId: product.id,
				quantity: 1,
				name: product.name,
				price: product.price,
				image: imageUrl || "",
				slug: product.slug,
			}}
		/>
	</div>
</div>
