import type { HTMLAttributes } from "astro/types";
import { tv } from "tailwind-variants";

interface Props extends Omit<HTMLAttributes<"button">, "type" | "id" | "role"> {
  value: string;
}

export const tabsTrigger = tv({
  base: [
    "inline-flex grow items-center justify-center gap-2 rounded-full px-4 py-2 font-semibold whitespace-nowrap transition-[background-color,color,box-shadow] duration-150 ease-out text-sm",
    "data-[state=active]:bg-card data-[state=active]:text-foreground data-[state=active]:shadow-soft-sm",
    "data-[state=inactive]:text-muted-foreground",
    "hover:text-foreground",
    "[&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4",
    "focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:outline-none",
    "disabled:pointer-events-none disabled:opacity-50",
  ],
});

const { value, class: className, ...rest } = Astro.props;
---

<button
  class={tabsTrigger({ class: className })}
  data-slot="tabs-trigger"
  data-tabs-trigger
  data-value={value}
  data-state="inactive"
  role="tab"
  aria-selected="false"
  {...rest}
>
  <slot />
</button>
