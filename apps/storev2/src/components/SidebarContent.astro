---
import SidebarUserSection from "@/components/auth/SidebarUserSection.astro";
import { getBrandLogoUrl } from "@/lib/image";
import { getStaticNavigationData } from "@/lib/static-navigation";
import IconArrowRight from "~icons/ri/arrow-right-s-line";
import IconGrid from "~icons/ri/grid-line";
import IconHome from "~icons/ri/home-4-line";
import IconCart from "~icons/ri/shopping-cart-2-line";
import IconUser from "~icons/ri/user-line";

const { categories, brands } = await getStaticNavigationData();
// Defensive filter: the brand query already enforces `having count > 0`, but a
// stale KV cache can still serve 0-product brands. Drop them at the nav level so
// the mobile menu never lists dead-end brand pages.
const navBrands = brands.filter((brand) => (brand.productCount ?? 0) > 0);
const topBrands = navBrands.slice(0, 6);
const remainingBrands = navBrands.slice(6);
const topCategories = categories.slice(0, 6);
const remainingCategories = categories.slice(6);

// Inline onerror handler: if a brand logo <img> fails to load at runtime
// (e.g. a non-image URL that passed the pre-check), swap it for the same
// brand-initial monogram used for missing logos. Self-contained — no sibling
// DOM needed. See GitHub issue #11.
const brandLogoOnError =
	"this.outerHTML='<div class=&quot;w-11 h-11 shrink-0 bg-muted border border-border flex items-center justify-center text-sm font-extrabold&quot;>'+this.alt.substring(0,2).toUpperCase()+'</div>';this.onerror=null";
---

<div class="flex flex-col h-full bg-background">
    <!-- User Section at Top - Most Important -->
    <div class="p-4 pr-20 bg-secondary text-secondary-foreground relative">
        <SidebarUserSection server:defer>
            <div slot="fallback" class="h-12 bg-secondary-foreground/10 animate-pulse"></div>
        </SidebarUserSection>
    </div>

    <!-- Main Scrollable Area -->
    <div class="flex-1 overflow-y-auto bg-dots-subtle">
        <!-- Quick Actions -->
        <div class="p-4 grid grid-cols-2 gap-3">
            <a 
                href="/" 
                class="flex flex-col items-center justify-center gap-2 p-4 bg-primary border border-border shadow-soft-sm hover:shadow-none hover:translate-x-[2px] hover:translate-y-[2px] transition-all active:bg-primary/80"
            >
                <IconHome class="w-6 h-6" />
                <span class="font-extrabold text-xs uppercase tracking-wide">Нүүр</span>
            </a>
            
            <a 
                href="/products" 
                class="flex flex-col items-center justify-center gap-2 p-4 bg-background border border-border shadow-soft-sm hover:shadow-none hover:translate-x-[2px] hover:translate-y-[2px] transition-all active:bg-muted"
            >
                <IconGrid class="w-6 h-6" />
                <span class="font-extrabold text-xs uppercase tracking-wide">Бүтээгдэхүүн</span>
            </a>
            
            <a 
                href="/cart" 
                class="flex flex-col items-center justify-center gap-2 p-4 bg-background border border-border shadow-soft-sm hover:shadow-none hover:translate-x-[2px] hover:translate-y-[2px] transition-all active:bg-muted"
            >
                <IconCart class="w-6 h-6" />
                <span class="font-extrabold text-xs uppercase tracking-wide">Сагс</span>
            </a>
            
            <a 
                href="/profile" 
                class="flex flex-col items-center justify-center gap-2 p-4 bg-background border border-border shadow-soft-sm hover:shadow-none hover:translate-x-[2px] hover:translate-y-[2px] transition-all active:bg-muted"
            >
                <IconUser class="w-6 h-6" />
                <span class="font-extrabold text-xs uppercase tracking-wide">Профайл</span>
            </a>
        </div>

        <!-- Brands - Logo Grid -->
        <div class="px-4 pb-4">
            <h3 class="font-extrabold text-xs uppercase tracking-wider text-muted-foreground mb-3 flex items-center gap-2">
                <span class="w-1.5 h-4 bg-accent"></span>
                Брэндүүд
            </h3>
            {navBrands.length > 0 ? (
                <>
                    <div class="grid grid-cols-3 gap-2">
                        {topBrands.map((brand: { id: number; name: string; slug: string; logoUrl?: string | null; productCount?: number }) => {
                            const logoUrl = getBrandLogoUrl(brand.logoUrl);
                            return (
                            <a
                                href={`/products/brand/${brand.slug}/1/`}
                                class="flex aspect-square items-center justify-center p-3 bg-background border border-border shadow-soft-sm hover:shadow-none hover:translate-x-[2px] hover:translate-y-[2px] hover:bg-muted transition-all group"
                                title={brand.name}
                            >
                                {logoUrl ? (
                                    <img
                                        src={logoUrl}
                                        alt={brand.name}
                                        class="max-h-full max-w-full object-contain group-hover:scale-110 transition-transform"
                                        loading="lazy"
                                        onerror={brandLogoOnError}
                                    />
                                ) : (
                                    <div class="w-full h-full bg-muted border border-border flex items-center justify-center text-sm font-extrabold group-hover:bg-primary transition-colors">
                                        {brand.name.substring(0, 2).toUpperCase()}
                                    </div>
                                )}
                            </a>
                            );
                        })}
                    </div>
                    {remainingBrands.length > 0 && (
                        <details class="mt-3 group">
                            <summary class="list-none flex items-center justify-center gap-2 w-full p-3 bg-muted border border-border font-bold text-sm hover:bg-primary transition-colors cursor-pointer select-none">
                                <span>Илүү харах</span>
                                <IconArrowRight class="w-4 h-4 transition-transform group-open:rotate-90" />
                            </summary>
                            <div class="mt-2 grid grid-cols-3 gap-2">
                                {remainingBrands.map((brand: { id: number; name: string; slug: string; logoUrl?: string | null; productCount?: number }) => {
                                    const logoUrl = getBrandLogoUrl(brand.logoUrl);
                                    return (
                                    <a
                                        href={`/products/brand/${brand.slug}/1/`}
                                        class="flex aspect-square items-center justify-center p-3 bg-background border border-border shadow-soft-sm hover:shadow-none hover:translate-x-[2px] hover:translate-y-[2px] hover:bg-muted transition-all group"
                                        title={brand.name}
                                    >
                                        {logoUrl ? (
                                            <img
                                                src={logoUrl}
                                                alt={brand.name}
                                                class="max-h-full max-w-full object-contain group-hover:scale-110 transition-transform"
                                                loading="lazy"
                                                onerror={brandLogoOnError}
                                            />
                                        ) : (
                                            <div class="w-full h-full bg-muted border border-border flex items-center justify-center text-sm font-extrabold group-hover:bg-primary transition-colors">
                                                {brand.name.substring(0, 2).toUpperCase()}
                                            </div>
                                        )}
                                    </a>
                                    );
                                })}
                            </div>
                        </details>
                    )}
                </>
            ) : (
                <div class="text-center py-8 text-muted-foreground">
                    <p class="text-sm font-medium">Брэнд олдсонгүй</p>
                </div>
            )}
        </div>

        <!-- Categories -->
        <div class="px-4 pb-4">
            <h3 class="font-extrabold text-xs uppercase tracking-wider text-muted-foreground mb-3 flex items-center gap-2">
                <span class="w-1.5 h-4 bg-primary"></span>
                Ангилал
            </h3>
            <div class="grid grid-cols-2 gap-2">
                {topCategories.map((category: { id: number; name: string; slug: string }) => (
                    <a
                        href={`/products/category/${category.slug}/1/`}
                        class="flex min-h-[60px] items-center justify-center px-3 py-2.5 bg-background border border-border font-extrabold text-xs leading-tight shadow-soft-sm hover:shadow-none hover:translate-x-[2px] hover:translate-y-[2px] hover:bg-primary transition-all text-center uppercase"
                    >
                        <span class="line-clamp-2">{category.name}</span>
                    </a>
                ))}
            </div>
            {remainingCategories.length > 0 && (
                <details class="mt-3 group">
                    <summary class="list-none flex items-center justify-center gap-2 w-full p-3 bg-muted border border-border font-bold text-sm hover:bg-primary transition-colors cursor-pointer select-none">
                        <span>Илүү харах</span>
                        <IconArrowRight class="w-4 h-4 transition-transform group-open:rotate-90" />
                    </summary>
                    <div class="mt-2 grid grid-cols-2 gap-2">
                        {remainingCategories.map((category: { id: number; name: string; slug: string }) => (
                            <a
                                href={`/products/category/${category.slug}/1/`}
                                class="flex min-h-[60px] items-center justify-center px-3 py-2.5 bg-background border border-border font-extrabold text-xs leading-tight shadow-soft-sm hover:shadow-none hover:translate-x-[2px] hover:translate-y-[2px] hover:bg-primary transition-all text-center uppercase"
                            >
                                <span class="line-clamp-2">{category.name}</span>
                            </a>
                        ))}
                    </div>
                </details>
            )}
        </div>

        <div class="px-4 pb-4">
            <h3 class="font-extrabold text-xs uppercase tracking-wider text-muted-foreground mb-3 flex items-center gap-2">
                <span class="w-1.5 h-4 bg-primary"></span>
                Онцлох хэсэг
            </h3>
            <div class="grid grid-cols-2 gap-2">
                <a
                    href="/products?filter=featured"
                    class="flex items-center justify-center p-2.5 bg-background border border-border text-[11px] font-bold uppercase tracking-wide shadow-soft-sm hover:shadow-none hover:translate-x-[2px] hover:translate-y-[2px] hover:bg-primary transition-all"
                >
                    Онцлох
                </a>
                <a
                    href="/products?filter=recent"
                    class="flex items-center justify-center p-2.5 bg-background border border-border text-[11px] font-bold uppercase tracking-wide shadow-soft-sm hover:shadow-none hover:translate-x-[2px] hover:translate-y-[2px] hover:bg-primary transition-all"
                >
                    Шинэ
                </a>
            </div>
        </div>
    </div>

    <!-- Bottom Branding -->
    <div class="p-4 border-t border-border bg-muted/50">
        <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-primary border border-border flex items-center justify-center font-extrabold text-xs uppercase tracking-wider shadow-soft-sm">
                AV
            </div>
            <div>
                <span class="font-extrabold text-sm block uppercase tracking-wider">Amerik Vitamin</span>
                <span class="text-[10px] text-muted-foreground font-medium">Баталгаатай импорт</span>
            </div>
        </div>
    </div>
</div>

<script>
  // Close sidebar when navigation links are clicked
  // Use event delegation to handle dynamically added links
  function setupSidebarNavigation() {
    interface SidebarNavigationContainer extends HTMLElement {
      __sidebarNavSetup?: boolean;
      __sidebarNavHandler?: EventListener;
    }

    // Find the sidebar container - look for the dialog wrapper
    const sidebarContainer = document.querySelector(
      '.starwind-dialog',
    ) as SidebarNavigationContainer | null;
    if (!sidebarContainer) return;

    // Remove existing listener if any (using a data attribute to track)
    if (sidebarContainer.__sidebarNavSetup && sidebarContainer.__sidebarNavHandler) {
      sidebarContainer.removeEventListener('click', sidebarContainer.__sidebarNavHandler);
    }

    // Create a single event handler using event delegation
    const handleLinkClick = (e: Event) => {
      const target = e.target as HTMLElement;
      const link = target.closest('a[href]') as HTMLAnchorElement;
      
      if (link && sidebarContainer.contains(link)) {
        // Find the close button and click it to trigger proper close animation
        const closeButton = sidebarContainer.querySelector('[data-slot="sheet-close"], .starwind-dialog-close') as HTMLButtonElement;
        if (closeButton) {
          // Use a small delay to ensure the click is processed
          setTimeout(() => {
            closeButton.click();
          }, 10);
        }
      }
    };

    // Store handler reference for cleanup
    sidebarContainer.__sidebarNavHandler = handleLinkClick;
    sidebarContainer.__sidebarNavSetup = true;

    sidebarContainer.addEventListener('click', handleLinkClick);
  }

  // Setup on page load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupSidebarNavigation);
  } else {
    setupSidebarNavigation();
  }

  // Setup after Astro navigation (for View Transitions)
  document.addEventListener('astro:after-swap', setupSidebarNavigation);
</script>
