---
import SidebarUserSection from "@/components/auth/SidebarUserSection.astro";
import { getBrandLogoUrl } from "@/lib/image";
import { getStaticNavigationData } from "@/lib/static-navigation";
import IconArrowDown from "~icons/ri/arrow-down-s-line";
import IconGrid from "~icons/ri/grid-line";
import IconHome from "~icons/ri/home-4-line";
import IconCart from "~icons/ri/shopping-cart-2-line";
import IconUser from "~icons/ri/user-line";

const { categories, brands } = await getStaticNavigationData();
// Defensive filter: the brand query already enforces `having count > 0`, but a
// stale KV cache can still serve 0-product brands. Drop them at the nav level so
// the mobile menu never lists dead-end brand pages.
const navBrands = brands.filter((brand) => (brand.productCount ?? 0) > 0);
const topBrands = navBrands.slice(0, 6);
const remainingBrands = navBrands.slice(6);
const topCategories = categories.slice(0, 6);
const remainingCategories = categories.slice(6);

// Inline onerror handler: if a brand logo <img> fails to load at runtime
// (e.g. a non-image URL that passed the pre-check), swap it for the same
// brand-initial monogram used for missing logos. Self-contained — no sibling
// DOM needed. See GitHub issue #11.
const brandLogoOnError =
	"this.outerHTML='<div class=&quot;w-11 h-11 shrink-0 bg-muted rounded-lg flex items-center justify-center text-sm font-semibold&quot;>'+this.alt.substring(0,2).toUpperCase()+'</div>';this.onerror=null";
---

<div class="flex flex-col h-full bg-background">
    <!-- User Section at Top - Most Important -->
    <div class="border-border border-b bg-wash-lemon/70 p-4 pr-20 relative">
        <SidebarUserSection server:defer>
            <div slot="fallback" class="h-12 animate-pulse rounded-xl bg-foreground/5"></div>
        </SidebarUserSection>
    </div>

    <!-- Main Scrollable Area -->
    <div class="flex-1 overflow-y-auto">
        <!-- Quick Actions -->
        <div class="grid grid-cols-2 gap-3 p-4">
            <a
                href="/"
                class="flex flex-col items-center justify-center gap-2 rounded-xl bg-primary p-4 text-primary-foreground shadow-soft-sm transition-[transform,box-shadow] duration-150 ease-out hover:-translate-y-0.5 hover:shadow-soft active:scale-[0.97]"
            >
                <IconHome class="w-6 h-6" />
                <span class="font-semibold text-xs">Нүүр</span>
            </a>

            <a
                href="/products"
                class="flex flex-col items-center justify-center gap-2 rounded-xl border border-border bg-card p-4 text-foreground shadow-soft-sm transition-[transform,box-shadow,background-color] duration-150 ease-out hover:-translate-y-0.5 hover:bg-muted hover:shadow-soft active:scale-[0.97]"
            >
                <IconGrid class="w-6 h-6" />
                <span class="font-semibold text-xs">Бүтээгдэхүүн</span>
            </a>

            <a
                href="/cart"
                class="flex flex-col items-center justify-center gap-2 rounded-xl border border-border bg-card p-4 text-foreground shadow-soft-sm transition-[transform,box-shadow,background-color] duration-150 ease-out hover:-translate-y-0.5 hover:bg-muted hover:shadow-soft active:scale-[0.97]"
            >
                <IconCart class="w-6 h-6" />
                <span class="font-semibold text-xs">Сагс</span>
            </a>

            <a
                href="/profile"
                class="flex flex-col items-center justify-center gap-2 rounded-xl border border-border bg-card p-4 text-foreground shadow-soft-sm transition-[transform,box-shadow,background-color] duration-150 ease-out hover:-translate-y-0.5 hover:bg-muted hover:shadow-soft active:scale-[0.97]"
            >
                <IconUser class="w-6 h-6" />
                <span class="font-semibold text-xs">Профайл</span>
            </a>
        </div>

        <!-- Brands - Logo Grid -->
        <div class="px-4 pb-4">
            <h3 class="mb-3 text-muted-foreground text-xs uppercase tracking-wide">
                Брэндүүд
            </h3>
            {navBrands.length > 0 ? (
                <>
                    <div class="grid grid-cols-3 gap-2">
                        {topBrands.map((brand: { id: number; name: string; slug: string; logoUrl?: string | null; productCount?: number }) => {
                            const logoUrl = getBrandLogoUrl(brand.logoUrl);
                            return (
                            <a
                                href={`/products/brand/${brand.slug}/1/`}
                                class="group flex aspect-square items-center justify-center rounded-xl border border-border bg-card p-3 shadow-soft-sm transition-[transform,box-shadow] duration-150 ease-out hover:-translate-y-0.5 hover:shadow-soft active:scale-[0.97]"
                                title={brand.name}
                            >
                                {logoUrl ? (
                                    <img
                                        src={logoUrl}
                                        alt={brand.name}
                                        class="max-h-full max-w-full object-contain transition-transform duration-150 ease-out group-hover:scale-105"
                                        loading="lazy"
                                        onerror={brandLogoOnError}
                                    />
                                ) : (
                                    <div class="flex h-full w-full items-center justify-center rounded-lg bg-muted font-semibold text-sm">
                                        {brand.name.substring(0, 2).toUpperCase()}
                                    </div>
                                )}
                            </a>
                            );
                        })}
                    </div>
                    {remainingBrands.length > 0 && (
                        <details class="group mt-3">
                            <summary class="flex min-h-11 w-full cursor-pointer select-none list-none items-center justify-center gap-2 rounded-full border border-border bg-card p-3 font-semibold text-sm shadow-soft-sm transition-[background-color] duration-150 ease-out hover:bg-muted [&::-webkit-details-marker]:hidden">
                                <span>Илүү харах</span>
                                <IconArrowDown class="h-4 w-4 transition-transform duration-200 ease-out group-open:rotate-180" />
                            </summary>
                            <div class="mt-2 grid grid-cols-3 gap-2">
                                {remainingBrands.map((brand: { id: number; name: string; slug: string; logoUrl?: string | null; productCount?: number }) => {
                                    const logoUrl = getBrandLogoUrl(brand.logoUrl);
                                    return (
                                    <a
                                        href={`/products/brand/${brand.slug}/1/`}
                                        class="group flex aspect-square items-center justify-center rounded-xl border border-border bg-card p-3 shadow-soft-sm transition-[transform,box-shadow] duration-150 ease-out hover:-translate-y-0.5 hover:shadow-soft active:scale-[0.97]"
                                        title={brand.name}
                                    >
                                        {logoUrl ? (
                                            <img
                                                src={logoUrl}
                                                alt={brand.name}
                                                class="max-h-full max-w-full object-contain transition-transform duration-150 ease-out group-hover:scale-105"
                                                loading="lazy"
                                                onerror={brandLogoOnError}
                                            />
                                        ) : (
                                            <div class="flex h-full w-full items-center justify-center rounded-lg bg-muted font-semibold text-sm">
                                                {brand.name.substring(0, 2).toUpperCase()}
                                            </div>
                                        )}
                                    </a>
                                    );
                                })}
                            </div>
                        </details>
                    )}
                </>
            ) : (
                <div class="py-8 text-center text-muted-foreground">
                    <p class="text-sm">Брэнд олдсонгүй</p>
                </div>
            )}
        </div>

        <!-- Categories -->
        <div class="px-4 pb-4">
            <h3 class="mb-3 text-muted-foreground text-xs uppercase tracking-wide">
                Ангилал
            </h3>
            <div class="grid grid-cols-2 gap-2">
                {topCategories.map((category: { id: number; name: string; slug: string }) => (
                    <a
                        href={`/products/category/${category.slug}/1/`}
                        class="flex min-h-[60px] items-center justify-center rounded-xl border border-border bg-card px-3 py-2.5 text-center font-semibold text-xs leading-tight shadow-soft-sm transition-[transform,box-shadow,background-color] duration-150 ease-out hover:-translate-y-0.5 hover:bg-muted hover:shadow-soft active:scale-[0.97]"
                    >
                        <span class="line-clamp-2">{category.name}</span>
                    </a>
                ))}
            </div>
            {remainingCategories.length > 0 && (
                <details class="group mt-3">
                    <summary class="flex min-h-11 w-full cursor-pointer select-none list-none items-center justify-center gap-2 rounded-full border border-border bg-card p-3 font-semibold text-sm shadow-soft-sm transition-[background-color] duration-150 ease-out hover:bg-muted [&::-webkit-details-marker]:hidden">
                        <span>Илүү харах</span>
                        <IconArrowDown class="h-4 w-4 transition-transform duration-200 ease-out group-open:rotate-180" />
                    </summary>
                    <div class="mt-2 grid grid-cols-2 gap-2">
                        {remainingCategories.map((category: { id: number; name: string; slug: string }) => (
                            <a
                                href={`/products/category/${category.slug}/1/`}
                                class="flex min-h-[60px] items-center justify-center rounded-xl border border-border bg-card px-3 py-2.5 text-center font-semibold text-xs leading-tight shadow-soft-sm transition-[transform,box-shadow,background-color] duration-150 ease-out hover:-translate-y-0.5 hover:bg-muted hover:shadow-soft active:scale-[0.97]"
                            >
                                <span class="line-clamp-2">{category.name}</span>
                            </a>
                        ))}
                    </div>
                </details>
            )}
        </div>

        <div class="px-4 pb-4">
            <h3 class="mb-3 text-muted-foreground text-xs uppercase tracking-wide">
                Онцлох хэсэг
            </h3>
            <div class="grid grid-cols-2 gap-2">
                <a
                    href="/products?filter=featured"
                    class="flex min-h-11 items-center justify-center rounded-full border border-border bg-card p-2.5 font-semibold text-xs shadow-soft-sm transition-[background-color,box-shadow] duration-150 ease-out hover:bg-muted hover:shadow-soft active:scale-[0.97]"
                >
                    Онцлох
                </a>
                <a
                    href="/products?filter=recent"
                    class="flex min-h-11 items-center justify-center rounded-full border border-border bg-card p-2.5 font-semibold text-xs shadow-soft-sm transition-[background-color,box-shadow] duration-150 ease-out hover:bg-muted hover:shadow-soft active:scale-[0.97]"
                >
                    Шинэ
                </a>
            </div>
        </div>
    </div>

    <!-- Bottom Branding -->
    <div class="border-border border-t bg-muted/50 p-4">
        <div class="flex items-center gap-3">
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-primary font-display text-primary-foreground text-xs">
                AV
            </div>
            <div>
                <span class="block font-display text-foreground text-sm">Amerik Vitamin</span>
                <span class="text-[10px] text-muted-foreground">Баталгаатай импорт</span>
            </div>
        </div>
    </div>
</div>

<script>
  // Close sidebar when navigation links are clicked
  // Use event delegation to handle dynamically added links
  function setupSidebarNavigation() {
    interface SidebarNavigationContainer extends HTMLElement {
      __sidebarNavSetup?: boolean;
      __sidebarNavHandler?: EventListener;
    }

    // Find the sidebar container - look for the dialog wrapper
    const sidebarContainer = document.querySelector(
      '.starwind-dialog',
    ) as SidebarNavigationContainer | null;
    if (!sidebarContainer) return;

    // Remove existing listener if any (using a data attribute to track)
    if (sidebarContainer.__sidebarNavSetup && sidebarContainer.__sidebarNavHandler) {
      sidebarContainer.removeEventListener('click', sidebarContainer.__sidebarNavHandler);
    }

    // Create a single event handler using event delegation
    const handleLinkClick = (e: Event) => {
      const target = e.target as HTMLElement;
      const link = target.closest('a[href]') as HTMLAnchorElement;

      if (link && sidebarContainer.contains(link)) {
        // Find the close button and click it to trigger proper close animation
        const closeButton = sidebarContainer.querySelector('[data-slot="sheet-close"], .starwind-dialog-close') as HTMLButtonElement;
        if (closeButton) {
          // Use a small delay to ensure the click is processed
          setTimeout(() => {
            closeButton.click();
          }, 10);
        }
      }
    };

    // Store handler reference for cleanup
    sidebarContainer.__sidebarNavHandler = handleLinkClick;
    sidebarContainer.__sidebarNavSetup = true;

    sidebarContainer.addEventListener('click', handleLinkClick);
  }

  // Setup on page load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupSidebarNavigation);
  } else {
    setupSidebarNavigation();
  }

  // Setup after Astro navigation (for View Transitions)
  document.addEventListener('astro:after-swap', setupSidebarNavigation);
</script>
