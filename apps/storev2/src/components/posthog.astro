<script  is:inline type="text/javascript" id="posthog-js">
  const POSTHOG_API_KEY = "phc_6ClB1oVCNXmTDzhKtRWwiHdKOr5nqCvaX3a90dO8aOR";
  const POSTHOG_HOST = "https://us.i.posthog.com";

  const initPosthog = () => {
    /** @type {{ init?: (apiKey: string, options: { api_host: string; defaults: string }) => void } | undefined} */
    const posthog = window.posthog;

    posthog?.init?.(POSTHOG_API_KEY, {
      api_host: POSTHOG_HOST,
      defaults: "2025-05-24",
    });
  };

  if (window.posthog) {
    initPosthog();
  } else {
    const script = document.createElement("script");
    script.type = "text/javascript";
    script.async = true;
    script.crossOrigin = "anonymous";
    script.src = `${POSTHOG_HOST}/static/array.js`;
    script.addEventListener("load", initPosthog, { once: true });
    document.head.append(script);
  }
</script>
