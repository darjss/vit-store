---
import { ClientRouter } from "astro:transitions";
import CartDrawer from "@/components/cart/cart-drawer";
import QueryDevtools from "@/components/query-devtools";
import SEO from "@/components/SEO.astro";
import { Toaster } from "@/components/ui/toast";
import Footer from "@/layouts/Footer.astro";
import Header from "@/layouts/Header.astro";
import MobileNavbar from "@/layouts/MobileNavbar.astro";
import PostHog from "../components/posthog.astro";

import "@fontsource-variable/onest";
import "@fontsource-variable/unbounded";
import "../styles/global.css";

export interface Props {
	title?: string;
	description?: string;
	image?: string;
	imageAlt?: string;
	noindex?: boolean;
	nofollow?: boolean;
	canonical?: string;
}

const { title, description, image, imageAlt, noindex, nofollow, canonical } = Astro.props;
---

<!doctype html>
<html lang="mn">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="generator" content={Astro.generator} />
        <SEO 
            title={title}
            description={description}
            image={image}
            imageAlt={imageAlt}
            noindex={noindex}
            nofollow={nofollow}
            canonical={canonical}
        />
        <ClientRouter />
        <PostHog />
    </head>
    <body>
        {/* Fallback pageview capture for Astro view transitions (SPA navigation).
            PostHog's history_change listener should catch most, but this ensures
            coverage if Astro's transition timing doesn't trigger it. */}
        <script is:inline>
            document.addEventListener('astro:after-swap', () => {
                if (window.posthog && typeof window.posthog.capture === 'function') {
                    window.posthog.capture('$pageview');
                }
            });

            // Exception capture is handled by PostHog's built-in
            // capture_exceptions (enabled in posthog.astro with
            // capture_unhandled_errors + capture_unhandled_rejections).
            // The previous inline handler duplicated every $exception event.
        </script>

        <div id="loading-bar" class="loading-bar">
            <div class="loading-bar-progress"></div>
        </div>

        <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-[100] focus:px-4 focus:py-3 focus:bg-primary focus:text-primary-foreground focus:font-semibold focus:rounded-full focus:shadow-lift">
            Үндсэн агуулгад очих
        </a>

        <Header />
        

        <main id="main" class="relative z-10 flex-1 overflow-x-hidden">
            <slot />
            <Toaster client:idle />
        </main>

        {/* Screen reader announcements for cart changes */}
        <div id="cart-live-region" aria-live="polite" aria-atomic="true" class="sr-only"></div>

        <Footer />
        <MobileNavbar />
        <CartDrawer client:idle />
        		{import.meta.env.DEV && <QueryDevtools client:idle />}

    </body>
</html>

<style>
    html,
    body {
        margin: 0;
        width: 100%;
        height: 100%;
    }
</style>
<script>
    let loadingBarHideTimer: number | undefined;
    let loadingBarFallbackTimer: number | undefined;
    const prefersReducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
    );

    function getLoadingBar() {
        return document.getElementById("loading-bar");
    }

    function hideLoadingBar() {
        const loadingBar = getLoadingBar();
        if (!loadingBar) {
            return;
        }

        loadingBar.classList.add("is-complete");
        loadingBarHideTimer = window.setTimeout(() => {
            loadingBar.classList.remove("show", "is-complete");
        }, 120);
    }

    function closeOpenDialogs() {
        document
            .querySelectorAll<HTMLDialogElement>("dialog[open]")
            .forEach((dialog) => {
                dialog.close();
                dialog.dataset.state = "closed";
            });

        document
            .querySelectorAll<HTMLElement>(".starwind-dialog-backdrop")
            .forEach((backdrop) => {
                backdrop.classList.add("hidden");
                backdrop.dataset.state = "closed";
            });

        document.body.classList.remove("overflow-hidden");
        if (document.activeElement instanceof HTMLElement) {
            document.activeElement.blur();
        }
    }

    document.addEventListener("astro:before-preparation", () => {
        if (loadingBarHideTimer) {
            window.clearTimeout(loadingBarHideTimer);
        }
        if (loadingBarFallbackTimer) {
            window.clearTimeout(loadingBarFallbackTimer);
        }

        closeOpenDialogs();

        if (prefersReducedMotion.matches) {
            return;
        }

        const loadingBar = getLoadingBar();
        if (loadingBar) {
            loadingBar.classList.remove("is-complete");
            loadingBar.classList.add("show");
            loadingBarFallbackTimer = window.setTimeout(hideLoadingBar, 8000);
        }
    });

    document.addEventListener("astro:page-load", () => {
        if (loadingBarFallbackTimer) {
            window.clearTimeout(loadingBarFallbackTimer);
        }
        hideLoadingBar();
    });
</script>
