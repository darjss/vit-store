---
import { ClientRouter } from "astro:transitions";
import CartDrawer from "@/components/cart/cart-drawer";
import QueryDevtools from "@/components/query-devtools";
import SEO from "@/components/SEO.astro";
import { Toaster } from "@/components/ui/toast";
import Footer from "@/layouts/Footer.astro";
import Header from "@/layouts/Header.astro";
import MobileNavbar from "@/layouts/MobileNavbar.astro";
import PostHog from "../components/posthog.astro";

import "../styles/global.css";

export interface Props {
	title?: string;
	description?: string;
	image?: string;
	imageAlt?: string;
	noindex?: boolean;
	nofollow?: boolean;
	canonical?: string;
}

const { title, description, image, imageAlt, noindex, nofollow, canonical } = Astro.props;
---

<!doctype html>
<html lang="mn">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="generator" content={Astro.generator} />
        <SEO 
            title={title}
            description={description}
            image={image}
            imageAlt={imageAlt}
            noindex={noindex}
            nofollow={nofollow}
            canonical={canonical}
        />
        <ClientRouter />
        <PostHog />
    </head>
    <body>
        {/* Fallback pageview capture for Astro view transitions (SPA navigation).
            PostHog's history_change listener should catch most, but this ensures
            coverage if Astro's transition timing doesn't trigger it. */}
        <script is:inline>
            document.addEventListener('astro:after-swap', () => {
                if (window.posthog && typeof window.posthog.capture === 'function') {
                    window.posthog.capture('$pageview');
                }
            });

            // Rich exception capture — PostHog's autocapture sometimes loses
            // error details in Facebook/Instagram in-app browsers.
            (function() {
                function sendException(props) {
                    if (window.posthog && typeof window.posthog.capture === 'function') {
                        window.posthog.capture('$exception', props);
                    }
                }

                window.addEventListener('error', function(event) {
                    var err = event.error || {};
                    sendException({
                        $exception_message: err.message || event.message || 'Unknown error',
                        $exception_type: err.name || 'Error',
                        $exception_source: event.filename || '',
                        $exception_lineno: event.lineno || 0,
                        $exception_colno: event.colno || 0,
                        $exception_stack_trace: err.stack || '',
                        $current_url: window.location.href,
                        $browser: navigator.userAgent,
                        $device_type: /Mobi|Android|iPhone/i.test(navigator.userAgent) ? 'Mobile' : 'Desktop',
                        error_captured_by: 'manual_global_handler',
                    });
                });

                window.addEventListener('unhandledrejection', function(event) {
                    var reason = event.reason;
                    var isErr = reason instanceof Error;
                    sendException({
                        $exception_message: isErr ? reason.message : String(reason),
                        $exception_type: isErr ? (reason.name || 'UnhandledRejection') : 'UnhandledRejection',
                        $exception_stack_trace: isErr ? (reason.stack || '') : '',
                        $current_url: window.location.href,
                        $browser: navigator.userAgent,
                        $device_type: /Mobi|Android|iPhone/i.test(navigator.userAgent) ? 'Mobile' : 'Desktop',
                        error_captured_by: 'manual_unhandled_rejection',
                    });
                });
            })();
        </script>

        <div id="loading-bar" class="loading-bar">
            <div class="loading-bar-progress"></div>
        </div>

        <div
            class="absolute inset-0 opacity-[0.03] pointer-events-none"
            style="background-image: linear-gradient(to right, var(--color-border) 1px, transparent 1px), linear-gradient(to bottom, var(--color-border) 1px, transparent 1px); background-size: 40px 40px;"
        >
        </div>

        <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-[100] focus:px-4 focus:py-3 focus:bg-primary focus:text-primary-foreground focus:font-black focus:uppercase focus:tracking-wider focus:border-4 focus:border-border focus:shadow-hard">
            Үндсэн агуулгад очих
        </a>

        <Header />
        

        <main id="main" class="relative z-10 flex-1 overflow-x-hidden">
            <slot />
            <Toaster client:idle />
        </main>

        {/* Screen reader announcements for cart changes */}
        <div id="cart-live-region" aria-live="polite" aria-atomic="true" class="sr-only"></div>

        <Footer />
        <MobileNavbar />
        <CartDrawer client:idle />
        		{import.meta.env.DEV && <QueryDevtools client:idle />}

    </body>
</html>

<style>
    html,
    body {
        margin: 0;
        width: 100%;
        height: 100%;
    }
</style>
<script>
    let loadingBarHideTimer: number | undefined;
    let loadingBarFallbackTimer: number | undefined;
    const prefersReducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
    );

    function getLoadingBar() {
        return document.getElementById("loading-bar");
    }

    function hideLoadingBar() {
        const loadingBar = getLoadingBar();
        if (!loadingBar) {
            return;
        }

        loadingBar.classList.add("is-complete");
        loadingBarHideTimer = window.setTimeout(() => {
            loadingBar.classList.remove("show", "is-complete");
        }, 120);
    }

    function closeOpenDialogs() {
        document
            .querySelectorAll<HTMLDialogElement>("dialog[open]")
            .forEach((dialog) => {
                dialog.close();
                dialog.dataset.state = "closed";
            });

        document
            .querySelectorAll<HTMLElement>(".starwind-dialog-backdrop")
            .forEach((backdrop) => {
                backdrop.classList.add("hidden");
                backdrop.dataset.state = "closed";
            });

        document.body.classList.remove("overflow-hidden");
        if (document.activeElement instanceof HTMLElement) {
            document.activeElement.blur();
        }
    }

    document.addEventListener("astro:before-preparation", () => {
        if (loadingBarHideTimer) {
            window.clearTimeout(loadingBarHideTimer);
        }
        if (loadingBarFallbackTimer) {
            window.clearTimeout(loadingBarFallbackTimer);
        }

        closeOpenDialogs();

        if (prefersReducedMotion.matches) {
            return;
        }

        const loadingBar = getLoadingBar();
        if (loadingBar) {
            loadingBar.classList.remove("is-complete");
            loadingBar.classList.add("show");
            loadingBarFallbackTimer = window.setTimeout(hideLoadingBar, 8000);
        }
    });

    document.addEventListener("astro:page-load", () => {
        if (loadingBarFallbackTimer) {
            window.clearTimeout(loadingBarFallbackTimer);
        }
        hideLoadingBar();
    });
</script>
