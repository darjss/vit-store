---















import MobileCartButton from "@/components/cart/mobile-cart-button";
import MobileSearchButton from "@/components/search/mobile-search-button";
import IconHome from "~icons/ri/home-4-line";
import IconStore from "~icons/ri/store-2-line";
---

<nav
    data-mobile-navbar
    class="md:hidden fixed inset-x-0 bottom-0 z-40 border-t-4 border-border bg-background h-[73px] transition-opacity duration-200 data-[overlay-open=true]:pointer-events-none data-[overlay-open=true]:opacity-40" transition:persist transition:name="mobile-navbar"
    aria-label="Гар утасны үндсэн цэс"
>
    <div class="mx-auto max-w-screen-sm">
        <ul class="grid grid-cols-4 gap-1 px-3 py-2">
            <li>
                <a
                    href="/"
                    class="group block px-3 py-2 transition-colors duration-200 text-foreground/70 hover:text-foreground hover:bg-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
                    aria-label="Нүүр"
                >
                    <div class="flex flex-col items-center gap-1">
                        <IconHome class="w-5 h-5 transition-transform duration-200 group-hover:scale-110" aria-hidden="true" />
                        <p class="font-bold text-[11px] leading-none">Нүүр</p>
                    </div>
                </a>
            </li>

            <li>
                <a
                    href="/products/"
                    class="group block px-3 py-2 transition-colors duration-200 text-foreground/70 hover:text-foreground hover:bg-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
                    aria-label="Бүтээгдэхүүн"
                >
                    <div class="flex flex-col items-center gap-1">
                        <IconStore class="w-5 h-5 transition-transform duration-200 group-hover:scale-110" aria-hidden="true" />
                        <p class="font-bold text-[11px] leading-none">
                            Бүтээгдэхүүн
                        </p>
                    </div>
                </a>
            </li>

            <li>
                <MobileCartButton client:load />
            </li>

            <li>
                <MobileSearchButton client:load />
            </li>
        </ul>
    </div>
</nav>

<script>
    function updateActiveLink() {
        const currentPath = window.location.pathname;
        const links = document.querySelectorAll("[data-mobile-navbar] a");

        links.forEach((link) => {
            const href = link.getAttribute("href");
            if (href) {
                link.classList.remove(
                    "bg-primary",
                    "text-primary-foreground",
                    "shadow-hard-sm",
                );
                link.classList.add("text-foreground/70");
                link.removeAttribute("aria-current");

                if (
                    (href === "/" && currentPath === "/") ||
                    (href !== "/" && currentPath.startsWith(href))
                ) {
                    link.classList.add(
                        "bg-primary",
                        "text-primary-foreground",
                        "shadow-hard-sm",
                    );
                    link.classList.remove("text-foreground/70");
                    link.setAttribute("aria-current", "page");
                }
            }
        });
    }

    function updateOverlayState() {
        const mobileNavbar = document.querySelector("[data-mobile-navbar]");
        if (!mobileNavbar) return;

        const hasOpenOverlay = Boolean(
            document.querySelector("dialog[open], [data-expanded]")
        );

        mobileNavbar.setAttribute(
            "data-overlay-open",
            hasOpenOverlay ? "true" : "false",
        );
        mobileNavbar.setAttribute("aria-hidden", hasOpenOverlay ? "true" : "false");
    }

    updateActiveLink();
    updateOverlayState();

    const overlayObserver = new MutationObserver(updateOverlayState);
    overlayObserver.observe(document.body, {
        attributes: true,
        attributeFilter: ["open", "data-expanded", "data-state"],
        childList: true,
        subtree: true,
    });

    document.addEventListener("astro:after-swap", updateActiveLink);
    document.addEventListener("astro:after-swap", updateOverlayState);
</script>
