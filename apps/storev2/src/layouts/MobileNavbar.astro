---
import MobileCartButton from "@/components/cart/mobile-cart-button";
import MobileSearchButton from "@/components/search/mobile-search-button";
import { HomeAngleIcon as IconHome, ShopIcon as IconStore } from "@solar-icons/solid/linear";
---

<nav
    data-mobile-navbar
    class="md:hidden fixed bottom-[var(--mobile-bottom-edge)] inset-x-3 z-40 h-[var(--mobile-navbar-height)] mx-auto max-w-md rounded-full border border-border bg-card supports-[backdrop-filter]:bg-card/90 supports-[backdrop-filter]:backdrop-blur-md shadow-soft-lg transition-opacity duration-200 data-[overlay-open=true]:pointer-events-none data-[overlay-open=true]:opacity-40" transition:persist transition:name="mobile-navbar"
    aria-label="Гар утасны үндсэн цэс"
>
    <ul class="grid h-full grid-cols-4 gap-1 p-1.5">
        <li>
            <a
                href="/"
                class="group flex min-h-[48px] flex-col items-center justify-center gap-1 rounded-full px-2 py-1.5 text-foreground/70 transition-colors duration-200 hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
                aria-label="Нүүр"
            >
                <IconHome class="w-5 h-5" aria-hidden="true" />
                <p class="font-semibold text-[11px] leading-none">Нүүр</p>
            </a>
        </li>

        <li>
            <a
                href="/products/"
                class="group flex min-h-[48px] flex-col items-center justify-center gap-1 rounded-full px-2 py-1.5 text-foreground/70 transition-colors duration-200 hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
                aria-label="Бүтээгдэхүүн"
            >
                <IconStore class="w-5 h-5" aria-hidden="true" />
                <p class="font-semibold text-[11px] leading-none">
                    Бүтээгдэхүүн
                </p>
            </a>
        </li>

        <li>
            <MobileCartButton client:idle />
        </li>

        <li>
            <MobileSearchButton client:idle />
        </li>
    </ul>
</nav>

<script>
    function updateActiveLink() {
        const currentPath = window.location.pathname;
        const links = document.querySelectorAll("[data-mobile-navbar] a");

        links.forEach((link) => {
            const href = link.getAttribute("href");
            if (href) {
                link.classList.remove(
                    "bg-primary",
                    "text-primary-foreground",
                    "shadow-soft-sm",
                );
                link.classList.add("text-foreground/70");
                link.removeAttribute("aria-current");

                if (
                    (href === "/" && currentPath === "/") ||
                    (href !== "/" && currentPath.startsWith(href))
                ) {
                    link.classList.add(
                        "bg-primary",
                        "text-primary-foreground",
                        "shadow-soft-sm",
                    );
                    link.classList.remove("text-foreground/70");
                    link.setAttribute("aria-current", "page");
                }
            }
        });
    }

    function updateOverlayState() {
        const mobileNavbar = document.querySelector("[data-mobile-navbar]");
        if (!mobileNavbar) return;

        const hasOpenOverlay = Boolean(
            document.querySelector("dialog[open], [data-expanded]")
        );

        mobileNavbar.setAttribute(
            "data-overlay-open",
            hasOpenOverlay ? "true" : "false",
        );
        mobileNavbar.setAttribute("aria-hidden", hasOpenOverlay ? "true" : "false");
    }

    updateActiveLink();
    updateOverlayState();

    const overlayObserver = new MutationObserver(updateOverlayState);
    overlayObserver.observe(document.body, {
        attributes: true,
        attributeFilter: ["open", "data-expanded", "data-state"],
        childList: true,
        subtree: true,
    });

    document.addEventListener("astro:after-swap", updateActiveLink);
    document.addEventListener("astro:after-swap", updateOverlayState);
</script>
