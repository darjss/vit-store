---
import IconPhone from "~icons/ri/phone-line";
import IconMail from "~icons/ri/mail-line";
import IconClock from "~icons/ri/time-line";
import IconMapPin from "~icons/ri/map-pin-line";
import IconFacebook from "~icons/ri/facebook-fill";
import IconInstagram from "~icons/ri/instagram-line";
import IconTruck from "~icons/ri/truck-line";
import IconQuestion from "~icons/ri/question-line";
import IconShield from "~icons/ri/shield-check-line";
import IconFile from "~icons/ri/file-list-line";
import IconSearch from "~icons/ri/search-line";
import IconClose from "~icons/ri/close-circle-line";

const currentYear = new Date().getFullYear();

const contactInfo = [
  {
    icon: IconPhone,
    label: "Утас",
    value: "9999-3950",
    href: "tel:+97699993950",
  },
  {
    icon: IconMail,
    label: "И-мэйл",
    value: "info@amerikvitamin.mn",
    href: "mailto:info@amerikvitamin.mn",
  },
  {
    icon: IconClock,
    label: "Цагийн хуваарь",
    value: "Даваа–Баасан 10:00–18:00",
    href: null,
  },
  {
    icon: IconMapPin,
    label: "Хүргэлт",
    value: "Улаанбаатар + Хөдөө",
    href: "/shipping",
  },
];

const shopLinks = [
  { label: "Нүүр", href: "/" },
  { label: "Бүтээгдэхүүн", href: "/products" },
  { label: "Сагс", href: "/cart" },
  { label: "Профайл", href: "/profile" },
];

const serviceLinks = [
  { label: "Түгээмэл асуулт", href: "/faq", icon: IconQuestion },
  { label: "Хүргэлтийн мэдээлэл", href: "/shipping", icon: IconTruck },
  { label: "Буцаалтын бодлого", href: "/returns-refunds", icon: IconClose },
  { label: "Захиалга хянах", href: "/order-tracking", icon: IconSearch },
  { label: "Бидэнтэй холбогдох", href: "/contact", icon: IconPhone },
];

const legalLinks = [
  { label: "Нууцлалын бодлого", href: "/privacy-policy", icon: IconShield },
  { label: "Үйлчилгээний нөхцөл", href: "/terms-of-service", icon: IconFile },
];

const socials = [
  {
    icon: IconFacebook,
    label: "Facebook",
    href: "https://www.facebook.com/profile.php?id=100057596651892",
  },
  {
    icon: IconInstagram,
    label: "Instagram",
    href: "https://www.instagram.com/amerikhunsbaraa/",
  },
];

const certifications = ["GMP", "FDA", "NSF", "USP", "Non-GMO", "USDA"];
---

<footer class="relative z-10 bg-secondary text-secondary-foreground pb-24 md:pb-0">
  <div class="mx-auto max-w-screen-2xl px-5 py-10 lg:px-8 lg:py-14">
    <!-- Main footer grid -->
    <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-12 lg:gap-8">
      <!-- Brand column -->
      <div class="lg:col-span-4">
        <div class="mb-4 flex items-center gap-2.5">
          <div class="h-10 w-10 rounded-xl bg-primary flex items-center justify-center font-display font-bold text-xs text-primary-foreground shadow-soft-sm">AV</div>
          <span class="font-display font-semibold text-base">Amerik Vitamin</span>
        </div>
        <p class="max-w-xs text-sm font-medium leading-relaxed text-secondary-foreground/70 mb-6">
          АНУ-аас шууд импортлогдсон жинхэнэ витамин, нэмэлт тэжээлийг Монгол улсын дотоодод хүргэлттэй борлуулж байна.
        </p>

        <!-- Socials -->
        <div class="flex items-center gap-2.5">
          {socials.map((social) => (
            <a
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-center w-11 h-11 rounded-full border border-secondary-foreground/15 bg-secondary-foreground/5 transition-[background-color,transform] duration-200 ease-out-quart hover:bg-secondary-foreground/15 active:scale-[0.94]"
              aria-label={social.label}
            >
              <social.icon class="w-4 h-4" />
            </a>
          ))}
        </div>
      </div>

      <!-- Shop links -->
      <div class="lg:col-span-2">
        <h3 class="mb-3.5 text-[11px] font-bold uppercase tracking-[0.12em] text-secondary-foreground/50">Үндсэн цэс</h3>
        <ul class="flex flex-col gap-1">
          {shopLinks.map((link) => (
            <li>
              <a href={link.href} class="inline-block py-1.5 font-medium text-sm text-secondary-foreground/75 hover:text-secondary-foreground transition-colors duration-150">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Service links -->
      <div class="lg:col-span-3">
        <h3 class="mb-3.5 text-[11px] font-bold uppercase tracking-[0.12em] text-secondary-foreground/50">Үйлчилгээ</h3>
        <ul class="flex flex-col gap-1">
          {serviceLinks.map((link) => (
            <li>
              <a href={link.href} class="inline-flex items-center gap-2 py-1.5 font-medium text-sm text-secondary-foreground/75 hover:text-secondary-foreground transition-colors duration-150">
                <link.icon class="w-3.5 h-3.5 shrink-0 opacity-60" />
                <span>{link.label}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div class="lg:col-span-3">
        <h3 class="mb-3.5 text-[11px] font-bold uppercase tracking-[0.12em] text-secondary-foreground/50">Холбоо барих</h3>
        <ul class="flex flex-col gap-3">
          {contactInfo.map((item) => (
            <li class="flex items-start gap-3">
              <div class="w-8 h-8 rounded-full bg-secondary-foreground/8 flex items-center justify-center shrink-0">
                <item.icon class="w-3.5 h-3.5 opacity-80" />
              </div>
              <div class="min-w-0">
                <div class="text-[11px] font-semibold uppercase tracking-wider text-secondary-foreground/50">{item.label}</div>
                {item.href ? (
                  <a href={item.href} class="text-sm font-medium text-secondary-foreground/85 hover:text-secondary-foreground transition-colors duration-150">
                    {item.value}
                  </a>
                ) : (
                  <span class="text-sm font-medium text-secondary-foreground/85">{item.value}</span>
                )}
              </div>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Certifications & payment -->
    <div class="mt-10 pt-6 border-t border-secondary-foreground/10">
      <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-5">
        <div class="flex flex-wrap items-center gap-x-3 gap-y-2">
          <span class="text-[11px] font-bold uppercase tracking-[0.12em] text-secondary-foreground/50">Баталгаа</span>
          {certifications.map((cert) => (
            <span class="inline-flex items-center gap-1.5 rounded-full border border-secondary-foreground/15 px-3 py-1 text-xs font-semibold text-secondary-foreground/75">
              <IconShield class="w-3 h-3 text-primary" />
              {cert}
            </span>
          ))}
        </div>

        <div class="flex items-center gap-3">
          <span class="text-[11px] font-bold uppercase tracking-[0.12em] text-secondary-foreground/50">Төлбөр</span>
          <div class="flex items-center gap-2">
            <span class="inline-flex h-8 items-center rounded-full bg-secondary-foreground/90 px-3">
              <img src="/qpay.png" alt="QPay" class="h-4 w-auto object-contain" loading="lazy" />
            </span>
            <span class="inline-flex h-8 items-center rounded-full border border-secondary-foreground/15 px-3 text-xs font-semibold text-secondary-foreground/75">Банкны шилжүүлэг</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-6 pt-5 border-t border-secondary-foreground/10 flex flex-col gap-3 text-xs lg:flex-row lg:items-center lg:justify-between">
      <div class="flex flex-wrap items-center gap-x-4 gap-y-1.5">
        <p class="font-medium text-secondary-foreground/60">Хүнсний нэмэлт нь эмийн орлогч биш.</p>
        {legalLinks.map((link) => (
          <a href={link.href} class="font-medium text-secondary-foreground/60 hover:text-secondary-foreground transition-colors duration-150 underline decoration-secondary-foreground/30 decoration-1 underline-offset-2">
            {link.label}
          </a>
        ))}
      </div>
      <p class="font-semibold text-secondary-foreground/60">© {currentYear} Amerik Vitamin</p>
    </div>
  </div>
</footer>
