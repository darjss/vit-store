---
import UserProfile from "@/components/auth/UserProfile.astro";
import CartButton from "@/components/cart/cart-button";
import SidebarContent from "@/components/SidebarContent.astro";
import SearchOverlay from "@/components/search/search-overlay";
import { Sheet, SheetContent, SheetTrigger } from "@/components/starwind/sheet";
import { HamburgerMenuIcon as IconMenu, UserIcon as IconUser } from "@solar-icons/solid/linear";
---

<header
    class="sticky top-0 z-50 border-b border-border bg-background supports-[backdrop-filter]:bg-background/90 supports-[backdrop-filter]:backdrop-blur-md" transition:persist transition:name="header"
>
    <div class="mx-auto max-w-screen-2xl px-4 py-2.5 lg:px-8 lg:py-3">
        <div class="flex items-center justify-between gap-2 lg:gap-4">
            <Sheet>
                <SheetTrigger class="flex h-11 w-11 items-center justify-center rounded-full text-foreground transition-[background-color,transform] duration-200 ease-out-quart hover:bg-muted active:scale-[0.94]">
                    <IconMenu class="w-6 h-6" />
                    <span class="sr-only">Toggle menu</span>
                </SheetTrigger>
                <SheetContent aria-label="Үндсэн цэс" side="left" class="h-[100dvh] w-[300px] sm:w-[400px] border-r border-border p-0">
                    <div class="h-full overflow-y-auto overscroll-contain bg-background [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
                        <SidebarContent />
                    </div>
                </SheetContent>
            </Sheet>
            <a href="/" class="flex min-w-0 shrink-0 items-center gap-2.5 rounded-full py-1 pr-2 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2">
                <div class="h-10 w-10 shrink-0 rounded-xl bg-primary flex items-center justify-center font-display font-bold text-xs shadow-soft-sm">
                    AV
                </div>
                <div class="min-w-0">
                    <span class="block truncate font-display font-semibold text-[13px] sm:text-[15px] leading-tight">Amerik Vitamin</span>
                    <span class="hidden lg:block text-[11px] font-medium text-muted-foreground">АНУ-аас шууд хүргэлттэй</span>
                </div>
            </a>

            <!-- Inline search field — the header's visual anchor on tablet/desktop -->
            <div class="hidden md:flex flex-1 justify-center px-2 lg:px-6">
                <div class="w-full max-w-xl">
                    <SearchOverlay client:idle />
                </div>
            </div>

            <div class="flex items-center gap-1.5 lg:gap-2.5 shrink-0">
                <UserProfile server:defer>
                    <div
                        slot="fallback"
                        aria-label="Профайл"
                        class="flex items-center justify-center w-11 h-11 rounded-full border border-border bg-card shadow-soft-sm"
                    >
                        <IconUser class="w-4 h-4" />
                    </div>
                </UserProfile>


                <div class="hidden md:block">
                    <CartButton client:idle />
                </div>
            </div>
        </div>
    </div>
</header>
