---
import UserProfile from "@/components/auth/UserProfile.astro";
import CartButton from "@/components/cart/cart-button";
import SidebarContent from "@/components/SidebarContent.astro";
import SearchOverlay from "@/components/search/search-overlay";
import { Sheet, SheetContent, SheetTrigger } from "@/components/starwind/sheet";
import IconMenu from "~icons/ri/menu-line";
import IconUser from "~icons/ri/user-line";
---

<header
    class="sticky top-0 z-50 border-b border-border bg-background"
    transition:persist
    transition:name="header"
>
    <div class="mx-auto max-w-screen-2xl px-4 py-2.5 lg:px-6 lg:py-3">
        <div class="flex items-center justify-between gap-2 lg:gap-4">
            <!-- Left: Menu + Logo -->
            <div class="flex items-center gap-2.5 lg:gap-3 min-w-0">
                <Sheet>
                    <SheetTrigger class="shrink-0 flex items-center justify-center w-10 h-10 rounded-lg border border-border bg-card shadow-soft-sm hover:shadow-soft hover:border-primary active:scale-[0.97] transition-[box-shadow,transform,border-color] duration-200 ease-out-quart">
                        <IconMenu class="w-5 h-5" />
                        <span class="sr-only">Toggle menu</span>
                    </SheetTrigger>
                    <SheetContent side="left" class="w-[300px] sm:w-[400px] border-r border-border p-0">
                        <div class="h-full overflow-y-auto bg-background">
                            <SidebarContent />
                        </div>
                    </SheetContent>
                </Sheet>

                <a href="/" class="flex min-w-0 items-center group">
                    <span class="block truncate font-extrabold text-base uppercase tracking-tight sm:text-lg group-hover:text-primary transition-colors duration-100">Amerik Vitamin</span>
                </a>
            </div>

            <!-- Right: Search + Profile + Cart -->
            <div class="flex items-center gap-2 lg:gap-2.5 shrink-0">
                <div class="hidden sm:block">
                    <SearchOverlay client:idle />
                </div>

                <UserProfile server:defer>
                    <div
                        slot="fallback"
                        aria-label="Профайл"
                        class="flex items-center justify-center w-10 h-10 rounded-lg border border-border bg-card shadow-soft-sm"
                    >
                        <IconUser class="w-4 h-4" />
                    </div>
                </UserProfile>

                <div class="hidden md:block">
                    <CartButton client:idle />
                </div>
            </div>
        </div>
    </div>
</header>
