{
	"type": "module",
	"name": "storev2",
	"version": "0.0.1",
	"scripts": {
		"astro": "astro",
		"build": "astro check && astro build",
		"deploy": "alchemy deploy --app storev2 --stage prod --env-file ../../.env.prod",
		"check-types": "astro check",
		"cf-typegen": "wrangler types --env-interface CloudflareBindings",
		"destroy": "alchemy destroy",
		"dev": "NODE_TLS_REJECT_UNAUTHORIZED=0 alchemy dev --app storev2 --stage dev",
		"preview": "astro preview"
	},
	"dependencies": {
		"@astrojs/check": "^0.9.5",
		"@astrojs/sitemap": "^3.6.0",
		"@astrojs/solid-js": "^5.1.1",
		"@corvu/otp-field": "^0.1.4",
		"@kobalte/core": "^0.13.11",
		"@solid-primitives/storage": "^4.3.3",
		"@tailwindcss/forms": "^0.5",
		"@tailwindcss/vite": "^4",
		"@tanstack/solid-form": "^1.23.8",
		"@tanstack/solid-query": "^5.90.8",
		"@tanstack/solid-query-devtools": "^5.90.4",
		"@trpc/client": "^11.7.0",
		"@unpic/solid": "^1.0.0",
		"@vit/api": "workspace:*",
		"@vit/shared": "workspace:*",
		"astro": "^5.10.0",
		"astro-seo": "^0.8.4",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"embla-carousel-solid": "^8.6.0",
		"server": "workspace:*",
		"sharp": "^0.34.4",
		"solid-js": "^1.9.9",
		"superjson": "^2.2.3",
		"tailwind-merge": "^3",
		"tailwind-variants": "^3",
		"tailwindcss": "^4",
		"tw-animate-css": "^1",
		"valibot": "^1.1.0"
	},
	"devDependencies": {
		"@astrojs/cloudflare": "^12.6.10",
		"@cloudflare/workers-types": "^4.20250805.0",
		"@iconify/json": "^2.2.416",
		"alchemy": "catalog:",
		"miniflare": "^4.20250617.3",
		"typescript": "^5.9.3",
		"unplugin-icons": "^22.5.0"
	}
