# Static assets use these headers. Selected SSR catalog pages opt in through
# Astro's Cloudflare route cache provider; middleware marks private/error paths
# no-store.
/*
  Cache-Control: public, s-maxage=60, stale-while-revalidate=300

/404.html
  Cache-Control: no-store

/500.html
  Cache-Control: no-store

# Hashed static assets — immutable
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Favicon — static, rarely changes
/favicon.svg
  Cache-Control: public, max-age=2592000
