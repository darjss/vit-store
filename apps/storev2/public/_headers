# Static assets use these headers. Selected anonymous SSR catalog pages opt in
# through Astro's Cloudflare cache provider; middleware bypasses private paths.

/404.html
  Cache-Control: no-store

/500.html
  Cache-Control: no-store

# Hashed static assets — immutable
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Favicon — static, rarely changes
/favicon.svg
  Cache-Control: public, max-age=2592000
