# Static assets use these headers. Storefront SSR HTML is explicitly no-store
# in middleware until secure cross-Worker invalidation exists.

/404.html
  Cache-Control: no-store

/500.html
  Cache-Control: no-store

# Hashed static assets — immutable
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Favicon — static, rarely changes
/favicon.svg
  Cache-Control: public, max-age=2592000
