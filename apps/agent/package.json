{
	"name": "agent",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "flue dev --target cloudflare",
		"build": "flue build --target cloudflare",
		"deploy": "wrangler deploy --config dist/vit_store_agent/wrangler.json",
		"check-types": "tsgo --noEmit",
		"cf-typegen": "wrangler types --env-interface CloudflareBindings",
		"mock:messenger-text": "bun scripts/mock-messenger-text.ts",
		"mock:product-cards": "bun scripts/mock-product-cards.ts"
	},
	"dependencies": {
		"@flue/runtime": "^1.0.0-beta.3",
		"@flue/messenger": "^1.0.0-beta.1",
		"@vit/assistant": "workspace:*",
		"@warriorteam/messenger-sdk": "^1.5.3",
		"agents": "^0.14.1",
		"hono": "catalog:",
		"superjson": "^2.2.3",
		"valibot": "catalog:"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260617.1",
		"@flue/cli": "^1.0.0-beta.3",
		"typescript": "catalog:",
		"wrangler": "^4.101.0"
	}
}
