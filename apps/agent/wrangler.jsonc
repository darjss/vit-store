{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "vit-store-agent",
	"compatibility_date": "2026-06-24",
	"compatibility_flags": ["nodejs_compat"],
	"ai": {
		"binding": "AI"
	},
	// Inbound Messenger photos are staged under the `messenger-inbound/` prefix
	// (#20). R2 lifecycle rules are not expressible here (no `lifecycle` key in
	// the wrangler config schema); the short-lived cleanup rule for that prefix
	// is applied out-of-band — see `r2-lifecycle.messenger-inbound.json` and
	// `bun run r2:lifecycle:inbound`.
	"r2_buckets": [
		{
			"binding": "MESSENGER_INBOUND_BUCKET",
			"bucket_name": "vit-store-bucket-prod",
			"preview_bucket_name": "vit-store-bucket-prod"
		}
	],
	"durable_objects": {
		"bindings": [
			{
				"name": "FLUE_REGISTRY",
				"class_name": "FlueRegistry"
			},
			{
				"name": "FLUE_CUSTOMER_ASSISTANT_AGENT",
				"class_name": "FlueCustomerAssistantAgent"
			},
			{
				"name": "MESSENGER_ADMISSION_STORE",
				"class_name": "MessengerAdmissionStore"
			},
			{
				"name": "CART_STORE",
				"class_name": "CartStore"
			},
			{
				"name": "CHECKOUT_STORE",
				"class_name": "CheckoutStore"
			}
		]
	},
	"migrations": [
		{
			"tag": "v1_flue_customer_assistant",
			"new_sqlite_classes": ["FlueRegistry", "FlueCustomerAssistantAgent"]
		},
		{
			"tag": "v2_messenger_admission_store",
			"new_sqlite_classes": ["MessengerAdmissionStore"]
		},
		{
			"tag": "v3_cart_store",
			"new_sqlite_classes": ["CartStore"]
		},
		{
			"tag": "v4_checkout_store",
			"new_sqlite_classes": ["CheckoutStore"]
		}
	]
}
