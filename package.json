{
	"name": "vit-store",
	"private": true,
	"type": "module",
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"hono": "^4.8.12",
			"@trpc/server": "^11.4.3",
			"@trpc/client": "^11.4.3",
			"@t3-oss/env-core": "^0.13.10",
			"dotenv": "^17.2.1",
			"valibot": "^1.1.0",
			"typescript": "^5.9.2",
			"tsdown": "^0.15.12",
			"drizzle-orm": "^0.44.4",
			"drizzle-kit": "^0.31.4",
			"alchemy": "0.93.12"
		}
	},
	"scripts": {
		"format": "biome format --write .",
		"check": "oxlint",
		"lint": "biome lint .",
		"lint:fix": "biome check --write .",
		"lint:fix:unsafe": "biome check --write --unsafe .",
		"knip": "BUN_INSTALL=.bun BUN_TMPDIR=tmp bunx knip --workspace apps/admin --workspace apps/storev2 --workspace apps/server --workspace packages/api --workspace packages/shared --workspace packages/logger --reporter compact --no-config-hints --include files,dependencies,exports",
		"dev": "turbo dev",
		"dev:alchemy": "alchemy dev --stage dev",
		"build": "turbo build",
		"check-types": "turbo check-types",
		"deploy": "turbo deploy",
		"destroy": "turbo destroy",
		"dev:native": "turbo -F native dev",
		"dev:web": "turbo -F web dev",
		"dev:server": "turbo -F server dev",
		"db:generate": "turbo -F @vit/api db:generate",
		"db:migrate": "turbo -F server db:migrate",
		"db:migrate:local": "turbo -F server db:migrate:local",
		"db:push": "turbo -F @vit/api db:push",
		"db:studio": "turbo -F server db:studio",
		"db:studio:local": "turbo -F server db:studio:local",
		"db:seed": "turbo -F server db:seed",
		"db:docker:up": "docker-compose up -d",
		"db:docker:down": "docker-compose down",
		"start:dev": "./start-dev.sh",
		"vit:extract": "bun scripts/extract-vit-products.ts",
		"vit:compare": "bun scripts/compare-extracted-products-to-db.ts",
		"brand-logos:scrape": "bun scripts/scrape-missing-brand-logos.ts",
		"dead-code": "npx fallow dead-code",
		"health": "npx fallow health",
		"dupes": "npx fallow dupes",
		"quality": "bun run check-types && npx fallow dead-code && npx fallow health",
		"quality:json": "mkdir -p .quality && (npx fallow dead-code --format json > .quality/code-issues.json || [ $? -eq 1 ]) && (npx fallow health --format json > .quality/health-issues.json || [ $? -eq 1 ])"
	},
	"dependencies": {
		"@ai-sdk/google": "^3.0.80",
		"@corvu/drawer": "^0.2.4",
		"@t3-oss/env-core": "catalog:",
		"dotenv": "^17.2.3",
		"string-similarity": "^4.0.4",
		"valibot": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.8",
		"@cloudflare/workers-types": "^4.20260617.1",
		"@types/node": "^22.19.1",
		"alchemy": "0.93.12",
		"miniflare": "^4.20260616.0",
		"oxlint": "^1.31.0",
		"tsdown": "catalog:",
		"turbo": "^2.6.1",
		"typescript": "^5.8.3",
		"wrangler": "^4.101.0",
		"zod": "4",
		"@typescript/native-preview": "^7.0.0-dev.20251203.1"
	},
	"overrides": {
		"@solid-primitives/event-listener": "2.4.6"
	},
	"packageManager": "bun@1.3.0",
	"patchedDependencies": {
		"@solid-primitives/storage@4.3.3": "patches/@solid-primitives%2Fstorage@4.3.3.patch",
		"alchemy@0.93.12": "patches/alchemy@0.93.12.patch"
	}
}
