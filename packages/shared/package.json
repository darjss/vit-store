{
	"name": "@vit/shared",
	"type": "module",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./domain/product": {
			"types": "./src/domain/product/index.ts",
			"default": "./src/domain/product/index.ts"
		},
		"./domain/order": {
			"types": "./src/domain/order/index.ts",
			"default": "./src/domain/order/index.ts"
		},
		"./domain/payment": {
			"types": "./src/domain/payment/index.ts",
			"default": "./src/domain/payment/index.ts"
		},
		"./*": {
			"types": "./src/*.ts",
			"default": "./src/*.ts"
		}
	},
	"scripts": {
		"build": "tsdown",
		"dev": "echo 'Shared package uses source files directly - no dev build needed'"
	},
	"devDependencies": {
		"tsdown": "catalog:"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"valibot": "^1.1.0",
		"drizzle-orm": "catalog:"
	}
}
